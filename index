let _fileHandle=null;          // [GAS] ใช้เป็น flag "เชื่อมต่อแล้ว" ให้ตัวเรียกเดิม
let _driveRev=0, _driveReady=false, _dbSyncTimer=null;

// true เฉพาะตอนรันใต้ HtmlService iframe ของ GAS — ถ้าเปิดไฟล์ local/Node harness จะ false
// 🌟 เปลี่ยน URL ตรงนี้ให้เป็น Web App URL ที่ได้มาจาก Google Apps Script หลังบ้านตัวใหม่ของคุณ
const BACKEND_URL = "https://script.google.com/a/macros/kku.ac.th/s/AKfycbztdOLLLG1GdHe0lWv7fReBIkMXUsKimV5ZBMKxaPtgnRIh5gr74zECPrllLSgcwglJ/exec";
let _driveRev = 0; // ตัวแปรคอยนับเวอร์ชันฐานข้อมูลเพื่อป้องกันการเซฟทับกัน

// ฟังก์ชันดึงข้อมูลจาก Google Drive ผ่าน API ตัวใหม่
async function dbBoot(){
  try {
    updateDbUI(true, DB_NAME, true); // แสดงสถานะว่ากำลังดึงข้อมูล
    const response = await fetch(BACKEND_URL);
    const r = await response.json();
    if(r && r.ok){
      if(r.json){
        const d = migrateState(JSON.parse(r.json));
        if(d){
          _applyState(d);
          autoSave();
        }
      }
      _driveRev = r.rev || 0;
      updateDbUI(true, DB_NAME, false); // เปลี่ยนสถานะเป็น เชื่อมต่อสำเร็จ
      renderAll(); // สั่งวาดตารางและข้อมูลใหม่ทั้งหมดบนหน้าเว็บ
    }
  } catch(e) {
    updateDbUI(false);
    showToast('โหลดจาก Drive ล้มเหลว: ' + (e.message || e), 'err');
  }
}

async function dbRestoreHandle(){
  return dbBoot();
}

// ฟังก์ชันบันทึกข้อมูลและ Sync กลับไปที่ Google Drive ผ่าน API ตัวใหม่
async function dbSyncNow(){
  if(!_driveReady) return;
  try{
    updateDbUI(true, DB_NAME, true); // แสดงสถานะว่ากำลังซิงค์
    const payload = {
      json: JSON.stringify(S),
      baseRev: _driveRev
    };
    
    const response = await fetch(BACKEND_URL, {
      method: 'POST',
      body: JSON.stringify(payload)
    });
    const r = await response.json();
    
    if(r && r.ok){
      _driveRev = r.rev;
      S.settings._lastBackupTs = Date.now();
      updateDbUI(true, DB_NAME, false);
      showToast('Sync → Drive สำเร็จ', 'ok');
    } else if(r && r.conflict){
      updateDbUI(true, DB_NAME, false);
      await _handleDriveConflict(r); // กรณีมีคนเซฟตัดหน้า ระบบจะถามเพื่อดึงข้อมูลล่าสุดมาทับ
    } else {
      throw new Error('saveDB not-ok');
    }
  }catch(e){
    showToast('Sync ล้มเหลว: ' + (e.message || e), 'err');
    updateDbUI(true, DB_NAME, false);
  }
}

// มีคนอื่นเขียนทับ DB ระหว่างที่เราแก้ → ถามก่อนทับ (กัน data loss)
async function _handleDriveConflict(r){
  const ok = await confirmModal('ข้อมูลบน Drive ถูกแก้โดยผู้อื่น (rev ไม่ตรง) — โหลดเวอร์ชันล่าสุดทับของคุณ?',{danger:true});
  if(ok){
    const d = migrateState(JSON.parse(r.json));
    if(d){ _applyState(d); _driveRev = r.rev; autoSave(); showToast('โหลดเวอร์ชันล่าสุดจาก Drive แล้ว','ok'); }
  } else {
    _driveRev = r.rev;   // ยอมรับ rev ล่าสุด → กด Sync อีกครั้งจะเขียนทับด้วยของคุณ
    showToast('เก็บข้อมูลของคุณไว้ — กด 🔄 Sync อีกครั้งเพื่อเขียนทับ','warn');
  }
}

function _scheduleDbSync(){ if(!_GAS || !_driveReady) return; clearTimeout(_dbSyncTimer); _dbSyncTimer=setTimeout(dbSyncNow,1200); }

