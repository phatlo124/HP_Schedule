function doImportHistory(){
  try{
    var raw=document.getElementById('import-hist-json').value.trim();
    var d=JSON.parse(raw);
    if(typeof d!=='object'||Array.isArray(d)){showToast('รูปแบบ JSON ไม่ถูกต้อง','err');return;}
    var merged=0;
    Object.entries(d).forEach(function(entry){
      var mk=entry[0], data=entry[1];
      if(mk==='_meta') return;
      S.scheduleHistory[mk]=data;
      merged++;
    });
    closeModal('modal-import-hist');
    autoSave(); renderHistoryTab(); updateNavBadges();
    showToast('Import ประวัติสำเร็จ: '+merged+' เดือน','ok');
  }catch(e){ showToast('JSON ไม่ถูกต้อง: '+e.message,'err'); }
}
</script>
