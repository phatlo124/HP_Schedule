function setFilter(f, el){
  UI.filter=f;
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  renderStaffList();
}

function getFilteredSorted(){
  const q=(document.getElementById('staff-search')||{}).value?.toLowerCase()||'';
  UI.search=q;
  let list=S.pharmacists.filter(p=>{
    if(q && !p.name.toLowerCase().includes(q)) return false;
    switch(UI.filter){
      case 'sched':    return isSchedulable(p);
      case 'unsched':  return !isSchedulable(p);
      case 'inactive': return p.flags.inactive;
      case 'age50':    return p.flags.age50plus;
      case 'credit':   return compensationReduction(p)>0;
      default: return true;
    }
  });
  // Sort: schedulable ก่อน (ตามแผนก/สถานะขึ้นเวร) แล้วตามชื่อ
  list.sort((a,b)=>{
    const sa=isSchedulable(a), sb=isSchedulable(b);
    if(sa!==sb) return sa?-1:1;
    return a.name.localeCompare(b.name,'th');
  });
  return list;
}

