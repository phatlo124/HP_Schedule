function saveBuddyGroup(){
  const ids=_buddyCheckedIds();
  if(ids.length<2||ids.length>3){ showToast('ผูก buddy ได้ 2–3 คน','warn'); return; }
  // 1 คนอยู่ได้กลุ่มเดียว: ดึงคนที่เลือกออกจากกลุ่มอื่นก่อน แล้วทิ้งกลุ่มที่เหลือ <2
  S.buddyPairs = (S.buddyPairs||[]).map(grp=>({...grp, members:grp.members.filter(m=>!ids.includes(m))}))
