/* ══ COPY TSV → Google Sheets format ══
   Layout matches SO SMC sheet:
   Row 1 : title
   Row 2 : time ranges     (e.g. "16:30–20:30")
   Row 3 : room / location (e.g. "ห้องยากลาง AE")
   Row 4 : slot index      (1, 2, 3 …)
   Row 5+: day number + pharmacist names  ('*****' = slot doesn't exist that day)
══════════════════════════════════════════════════════ */
function copyTSV(){
  if(!S.schedule){showToast('No schedule — generate first','warn');return;}
  const m=S.schedule.month, y=S.schedule.year, cY=y-543;
  const totalDays=new Date(cY,m,0).getDate();
  const DOW_TH=['อา','จ','อ','พ','พฤ','ศ','ส'];

  /* ═══════════════════════════════════════════════════════════════════════
     FIXED GOOGLE SHEET COLUMN LAYOUT — 20 columns (A–T)
     Col 0  (A): "วันที่"
     Col 1  (B): day number + day-of-week
     Col 2–6  (C–G): KL DAY ×5        08.00–16.00 / 08.30–16.30 / …
     Col 7    (H): KL HALF ×1         09.00–12.30
     Col 8–11 (I–L): SW DAY ×4        08.00–16.00 / 08.30–16.30 / …
     Col 12–15 (M–P): KL EVE ×4       16.30–20.30
     Col 16   (Q): SW EVE ×1          16.30–20.30
     Col 17–18 (R–S): SW NIGHT ×2     16.30–23.30
     Col 19   (T): SW OVNT ×1         23.30–08.30
  ═══════════════════════════════════════════════════════════════════════ */
  const TOTAL_COLS = 20;

  // Map slot ID → fixed column index (0-based)
  const SLOT_COL = {
    kl_day_0:2, kl_day_1:3, kl_day_2:4, kl_day_3:5, kl_day_4:6,
    kl_half_0:7,
    sw_day_0:8, sw_day_1:9, sw_day_2:10, sw_day_3:11,
    kl_eve_0:12, kl_eve_1:13, kl_eve_2:14, kl_eve_3:15,
    sw_eve_0:16,
    sw_night_0:17, sw_night_1:18,
    sw_ovnt_0:19,
  };

  // Helper: build a blank row of TOTAL_COLS tabs
  const blankRow = () => new Array(TOTAL_COLS).fill('');

  // ── Row 1: Title ──────────────────────────────────────────────────────
  const r1 = blankRow();
  r1[0] = `ตารางเวรเภสัชกรประจำเดือน ${THAI_MONTHS[m]} ${y}`;

  // ── Row 2: Document reference ─────────────────────────────────────────
  const r2 = blankRow();
  r2[0] = 'เอกสารแนบท้ายคำสั่งคณะแพทยศาสตร์ที่……………………………………………...ลงวันที่........................................';

  // ── Row 3: Time ranges ────────────────────────────────────────────────
  const r3 = blankRow();
  // KL DAY ×5: alternating 08.00-16.00 / 08.30-16.30
  r3[2]='08.00 - 16.00'; r3[3]='08.30 - 16.30'; r3[4]='08.00 - 16.00';
  r3[5]='08.30 - 16.30'; r3[6]='08.00 - 16.00';
  r3[7]='09.00 - 12.30'; // HALF
  // SW DAY ×4
  r3[8]='08.00 - 16.00'; r3[9]='08.30 - 16.30';
  r3[10]='08.00 - 16.00'; r3[11]='08.30 - 16.30';
  // KL EVE ×4 + SW EVE ×1
  r3[12]='16.30 - 20.30'; r3[13]='16.30 - 20.30';
  r3[14]='16.30 - 20.30'; r3[15]='16.30 - 20.30'; r3[16]='16.30 - 20.30';
  // SW NIGHT ×2 (merged header: only first cell shows time)
  r3[17]='16.30 - 23.30'; r3[18]='';
  // SW OVNT ×1
  r3[19]='23.30 - 08.30';

  // ── Row 4: Room / unit labels ─────────────────────────────────────────
  const r4 = blankRow();
  r4[2]='ห้องยากลาง';   // spans C–H (KL DAY + HALF); rest blank = merged
  r4[8]='ห้องยา สว.';   // spans I–L (SW DAY)
  r4[12]='ห้องยากลาง';  // spans M–P (KL EVE)
  r4[16]='ห้องยา สว.';  // SW EVE
  r4[17]='ห้องยา สว.';  // SW NIGHT 1
  r4[18]='ห้องยา สว.';  // SW NIGHT 2
  r4[19]='ห้องยา สว.';  // SW OVNT

  // ── Rows 5+: Day data ─────────────────────────────────────────────────
  const bodyRows = [];
  for(let d=1; d<=totalDays; d++){
    const dayData = S.schedule.days[d];
    if(!dayData) continue;
    const dow = new Date(cY, m-1, d).getDay();
    const row = blankRow();
    row[0] = 'วันที่';
    row[1] = `${d} `;

    // Build slot lookup by id
    const slotMap = {};
    (dayData.slots||[]).forEach(sl=>{ slotMap[sl.id]=sl; });

    // Fill each fixed column
    for(const [slotId, colIdx] of Object.entries(SLOT_COL)){
      const slot = slotMap[slotId];
      if(slot === undefined){
        // Slot doesn't exist for this day type → mark with ***
        row[colIdx] = '***************';
      } else {
        row[colIdx] = slot.assignedTo || '';
      }
    }

    bodyRows.push(row);
  }

  // ── Assemble TSV ──────────────────────────────────────────────────────
  const allRows = [r1, r2, r3, r4, ...bodyRows];
  const tsv = allRows.map(row => row.join('\t')).join('\n');

  navigator.clipboard.writeText(tsv)
    .then(()=>showToast('คัดลอก TSV แล้ว — Paste ใน Google Sheets ได้เลย ✓','ok'))
    .catch(()=>{
      const ta=document.createElement('textarea');
      ta.value=tsv; ta.style.position='fixed'; ta.style.opacity='0';
      document.body.appendChild(ta); ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      showToast('คัดลอก TSV แล้ว','ok');
    });
}

