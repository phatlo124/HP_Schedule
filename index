/* ── [OVERRIDE SAFETY] Warnings for a manual slot assignment ──
   A manual override bypasses the auto-scheduler's HC + rotation logic, so we SURFACE
   (never block) any problem the change introduces, so the user can decide. Returns
   an array of human-readable warning strings for the assigned person. */
function _overrideWarnings(day, slot, name){
  const w=[]; if(!name) return w;
  const sched=S.schedule; const d=+day;
  // (1) same-day conflict (HC-2)
  const sameDay=(sched.days[d]?.slots||[]).filter(s=>s!==slot && s.assignedTo===name);
  if(sameDay.length) w.push(`${name} มีเวรอื่นในวันที่ ${d} แล้ว (${sameDay.map(s=>s.shift).join(', ')}) — เวรชนกัน`);
  // (2) OVNT consecutive days (HC-1)
  if(slot.shift==='OVNT'){
    [d-1,d+1].forEach(adj=>{
      if((sched.days[adj]?.slots||[]).some(s=>s.shift==='OVNT'&&s.assignedTo===name))
        w.push(`${name} ขึ้นเวรดึก (OVNT) ติดกับวันที่ ${adj} — ผิด HC-1`);
    });
  }
  // (3) eligibility (age50 / inactive)
  const _p=S.pharmacists.find(p=>p.name===name);
  if(_p && typeof isEligibleForShift==='function' && !isEligibleForShift(_p, slot.shift))
    w.push(`${name} ไม่มีสิทธิ์ขึ้นเวร ${slot.shift} (age50/เงื่อนไข)`);
  // (4) column (posKey) repeat — this month (excluding this slot) + previous month from history
  if(slot.posKey){
    const cntOther=Object.values(sched.days).reduce((a,dd)=>a+(dd.slots||[]).filter(s=>s!==slot&&s.posKey===slot.posKey&&s.assignedTo===name).length,0);
    if(cntOther>=1) w.push(`${name} ลงตำแหน่ง ${slot.label||slot.posKey} นี้อยู่แล้ว ${cntOther} ครั้งในเดือนนี้ (จะกลายเป็นซ้ำ)`);
    const prevMk=getPrevMonthKey();
    const prevCnt=S.scheduleHistory[prevMk]?.[name]?._byPosKey?.[slot.posKey]||0;
    if(prevCnt>0) w.push(`${name} เคยลงตำแหน่ง ${slot.label||slot.posKey} ${prevCnt} ครั้งเมื่อเดือนก่อน (${prevMk})`);
  }
  // (5) room (unit) frequent — same avg+threshold criterion as the warning badge
  const _U=slot.unit;
  if(_U && typeof repeatSchedCounts==='function'){
    const thr=S.settings.repeatThreshold ?? 1;
    const active=S.pharmacists.filter(isSchedulable).map(p=>p.name);
    const nSched=active.length||1;
    const {unit}=repeatSchedCounts(sched);
    const histAll={}; active.forEach(n=>{ histAll[n]=repeatHistCounts(n); });
    const already=(slot.assignedTo===name);
    const proj=((unit[name]&&unit[name][_U])||0) + ((histAll[name]&&histAll[name].byUnit[_U])||0) + (already?0:1);
    const counts=active.map(n=>((unit[n]&&unit[n][_U])||0)+((histAll[n]&&histAll[n].byUnit[_U])||0));
    const avg=counts.reduce((a,b)=>a+b,0)/nSched;
    if(proj>avg+thr){
      const uname=_U==='KL'?'ห้องยากลาง':_U==='SW'?'ห้องยาฉุกเฉิน':_U;
      w.push(`${name} จะได้เวร${uname} ${proj} ครั้ง (เฉลี่ยกลุ่ม ${avg.toFixed(1)} + ${thr}) — ห้องซ้ำบ่อย`);
    }
  }
  return w;
}

async function doOverride(){
  if(!S.schedule?.days?.[_overrideDay]) return;
  const slot=S.schedule.days[_overrideDay].slots.find(s=>s.id===_overrideSlotId);
  if(!slot) return;

  const newName = document.getElementById('override-select').value||null;
  const oldName = slot.assignedTo||null;
  const slotHrs = getSlotMeta(slot).hours;

  if(newName && newName!==oldName){
    const newP0 = S.pharmacists.find(x=>x.name===newName);
    if(newP0 && newP0.flags.inactive){ showToast('ไม่สามารถจัดเวรให้คนที่ปิดการใช้งาน','warn'); return; }
    // ── [OVERRIDE SAFETY] pre-commit conflict check → supervisor confirmation pop-up ──
    // (same-day conflict is already blocked in the dropdown; this catches column repeat,
    //  OVNT-consecutive, eligibility, and any other logic conflict.)
    const warns = _overrideWarnings(_overrideDay, slot, newName);
    if(warns.length){
      const ok = await confirmModal('การจัดเวรนี้ขัดกับเงื่อนไข:\n\n• ' + warns.join('\n• ')
        + '\n\nหัวหน้ายืนยันที่จะจัดเวรนี้หรือไม่?', {danger:true, title:'⚠️ ขัดกับเงื่อนไขการจัดเวร'});
      if(!ok) return;   // declined → abort with no change
    }
  }

  // ── commit: deduct old / assign / add new (S.schedule.stats ใช้โดยแท็บ 06) ──
  if(oldName && oldName !== newName){
    const oldP = S.pharmacists.find(x=>x.name===oldName);
    if(oldP && S.schedule.stats?.[oldP.id]){
      const sc = S.schedule.stats[oldP.id];
      sc[slot.shift] = Math.max(0,(sc[slot.shift]||0)-1);
      sc.hours = Math.max(0, Math.round(((sc.hours||0) - slotHrs)*10)/10);
    }
  }
  slot.assignedTo = newName;
  slot.locked = document.getElementById('override-lock').checked;
  if(newName && newName !== oldName){
    const newP = S.pharmacists.find(x=>x.name===newName);
    if(newP){
      if(!S.schedule.stats) S.schedule.stats={};
      if(!S.schedule.stats[newP.id]) S.schedule.stats[newP.id]={hours:0};
      const sc = S.schedule.stats[newP.id];
      sc[slot.shift] = (sc[slot.shift]||0)+1;
      sc.hours = Math.round(((sc.hours||0) + slotHrs)*10)/10;
    }
  }

  // re-validate HC-1/2/3 so the Violations panel + over-hour flags reflect the change
  const prevLastOvnt = S.scheduleHistory[getPrevMonthKey()]?._meta?.lastOvnt || null;
  S.schedule.violations = validateSchedule(S.schedule, prevLastOvnt);

  closeModal('modal-override');
  autoSave(); renderGenerateTab(); renderStatsTab();   // both views recompute from live slots
  if(S.schedule.violations.length) showToast(`บันทึกแล้ว — พบ ${S.schedule.violations.length} ข้อขัดแย้ง (ดูแผง Violations)`,'warn');
  else                             showToast('บันทึกการแก้ไขแล้ว ✓','ok');
}


/* ══════════════════════════════════════════════════════════
   STATS TAB — Part E
══════════════════════════════════════════════════════════ */
function computeSigma(hours){
  if(!hours.length) return 0;
  const mean=hours.reduce((a,b)=>a+b,0)/hours.length;
  const variance=hours.reduce((s,h)=>s+Math.pow(h-mean,2),0)/hours.length;
  return Math.sqrt(variance);
}

/* [STATS v4_2_7] median + IQR (robust สำหรับชั่วโมงสะสมที่ non-normal — เบ้ซ้ายจากหาง part-time/newbie)
   ใช้ linear interpolation (วิธีเดียวกับ numpy default) · คืน {median,q1,q3,iqr} · ทน outlier */
function medianIQR(arr){
  const a = arr.slice().filter(v => v != null && !isNaN(v)).sort((x,y)=>x-y);
  const n = a.length;
  if(!n) return { median:0, q1:0, q3:0, iqr:0, n:0 };
  const q = p => {
    const idx = p * (n - 1);
    const lo = Math.floor(idx), hi = Math.ceil(idx);
    if(lo === hi) return a[lo];
    return a[lo] + (a[hi] - a[lo]) * (idx - lo);
  };
  const q1 = q(0.25), median = q(0.5), q3 = q(0.75);
  return { median, q1, q3, iqr:+(q3 - q1).toFixed(4), n };
}

/* ══════════════════════════════════════════════════════════
   HISTORICAL HOURS MATRIX — แท็บ 08
   Reads: S.scheduleHistory, S.pharmacists  (read-only)
   Writes to: #history-matrix-wrap
══════════════════════════════════════════════════════════ */
function renderHistoryMatrix(opts) {
  opts = opts || {};
  const monthsLimit = opts.monthsLimit || 12;
  const wrap = opts.returnHTML ? null : document.getElementById('history-matrix-wrap');
  if (!opts.returnHTML && !wrap) return;

  const histKeys = Object.keys(S.scheduleHistory).sort();
  if (histKeys.length < 2) {
    const emptyHtml = '<div class="panel"><div class="panel-head"><h3>📈 สะสมชั่วโมงย้อนหลัง</h3></div>'
      + '<div style="padding:24px"><div class="empty-state" style="min-height:90px">'
      + '<div class="empty-icon">📅</div><div class="empty-title">ต้องการข้อมูลอย่างน้อย 2 เดือน</div>'
      + '<div class="empty-sub">เพื่อแสดงสถิติสะสมย้อนหลัง</div></div></div></div>';
    if (opts.returnHTML) return emptyHtml;
    wrap.innerHTML = emptyHtml;
    return;
  }

  // Rolling last-N months (จอ = 12 · พิมพ์ = 6 เพื่อให้พอดี A4 และเห็นคอลัมน์สะสมเสมอ)
  const cols        = histKeys.slice(-monthsLimit);
  const latestMk    = cols[cols.length - 1];
  const cumHrs      = S.scheduleHistory[latestMk]?._meta?._cumulativeHrs || {};
  const cumFrom     = S.scheduleHistory[latestMk]?._meta?._cumulativeFrom || latestMk;
  const monthCount  = cols.length;

  // Sort by descending cumulative hours (most → least); ties broken by name
  const activeStaff = S.pharmacists.filter(isSchedulable)
    .sort((a, b) => {
      const diff = (cumHrs[b.name] || 0) - (cumHrs[a.name] || 0);
      if (diff !== 0) return diff;
      return a.name.localeCompare(b.name, 'th');
    });

  // Per-column min/max for cell highlighting (active staff only, exclude nulls)
  const colMinMax = {};
  cols.forEach(mk => {
    const vals = activeStaff
      .map(p => { const gt = S.scheduleHistory[mk]?.[p.name]?.grandTotal; return (gt !== undefined && gt !== null) ? gt : null; })
      .filter(v => v !== null);
    colMinMax[mk] = { max: vals.length ? Math.max(...vals) : null, min: vals.length ? Math.min(...vals) : null, count: vals.length };
  });

  // Year-total stats across all active staff
  // [STATS v4_2_7] ชั่วโมงสะสม non-normal (เบ้ซ้าย) → ใช้ median ± IQR แทน mean ± σ
  const allCumVals      = activeStaff.map(p => cumHrs[p.name] || 0);
  const maxCum          = allCumVals.length ? Math.max(...allCumVals, 0.01) : 1;
  const cumValsWorked   = allCumVals.filter(v => v > 0);   // ไม่นับคนที่ไม่มีชั่วโมงสะสม
  const cumStat         = medianIQR(cumValsWorked);        // {median,q1,q3,iqr,n}
  const cumMedian       = cumStat.median;
  const cumIQR          = cumStat.iqr;
  // Tukey fences (robust outlier rule) — แทน threshold 4×monthCount เดิมที่อิง σ
  const fenceLo         = cumStat.q1 - 1.5 * cumIQR;
  const fenceHi         = cumStat.q3 + 1.5 * cumIQR;
  const isCumOutlier    = v => (v > 0) && (v < fenceLo || v > fenceHi);
  const nOutliers       = cumValsWorked.filter(isCumOutlier).length;

  // Column headers: "ม.ค. 68" format
  const colHeaders = cols.map(mk => {
    const [y, m] = mk.split('-').map(Number);
    return THAI_MONTHS_SHORT[m] + '\u00a0' + String(y).slice(-2);
  });

  // ── thead ──
  const thead = '<tr style="background:var(--navy);color:#fff;position:sticky;top:0;z-index:2">'
    + '<th style="min-width:110px;text-align:left;padding:6px 10px;white-space:nowrap">ชื่อ</th>'
    + '<th style="min-width:160px;padding:4px 10px;color:var(--gold-light);text-align:left">📊 สถิติสะสม</th>'
    + colHeaders.map(h => '<th style="min-width:70px;white-space:nowrap;padding:4px 6px;font-size:0.73rem;text-align:center">' + h + '</th>').join('')
    + '</tr>';

  // ── tbody (fills colTotals as side-effect) ──
  const colTotals = cols.map(() => 0);
  const tBody = activeStaff.map(p => {
    const monthlySeries = cols.map((mk, ci) => {
      const gt = S.scheduleHistory[mk]?.[p.name]?.grandTotal;
      if (gt === undefined || gt === null) return null;
      colTotals[ci] += gt;
      return gt;
    });

    const cells = monthlySeries.map((v, ci) => {
      if (v === null) return '<td style="text-align:center;color:var(--text3);font-size:0.7rem;padding:1px 6px">—</td>';
      const { max, min } = colMinMax[cols[ci]];
      let bg = '';
      if (v === max && max !== min) bg = 'background:var(--amber-light);font-weight:700;';
      else if (v === min && max !== min) bg = 'background:var(--teal-light);font-weight:700;';
      return '<td style="text-align:center;' + bg + 'font-size:0.72rem;padding:1px 6px">' + v.toFixed(1) + '</td>';
    }).join('');

    // Year-total cell: 4-stack layout
    const cum      = cumHrs[p.name] || 0;
    const mCt      = monthlySeries.filter(v => v !== null).length;
    const avg      = mCt > 0 ? cum / mCt : 0;
    const dev      = +(cum - cumMedian).toFixed(1);   // [v4_2_7] เทียบ median (robust) แทน mean
    const devSign  = dev >= 0 ? '+' : '';
    const outlier  = isCumOutlier(cum);               // นอก Tukey fence = ผิดปกติจริง
    const devColor = outlier ? 'var(--red)' : 'var(--text2)';
    const pSeries  = monthlySeries.filter(v => v !== null);
    const indivSig = computeSigma(pSeries);
    const pct      = maxCum > 0 ? Math.round(cum / maxCum * 100) : 0;
    const barColor = outlier ? 'var(--amber)' : 'var(--teal)';

    const ytCell = '<td style="padding:2px 8px;min-width:160px;vertical-align:top;border-right:1px solid #e5e5e5">'
      + '<div style="font-size:0.8rem;font-weight:700;color:var(--teal);line-height:1.15">' + cum.toFixed(1) + ' ชม.</div>'
      + '<div style="font-size:0.62rem;color:var(--text2);line-height:1.2">⌀\u00a0' + avg.toFixed(1) + ' ชม./เดือน</div>'
      + '<div style="font-size:0.62rem;line-height:1.2;color:' + devColor + '">σ\u00a0' + indivSig.toFixed(1)
        + '\u00a0<span>[' + devSign + dev + ' จาก median]</span></div>'
      + '<div style="margin-top:1px;display:flex;align-items:center;gap:4px">'
        + '<div style="flex:1;height:4px;background:#e5e5e5;border-radius:3px;overflow:hidden">'
          + '<div style="height:100%;width:' + pct + '%;background:' + barColor + ';border-radius:3px"></div>'
        + '</div>'
        + '<span style="font-family:\'IBM Plex Mono\',monospace;font-size:0.6rem;color:var(--text3)">' + pct + '%</span>'
      + '</div>'
      + '</td>';

    return '<tr>'
      + '<td style="padding:2px 8px;white-space:nowrap;font-weight:500;font-size:0.74rem">' + p.name + '</td>'
      + ytCell + cells
      + '</tr>';
  }).join('');

  // ── tfoot ──
  const footCells = cols.map((mk, ci) => {
    const total        = colTotals[ci];
    const cnt          = colMinMax[mk].count || 0;
    const avg          = cnt > 0 ? +(total / cnt).toFixed(1) : null;
    const badge        = avg !== null
      ? '<br><span style="font-size:0.63rem;padding:1px 5px;border-radius:8px;'
          + 'background:var(--teal);color:#fff">'
          + '\u2300\u00a0' + avg + ' /คน</span>'
      : '';
    return '<td style="text-align:center;font-size:0.78rem;font-weight:700;padding:4px 6px;line-height:1.6">'
      + total.toFixed(1) + badge + '</td>';
  }).join('');

  const teamTotal     = allCumVals.reduce((a, b) => a + b, 0);
  const teamAvgPerson = allCumVals.length ? teamTotal / allCumVals.length : 0;
  // [STATS v4_2_7] ยุติธรรมสะสม = ไม่มีใครหลุด Tukey fence (median ± 1.5·IQR)
  const fairOk        = nOutliers === 0;
  const footYt = '<td style="padding:6px 8px;font-size:0.73rem;line-height:1.6;vertical-align:top;border-right:1px solid rgba(255,255,255,.15)">'
    + '<div style="font-weight:700;color:var(--gold-light)">รวมทีม: ' + teamTotal.toFixed(1) + ' ชม.</div>'
    + '<div>⌀ ' + teamAvgPerson.toFixed(1) + ' ชม./คน</div>'
    + '<div title="ชั่วโมงสะสมเบ้ (non-normal) จึงใช้ median ± IQR แทน mean ± σ">Median: ' + cumMedian.toFixed(1) + ' ชม. · IQR ' + cumIQR.toFixed(1)
      + ' <span style="opacity:.8;font-size:0.66rem">(Q1–Q3 ' + cumStat.q1.toFixed(1) + '–' + cumStat.q3.toFixed(1) + ')</span></div>'
    + '<div>'
      + '<span style="padding:1px 7px;border-radius:10px;font-size:0.66rem;'
        + 'background:' + (fairOk ? 'var(--green)' : 'var(--red)') + ';color:#fff">'
        + (fairOk ? 'ยุติธรรมสะสม' : ('ควรตรวจสอบ · ' + nOutliers + ' outlier')) + '</span></div>'
    + '</td>';

  const tFoot = '<tr style="background:var(--navy2);color:#fff;font-weight:700">'
    + '<td style="padding:5px 10px">รวม</td>'
    + footYt + footCells
    + '</tr>';

  // Cumulative-from label
  const [_cfY, _cfM] = cumFrom.split('-').map(Number);
  const cumFromLabel  = THAI_MONTHS_SHORT[_cfM] + '\u00a0' + String(_cfY).slice(-2);

  const html = '<div class="panel">'
    + '<div class="panel-head">'
      + '<h3>📈 สะสมชั่วโมงย้อนหลัง</h3>'
      + '<span style="font-size:0.68rem;color:var(--gold-light);opacity:.75">สะสมตั้งแต่\u00a0'
        + cumFromLabel + '\u00a0·\u00a0' + monthCount + '\u00a0เดือน</span>'
    + '</div>'
    + '<div style="overflow-x:auto">'
      + '<table class="stats-table" style="border-collapse:collapse;width:100%;min-width:600px">'
        + '<thead>' + thead + '</thead>'
        + '<tbody>' + tBody + '</tbody>'
        + '<tfoot>' + tFoot + '</tfoot>'
      + '</table>'
    + '</div>'
    + '</div>';
  if (opts.returnHTML) return html;
  wrap.innerHTML = html;

  // ── [FEATURE-2] Column-Based Position Saturation Index ──
  (function(){
    const posLabel = {};
    Object.values(S.positions || {}).forEach(pm =>
      Object.entries(pm).forEach(([k, v]) => { if (!posLabel[k]) posLabel[k] = v.label; }));
    const cumByPos = {};
    let anyData = false;
    activeStaff.forEach(p => { cumByPos[p.name] = {}; });
    cols.forEach(mk => {
      const ent = S.scheduleHistory[mk]; if (!ent) return;
      activeStaff.forEach(p => {
        const bk = ent[p.name] && ent[p.name]._byPosKey; if (!bk) return;
        Object.entries(bk).forEach(([k, c]) => { cumByPos[p.name][k] = (cumByPos[p.name][k] || 0) + c; anyData = true; });
      });
    });
    let html = '<div class="panel" style="margin-top:14px">'
      + '<div class="panel-head"><h3>📊 สถิติการกระจายตำแหน่งตามคอลัมน์ '
        + '<span style="font-weight:400;opacity:.7">(Column-Based Position Saturation Index)</span></h3></div>'
      + '<div style="padding:10px 12px">';
    if (!anyData) {
      html += '<div style="font-size:0.78rem;color:var(--text3);line-height:1.6">'
        + '&#9432; ยังไม่มีข้อมูลการกระจายตำแหน่งรายคอลัมน์ — ดัชนีนี้เริ่มสะสมหลัง Archive '
        + 'เดือนถัดไป (ประวัติที่บันทึกก่อนเวอร์ชันนี้ไม่มีข้อมูลราย posKey)</div>';
    } else {
      const ranking = activeStaff.map(p => {
        const m = cumByPos[p.name]; const total = Object.values(m).reduce((a, b) => a + b, 0);
        let topK = null, topC = 0;
        Object.entries(m).forEach(([k, c]) => { if (c > topC) { topC = c; topK = k; } });
        return { name: p.name, total, topK, share: total ? topC / total : 0 };
      }).filter(r => r.total > 0).sort((a, b) => b.share - a.share);
      const meanShare = ranking.length ? ranking.reduce((a, r) => a + r.share, 0) / ranking.length : 0;
      html += ranking.map(r => {
        const skewed = r.share >= 0.5 && r.share >= meanShare + 0.10;
        const pct = Math.round(r.share * 100);
        const lab = posLabel[r.topK] || r.topK || '—';
        const color = skewed ? 'var(--red)' : 'inherit';
        const badge = skewed
          ? '<span style="margin-left:6px;font-size:0.66rem;padding:1px 7px;border-radius:10px;background:var(--red);color:#fff">เอนเอียงสูง</span>'
          : '';
        return '<div style="display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid #f0ede5;font-size:0.78rem">'
          + '<span style="flex:0 0 130px;font-weight:600">' + r.name + '</span>'
          + '<span style="flex:1;color:' + color + '">'
            + (skewed
                ? 'มีประวัติซ้ำตำแหน่งในคอลัมน์ <b>' + lab + '</b> สูงที่สุดกว่าค่าเฉลี่ยอย่างมีนัยสำคัญ'
                : 'คอลัมน์เด่น: ' + lab)
          + '</span>'
          + '<span style="flex:0 0 56px;text-align:right;font-family:\'IBM Plex Mono\',monospace;color:' + color + '">'
            + pct + '%</span>' + badge
          + '</div>';
      }).join('');
      html += '<div style="margin-top:8px;font-size:0.7rem;color:var(--text3)">'
        + '% = สัดส่วนเวรที่กระจุกในคอลัมน์เดียวจากเวรสะสมทั้งหมด · ค่าเฉลี่ยกลุ่ม ' + Math.round(meanShare * 100) + '%'
        + ' · ผู้ที่ “เอนเอียงสูง” ควรถูกจัดสลับไปคอลัมน์อื่นในเดือนถัดไป</div>';
    }
    html += '</div></div>';
    wrap.innerHTML += html;
  })();
}

function renderStatsTab(){
  const btnTSV     = document.getElementById('btn-copy-tsv');
  const btnExport  = document.getElementById('btn-export-sched');
  const btnArchive = document.getElementById('btn-archive-sched');
  const sigEl=document.getElementById('stats-sigma');
  const sigSub=document.getElementById('stats-sigma-sub');
  const emptyEl=document.getElementById('stats-empty');
  const wrap=document.getElementById('stats-table-wrap');

  if(!S.schedule){
    if(sigEl){sigEl.textContent='—';sigEl.className='sigma-badge';}
    if(sigSub) sigSub.textContent='สร้างตารางก่อน';
    if(emptyEl) emptyEl.textContent='—';
    if(btnTSV) btnTSV.disabled=true;
    if(btnExport) btnExport.disabled=true;
    if(btnArchive) btnArchive.disabled=true;
    if(wrap) wrap.innerHTML='<div class="empty-state" style="min-height:180px"><div class="empty-icon">📊</div><div class="empty-title">ยังไม่มีข้อมูล</div><div class="empty-sub">สร้างตารางเวรในแท็บ 06 ก่อน</div></div>';
    return;
  }
  if(btnTSV) btnTSV.disabled=false;
  if(btnExport) btnExport.disabled=false;
  if(btnArchive) btnArchive.disabled=false;

  // ── Month key for this schedule ──
  const schedMk=monthKey(S.schedule.month, S.schedule.year);

  // ── Shift counts ──
  const activeStaff=S.pharmacists.filter(isSchedulable);
  const staffCounts={};
  // ── Load BF from previous month's ledger ──
  const _statsPrevMk = getPrevMonthKey();
  const _statsPrevLO = (S.scheduleHistory[_statsPrevMk]?._meta?.leftoverByName) || {};
  const _statsCreditHrs = S.settings.hoursPerCredit || 8;
  const _statsEveHrs    = SHIFT_META.EVE?.hours || 4;
  // ── role-aware comp totals (mirrors runScheduler effective pool) ──
  const _statsShownRoles = getCompRoles().filter(r => activeStaff.some(p => (+(p.comp[r.id]||0))>0));
  activeStaff.forEach(p=>{
    const prevLO = _statsPrevLO[p.name] || {};
    const roleComp={}; let compTotal=0, bf=0, deduct=0;
    getCompRoles().forEach(r=>{
      const typed=+(p.comp[r.id]||0); const lo=+(prevLO[r.id]||0);
      roleComp[r.id]=typed; compTotal+=typed; bf+=lo;
      if(r.needsComp){ const rate=r.hoursPerCredit||0; if(rate>0) deduct+=Math.floor((typed+lo)/rate); }
    });
    staffCounts[p.name]={
      id:p.id, kl_day:0, sw_day:0, ae:0, night:0, ovnt:0,
      total:0, hrs:0,
      roleComp, compTotal:+compTotal.toFixed(2),
      deduct,
      grandTotal:0, schedRank:isSchedulable(p)?0:1,
      bf:+bf.toFixed(2)
    };
  });

  let totalSlots=0, filledSlots=0;
  Object.values(S.schedule.days).forEach(day=>{
    day.slots.forEach(sl=>{
      totalSlots++;
      if(sl.assignedTo){
        filledSlots++;
        const st=staffCounts[sl.assignedTo];
        if(st){
          st.total++;
          const hrs=getSlotMeta(sl).hours;
          st.hrs+=hrs;
          // [FEATURE-1] per-column (posKey) tally for repetition detection
          if(sl.posKey){ st.byPosKey = st.byPosKey || {}; st.byPosKey[sl.posKey] = (st.byPosKey[sl.posKey]||0) + 1; }
          const isFull=(sl.shift==='DAY'||sl.shift==='HALF');
          if(isFull&&sl.unit==='KL') st.kl_day++;
          else if(isFull&&sl.unit==='SW') st.sw_day++;
          else if(sl.shift==='EVE') st.ae++;
          else if(sl.shift==='NIGHT') st.night++;
          else if(sl.shift==='OVNT') st.ovnt++;
          // [SLOT-POS] เก็บ posKey ที่แต่ละคนได้รับ (1-indexed, ข้าม OVNT) เพื่อแสดง slot position ใน stats
          if(sl.posKey && sl.shift!=='OVNT'){
            st.slotPos = st.slotPos || {};
            st.slotPos[sl.posKey] = st.slotPos[sl.posKey] || [];
            st.slotPos[sl.posKey].push((sl.slotIdx ?? 0) + 1); // 1-indexed
          }
        }
      }
    });
  });

  const rows=[];
  activeStaff.forEach(p=>{
    const st=staffCounts[p.name];
    if(st){ st.grandTotal=st.hrs+st.compTotal; rows.push({name:p.name,...st}); }
  });

  if(emptyEl) emptyEl.textContent=`${totalSlots-filledSlots}/${totalSlots}`;

  const hrs=rows.map(r=>r.hrs);
  const sigma=computeSigma(hrs);
  // [FAIRNESS-FIX] sigma_noOT = σ ของ schedHrs เฉพาะคนที่ไม่มี OT (compTotal=0).
  // นี่คือ metric ที่ "อ้างอิงได้" ว่า algorithm จัดเวรยุติธรรม — คน OT คลังถูก Virtual
  // Hours engine ลดเวรให้โดยตั้งใจ → schedHrs ต่ำ ถ้านับรวมจะทำให้ σ พุ่งโดยไม่มีความหมาย.
  const hrsNoOT=rows.filter(r=>!r.compTotal||r.compTotal===0).map(r=>r.hrs);
  const sigmaNoOT=hrsNoOT.length>=2?computeSigma(hrsNoOT):sigma;
  // [SAFEGUARD] เมื่อกลุ่ม no-OT เล็กลง (สัดส่วน OT สูง) σ no-OT เริ่มไม่เสถียร (n น้อย → แกว่งง่าย)
  // เตือน admin ไม่ให้อ้างอิง σ no-OT มากเกินไปถ้ากลุ่มอ้างอิงเล็ก. เกณฑ์: OT > 40% ของ schedulable.
  const _otCount=rows.filter(r=>r.compTotal>0).length;
  const _otRatio=rows.length? _otCount/rows.length : 0;
  const _otWarn = _otRatio>0.40;
  if(sigEl){
    // แสดง σ no-OT เป็นค่าหลัก (อ้างอิงได้)
    sigEl.textContent=sigmaNoOT.toFixed(2);
    sigEl.className='sigma-badge '+(sigmaNoOT<=3?'sigma-ok':sigmaNoOT<=6?'sigma-warn':'sigma-bad');
  }
if(sigSub){
    const lbl0=sigmaNoOT<=3?'ยอดเยี่ยม (≤3)':sigmaNoOT<=6?'ดี (≤6)':'ปรับปรุงได้';
    const warnLine = _otWarn
      ? `<br><span style="font-size:.82em;color:var(--red);font-weight:600">⚠ OT ${Math.round(_otRatio*100)}% ของทีม (n no-OT=${hrsNoOT.length}) — σ no-OT เริ่มอ้างอิงได้น้อยลง กลุ่มอ้างอิงเล็ก</span>`
      : '';
    sigSub.innerHTML=`${lbl0} · เฉพาะคนไม่มี OT (n=${hrsNoOT.length})<br><span style="font-size:.9em;opacity:.7">σ ทุกคน: ${sigma.toFixed(2)} (รวม OT)</span>${warnLine}`;
    const dsSig=document.getElementById('sc-sigma');
    const dsSigSub=document.getElementById('sc-sigma-sub');
    if(dsSig) dsSig.textContent=sigmaNoOT.toFixed(2);
    if(dsSigSub) dsSigSub.innerHTML=`${sigmaNoOT<=3?'ยอดเยี่ยม':sigmaNoOT<=6?'ดี':'ควรปรับปรุง'}<br><span style="font-size:.9em;opacity:.7">ทุกคน: ${sigma.toFixed(2)}</span>${_otWarn?'<br><span style="font-size:.8em;color:var(--red)">⚠ OT '+Math.round(_otRatio*100)+'%</span>':''}`;
  }

  // PATCH-2: Variance badge below Sigma card (รวมชั่วโมง/เดือน spread)
  const grandArr=rows.map(r=>r.grandTotal);
  let varBadgeEl=document.getElementById('stats-variance-badge');
  if(!varBadgeEl){
    const sigCard=sigEl&&sigEl.closest('.stat-card');
    if(!sigCard){ /* DOM not ready — skip badge render */ }
    else {
      varBadgeEl=document.createElement('div');
      varBadgeEl.id='stats-variance-badge';
      varBadgeEl.style.cssText='margin-top:6px;font-size:0.72rem;line-height:1.4;';
      sigCard.appendChild(varBadgeEl);
    }
  }
  if(grandArr.length>=2){
    // [FAIRNESS-FIX] แยก spread เวรล้วน (no-OT) ออกจาก spread ภาระรวมจริง
    // no-OT = วัดว่า algorithm จัดเวรยุติธรรมแค่ไหน (อ้างอิงได้)
    const hrsOnlyNoOT=rows.filter(r=>!r.compTotal||r.compTotal===0).map(r=>r.hrs);
    const spreadNoOT=hrsOnlyNoOT.length>=2
      ? Math.round((Math.max(...hrsOnlyNoOT)-Math.min(...hrsOnlyNoOT))*10)/10
      : null;
    // [OPTION-1] "ภาระรวมจริง" = schedHrs + OT ที่หักออกจริง (compVirtualHours = ตัดเศษ BF ที่ยกไป)
    // แทน grandTotal เดิมที่รวมเศษ OT → ทำให้คน OT ดูสูงเกินจริง. วิธีนี้สะท้อนภาระที่แบกจริงเดือนนี้.
    const realLoadArr = rows.map(r=>{
      const p = (typeof S!=='undefined') && S.pharmacists ? S.pharmacists.find(x=>x.name===r.name) : null;
      const compReal = (p && typeof compVirtualHours==='function') ? compVirtualHours(p.comp) : (r.compTotal||0);
      return r.hrs + compReal;
    });
    const vMax=Math.max(...realLoadArr), vMin=Math.min(...realLoadArr);
    const spreadReal=Math.round((vMax-vMin)*10)/10;
    const noOTLine = spreadNoOT!==null
      ? (spreadNoOT<=8
          ? `<span style="color:var(--green);font-weight:600">✓ ชม.เวรล้วน (ไม่มี OT): ห่างกัน ${spreadNoOT} ชม. [ยอมรับได้]</span>`
          : `<span style="color:var(--red);font-weight:600">&#9888; ชม.เวรล้วน (ไม่มี OT): ห่างกัน ${spreadNoOT} ชม. [ควรตรวจสอบ]</span>`)
      : '';
    const realLine=`<span style="font-size:.92em;color:var(--text3)">&#9432; ภาระรวมจริง (เวร + OT ที่หักจริง): ห่างกัน ${spreadReal} ชม. (ไม่นับเศษ OT ที่ยกไปเดือนหน้า)</span>`;
    varBadgeEl.innerHTML=noOTLine+(noOTLine?'<br>':'')+realLine;
  } else {
    varBadgeEl.innerHTML='';
  }

  if(!wrap) return;
  rows.sort((a,b)=>{
    if(a.schedRank!==b.schedRank) return a.schedRank-b.schedRank;
    return a.name.localeCompare(b.name,'th');
  });

let totalRow={kl_day:0,sw_day:0,ae:0,night:0,ovnt:0,total:0,hrs:0,roleTot:{},deduct:0,grandTotal:0,bf:0};
  _statsShownRoles.forEach(r=>{ totalRow.roleTot[r.id]=0; });
  // [_slotPfx] helper: สร้าง "(pfx#1, pfx#2)" จาก array ของ 1-indexed positions
  const _fmtPos = (pfxKeys, slotPos) => {
    if (!slotPos) return '';
    const parts = [];
    pfxKeys.forEach(([pfx, pk]) => {
      const arr = slotPos[pk];
      if (arr && arr.length) arr.forEach(n => parts.push(`${pfx}#${n}`));
    });
    return parts.length ? ` <span style="font-size:0.68rem;opacity:0.75;font-weight:400">(${parts.join(', ')})</span>` : '';
  };
  // PATCH-1A: combined KL/SW cell helper — คอลัมน์ KL/SW = kl_day, kl_half, sw_day
  const mkKlSwPos=(kl,sw,slotPos)=>{
    const pills=[];
    if(kl>0){
      const pos=_fmtPos([['day','kl_day'],['half','kl_half']],slotPos);
      pills.push(`<span class="badge badge-teal" style="font-size:0.75rem;display:block;margin-bottom:2px">KL ×${kl}${pos}</span>`);
    }
    if(sw>0){
      const pos=_fmtPos([['sw','sw_day']],slotPos);
      pills.push(`<span class="badge badge-gold" style="font-size:0.75rem;display:block">SW ×${sw}${pos}</span>`);
    }
    return `<td class="${(kl+sw)===0?'zero':''}" style="white-space:nowrap;width:1%;min-width:85px;font-size:0.73rem">${pills.length?pills.join(''):'<span style="color:var(--text3)">&#8212;</span>'}</td>`;
  };
  // AE cell — คอลัมน์ AE = kl_eve, sw_eve (แยก prefix ชัดเจน)
  const mkAePos=(ae,slotPos)=>{
    const pos=_fmtPos([['kl-eve','kl_eve'],['sw-eve','sw_eve']],slotPos);
    return `<td class="${ae===0?'zero':''}"><span class="badge badge-navy" style="font-size:0.75rem">${ae||'&#8212;'}${pos}</span></td>`;
  };
  // บ่าย cell — คอลัมน์ บ่าย = sw_night
  const mkNightPos=(night,slotPos)=>{
    const pos=_fmtPos([['night','sw_night']],slotPos);
    return `<td class="${night===0?'zero':''}"><span class="badge badge-amber" style="font-size:0.75rem">${night||'&#8212;'}${pos}</span></td>`;
  };
  const mkCell=(v,cls)=>`<td class="${v===0?'zero':''}"><span class="badge badge-${cls}" style="font-size:0.75rem">${v||'&#8212;'}</span></td>`;
  // [FEATURE-1] column-position label lookup + concentration warning (>50% in one column)
  const _posLabel = {};
  Object.values(S.positions || {}).forEach(pm =>
    Object.entries(pm).forEach(([k, v]) => { if (!_posLabel[k]) _posLabel[k] = v.label; }));
  const REPEAT_THRESH = 0.5;   // >50% ของเวรทั้งหมดกระจุกในคอลัมน์เดียว
  const REPEAT_MIN    = 3;     // ต้องมีเวรอย่างน้อย 3 ก่อนจึงเตือน (กัน false positive)
  // [PART C] group-average per posKey (จาก repeatWarnings ที่คำนวณ count+avg ไว้แล้ว)
  // เพื่อแสดง "N× · เฉลี่ย M×" และแยกระดับ เฝ้าระวัง/วิกฤต. build ครั้งเดียวก่อน loop rows.
  const _rwData = (typeof repeatWarnings==='function') ? repeatWarnings() : {column:[],room:[]};
  const _rwAvgByPos = {};   // posKey -> group avg (เท่ากันทุกคนใน posKey เดียว)
  const _rwByName = {};     // name -> { posKey -> {count, avg} }
  (_rwData.column||[]).forEach(it=>{
    _rwAvgByPos[it.posKey] = it.avg;
    (_rwByName[it.name] = _rwByName[it.name]||{})[it.posKey] = {count:it.count, avg:it.avg};
  });
  function colRepeatWarn(byPosKey, name){
    // รวมเดือนปัจจุบัน + ประวัติข้ามเดือน (rolling window) → track ตำแหน่งซ้ำ "ก่อนเวียนครบรอบ"
    const combined = {};
    Object.entries(byPosKey || {}).forEach(([k, c]) => { combined[k] = (combined[k]||0) + c; });
    if (typeof repeatHistCounts === 'function' && name) {
      const h = (repeatHistCounts(name) || {}).byPosKey || {};
      Object.entries(h).forEach(([k, c]) => { combined[k] = (combined[k]||0) + c; });
    }
    const keys = Object.keys(combined);
    if (!keys.length) return '';
    // [PART C] helper: render 3-tier badge ด้วยตัวเลข count + group avg
    const _tierBadge = (pk, cnt) => {
      const lab = _posLabel[pk] || pk;
      const avg = _rwAvgByPos[pk];
      const avgTxt = (typeof avg==='number') ? ` · เฉลี่ย ${avg.toFixed(1)}×` : '';
      const over = (typeof avg==='number') ? (cnt - avg) : null;
      // วิกฤต: เกินเฉลี่ย ≥2 · เฝ้าระวัง: เกิน ≥1 (หรือไม่มี avg = fallback แดง)
      if (over!==null && over>=2)
        return `<div style='font-size:11px;color:var(--red);font-weight:600'>🔴 กระจุก ${lab} (${cnt}×${avgTxt})</div>`;
      return `<div style='font-size:11px;color:var(--amber);font-weight:500'>⚠ ซ้ำ ${lab} (${cnt}×${avgTxt})</div>`;
    };
    if (keys.length === 1) {                      // ลงตำแหน่งเดียว ไม่เคยเวียน
      const only = keys[0];
      return combined[only] >= 2 ? _tierBadge(only, combined[only]) : '';
    }
    const cycles = Math.min(...keys.map(k => combined[k]));   // รอบที่เวียนครบแล้ว
    let topK = null, topRep = 0;
    keys.forEach(k => { const r = combined[k] - cycles; if (r > topRep) { topRep = r; topK = k; } });
    if (topRep >= 2) {                            // ลงซ้ำก่อนเวียนครบรอบ
      // [ค] rotation-aware: ถ้าเวียนหลายตำแหน่งแล้ว (≥3) และตัวที่ซ้ำไม่ได้กระจุกเกินจริง
      // (≤ ROTATE_CONC ของเวรทั้งหมด) = โดน "ตำแหน่งที่มี slot เยอะเชิงโครงสร้าง" เช่น kl_eve ซ้ำ
      // ถือว่ากระจายดีแล้ว → ไม่เตือน. เตือนเฉพาะคนติดตำแหน่งเดิมจริง (R≤2 หรือกระจุกหนัก)
      const ROTATE_CONC = 0.6;
      const tot = keys.reduce((a,k)=>a+combined[k], 0);
      const concentrated = (combined[topK] / tot) > ROTATE_CONC;
      if (keys.length >= 3 && !concentrated) return '';
      return _tierBadge(topK, combined[topK]);
    }
    return '';                                    // เวียนครบ/ยังไม่ซ้ำ → ไม่เตือน
  }
  const tBody=rows.map(r=>{
    // ── INTEGRITY-B: kl and sw are tallied independently from backend stats[p.id].kl
    //    and stats[p.id].sw. The UI merge (KL/SW display column) is cosmetic only —
    //    the accumulators remain separate to preserve correct hour calculations.
    totalRow.kl_day += (r.kl_day || 0);
    totalRow.sw_day += (r.sw_day || 0);
    totalRow.ae     += r.ae;
    totalRow.night+=r.night; totalRow.ovnt+=r.ovnt; totalRow.total+=r.total;
    totalRow.hrs        += isFinite(r.hrs)        ? r.hrs        : 0;
    _statsShownRoles.forEach(rl=>{ totalRow.roleTot[rl.id] += (+(r.roleComp&&r.roleComp[rl.id]||0)); });
    totalRow.deduct     += isFinite(r.deduct)     ? r.deduct     : 0;
    totalRow.grandTotal += isFinite(r.grandTotal) ? r.grandTotal : 0;
    totalRow.bf         += isFinite(r.bf)         ? r.bf         : 0;
    // PATCH-1B: รวมเวร = sum of all slot counters (not r.total which counts unique days)
    const slotSum = (r.kl_day||0) + (r.sw_day||0) + (r.ae||0) + (r.night||0) + (r.ovnt||0);
    const bfVal = (r.bf||0);
    const roleCells = _statsShownRoles.map(rl=>{
      const h=+(r.roleComp&&r.roleComp[rl.id]||0);
      return `<td class="${h===0?'zero':''}" style="color:var(--teal)">${h>0?h.toFixed(1):'&#8212;'}</td>`;
    }).join('');
    return `<tr>
      <td>${r.name}</td>
      ${mkKlSwPos(r.kl_day,r.sw_day,r.slotPos)}${mkAePos(r.ae,r.slotPos)}${mkNightPos(r.night,r.slotPos)}${mkCell(r.ovnt,'purple')}
      <td style="font-weight:700">${slotSum}${colRepeatWarn(r.byPosKey, r.name)}</td>
      <td>${r.hrs.toFixed(1)}</td>
      <td style="color:var(--gold);font-family:'IBM Plex Mono',monospace;font-size:0.8rem">${bfVal>0?bfVal.toFixed(2):'&#8212;'}</td>
      ${roleCells}
      <td style="text-align:center;font-family:'IBM Plex Mono',monospace;font-size:0.8rem">
        ${r.deduct>0?`<span style="color:var(--teal);font-weight:700">&#8722;${r.deduct}</span>`:'<span style="color:var(--text3)">0</span>'}
      </td>
      <td style="font-weight:700;color:var(--teal)">${r.grandTotal.toFixed(1)}</td>
    </tr>`;
  }).join('');

  // [STATS] Mean + S.D. ของ "รวมชั่วโมง/เดือน" (grandTotal) ข้ามคนที่แสดงในตาราง
  // วัดการกระจายเวรตาม normal-distribution (population SD ÷N) → สะท้อนช่วง max-min
  const _gtVals = rows.map(r=>isFinite(r.grandTotal)?r.grandTotal:0);
  const _gtN    = _gtVals.length;
  const _gtMean = _gtN ? _gtVals.reduce((a,b)=>a+b,0)/_gtN : 0;
  const _gtSD   = _gtN ? Math.sqrt(_gtVals.reduce((a,b)=>a+(b-_gtMean)*(b-_gtMean),0)/_gtN) : 0;
  const _gtMax  = _gtN ? Math.max(..._gtVals) : 0;
  const _gtMin  = _gtN ? Math.min(..._gtVals) : 0;

// PATCH-1C: merged KL/SW total + corrected รวมเวร total + BF total
  const tFoot=`<tr class="total-row" style="font-weight:700;background:var(--navy2);color:#fff">
    <td>รวม</td>
    <td>KL ${totalRow.kl_day} / SW ${totalRow.sw_day}</td>
    <td>${totalRow.ae}</td>
    <td>${totalRow.night}</td><td>${totalRow.ovnt}</td>
    <td>${totalRow.kl_day+totalRow.sw_day+totalRow.ae+totalRow.night+totalRow.ovnt}</td>
    <td>${totalRow.hrs.toFixed(1)}</td>
    <td style="color:var(--gold-light)">${totalRow.bf.toFixed(2)}</td>
    ${_statsShownRoles.map(rl=>`<td>${(totalRow.roleTot[rl.id]||0).toFixed(1)}</td>`).join('')}
    <td>&#8722;${totalRow.deduct}</td>
    <td style="color:var(--gold-light)">${totalRow.grandTotal.toFixed(1)} hr
      <div style="font-size:.64rem;font-weight:400;opacity:.9;margin-top:3px;line-height:1.45">
        (${_gtMean.toFixed(1)} &plusmn; ${_gtSD.toFixed(1)})<br>
        <span style="opacity:.8">Max&ndash;Min ${_gtMax.toFixed(1)}&ndash;${_gtMin.toFixed(1)}</span>
      </div>
    </td>
  </tr>`;

// PATCH-1D: merged KL/SW header, corrected labels + BF column header
  wrap.innerHTML=`<table class="stats-table">
    <thead><tr style="background:var(--navy);color:#fff">
      <th>ชื่อ</th>
      <th style="white-space:nowrap;width:1%;min-width:85px;font-size:0.73rem">เช้ากลาง/สว. (KL/SW)</th>
      <th>AE เล็ก</th><th>บ่าย</th><th>ดึก</th>
      <th>รวมเวร</th><th>ชม.เวร</th>
      <th style="color:var(--gold-light)">ยกมา (BF) (ชม.)</th>
      ${_statsShownRoles.map(rl=>`<th style="color:var(--teal-light)" title="หัก /${rl.hoursPerCredit}ชม.=1เวร${rl.needsComp?'':' · ไม่ชดเชย'}">${rl.name} (ชม.)${rl.needsComp?'':' *'}</th>`).join('')}
      <th style="color:var(--teal-light)">หักลบ (เวร)</th>
      <th style="color:var(--gold-light)" title="ชม.เวร + OT/ชดเชย (คลัง/TDM) — คนที่มี OT จะสูงกว่าเพราะรวมงานชดเชย ไม่ใช่ชม.เวรจริง · ใช้ 'ชม.เวร' ดูภาระเวรล้วน">รวมชั่วโมง/เดือน</th>
    </tr></thead>
    <tbody>${tBody}</tbody>
    <tfoot>${tFoot}</tfoot>
  </table>`;
  renderHistoryMatrix();
}

/* ══════════════════════════════════════════════════════════
   COMP AUDIT DASHBOARD
   Reads: S.schedule, S.pharmacists, S.settings, SHIFT_META
   Does NOT modify state. UI/Stats rendering only.
   Columns:
     1 Name  2 BF (Brought Fwd from prev months)  3 OT Warehouse (this month)  4 TDM (this month)
     5 Total Accumulated Before Deductions  6 Shifts Deducted  7 Remainder → Next Month
══════════════════════════════════════════════════════════ */
/* copyTSV and exportScheduleJSON are defined earlier (Google Sheets 4-row format) */

/* ══ PRINT STATS TABLE ══ */
function printStatsTable(){
  if(!S.schedule){ showToast('สร้างตารางก่อน','warn'); return; }
  var w = window.open('','_blank');
  if(!w){ showToast('ไม่สามารถเปิดหน้าต่างได้ — กรุณาอนุญาต popup','err'); return; }

  var mLabel = THAI_MONTHS[S.schedule.month] + ' ' + S.schedule.year;
  var schedMk = monthKey(S.schedule.month, S.schedule.year);

  var activeStaff = S.pharmacists.filter(isSchedulable);
  var staffCounts = {};
  // ── Load BF from previous month's ledger (mirrors renderStatsTab) ──
  var _printPrevMk = getPrevMonthKey();
  var _printPrevLO = (S.scheduleHistory[_printPrevMk]?._meta?.leftoverByName) || {};
  var _printCreditHrs = S.settings.hoursPerCredit || 8;
  var _printEveHrs    = (SHIFT_META.EVE&&SHIFT_META.EVE.hours) || 4;
  var _printShownRoles = getCompRoles().filter(function(r){ return activeStaff.some(function(p){ return (+(p.comp[r.id]||0))>0; }); });
  activeStaff.forEach(function(p){
    var prevLO = _printPrevLO[p.name] || {};
    var roleComp={}, compTotal=0, bf=0, deduct=0;
    getCompRoles().forEach(function(r){
      var typed=+(p.comp[r.id]||0), lo=+(prevLO[r.id]||0);
      roleComp[r.id]=typed; compTotal+=typed; bf+=lo;
      if(r.needsComp){ var rate=r.hoursPerCredit||0; if(rate>0) deduct+=Math.floor((typed+lo)/rate); }
    });
    staffCounts[p.name] = {
      id:p.id, kl_day:0, sw_day:0, ae:0, night:0, ovnt:0,
      total:0, hrs:0,
      roleComp:roleComp, compTotal:+compTotal.toFixed(2),
      deduct:deduct, grandTotal:0, schedRank:isSchedulable(p)?0:1,
      bf: +bf.toFixed(2)
    };
  });

  var totalSlots=0, filledSlots=0;
  Object.values(S.schedule.days).forEach(function(day){
    day.slots.forEach(function(sl){
      totalSlots++;
      if(sl.assignedTo){
        filledSlots++;
        var st = staffCounts[sl.assignedTo];
        if(st){
          st.total++;
          var hrs = getSlotMeta(sl).hours;
          st.hrs += hrs;
          // [FEATURE-1] per-column tally for print warning
          if(sl.posKey){ st.byPosKey = st.byPosKey || {}; st.byPosKey[sl.posKey] = (st.byPosKey[sl.posKey]||0) + 1; }
          var isFull = (sl.shift==='DAY'||sl.shift==='HALF');
          if(isFull && sl.unit==='KL')     st.kl_day++;
          else if(isFull && sl.unit==='SW') st.sw_day++;
          else if(sl.shift==='EVE')   st.ae++;
          else if(sl.shift==='NIGHT') st.night++;
          else if(sl.shift==='OVNT')  st.ovnt++;
          // [SLOT-POS] เก็บตำแหน่ง slot (1-indexed, ข้าม OVNT) ให้ print ตรงกับหน้าจอ
          if(sl.posKey && sl.shift!=='OVNT'){
            st.slotPos = st.slotPos || {};
            st.slotPos[sl.posKey] = st.slotPos[sl.posKey] || [];
            st.slotPos[sl.posKey].push((sl.slotIdx==null?0:sl.slotIdx)+1);
          }
        }
      }
    });
  });

  // Capture history matrix HTML before building print page
  var matrixHTML = renderHistoryMatrix({ returnHTML:true, monthsLimit:6 }) || '';

  var rows = [];
  activeStaff.forEach(function(p){
    var st = staffCounts[p.name];
    if(st){ st.grandTotal = st.hrs + st.compTotal; rows.push(Object.assign({name:p.name},st)); }
  });
  rows.sort(function(a,b){
    if(a.schedRank!==b.schedRank) return a.schedRank-b.schedRank;
    return a.name.localeCompare(b.name,'th');
  });

  // [BUG-1 PRINT PARITY] ให้ตรงกับ UI (renderStatsTab) — σ คิดจาก no-OT pool เป็นค่าหลัก
  // คนมี OT ถูก Virtual Hours engine ลดเวรให้โดยตั้งใจ → schedHrs ต่ำ → ถ้านับรวม σ พุ่งโดยไม่มีความหมาย
  var _sigFn = function(h){
    if(!h.length) return 0;
    var mean = h.reduce(function(a,b){return a+b;},0)/h.length;
    return Math.sqrt(h.reduce(function(s,x){return s+Math.pow(x-mean,2);},0)/h.length);
  };
  var hrsAllArr  = rows.map(function(r){ return r.hrs; });
  var hrsNoOTArr = rows.filter(function(r){ return !r.compTotal||r.compTotal===0; }).map(function(r){ return r.hrs; });
  var sigmaAll   = _sigFn(hrsAllArr);
  var sigma      = hrsNoOTArr.length>=2 ? _sigFn(hrsNoOTArr) : sigmaAll;   // no-OT = ค่าหลัก
  var sigCls = sigma<=3?'sigma-ok':sigma<=6?'sigma-warn':'sigma-bad';
  // [SAFEGUARD] สัดส่วน OT > 40% → กลุ่ม no-OT เล็ก σ no-OT อ้างอิงได้น้อยลง
  var _otCnt = rows.filter(function(r){ return r.compTotal>0; }).length;
  var _otRatioP = rows.length ? _otCnt/rows.length : 0;
  var sigLbl = (sigma<=3?'ยอดเยี่ยม (≤3)':sigma<=6?'ดี (≤6)':'ควรปรับปรุง')
             + ' · เฉพาะคนไม่มี OT n=' + hrsNoOTArr.length + ' (σ ทุกคน ' + sigmaAll.toFixed(2) + ')'
             + (_otRatioP>0.40 ? ' · ⚠ OT '+Math.round(_otRatioP*100)+'% กลุ่มอ้างอิงเล็ก' : '');

  // [FEATURE-1] column-position repetition warning for print
  var _printPosLabel = {};
  Object.values(S.positions || {}).forEach(function(pm){
    Object.entries(pm).forEach(function(kv){ if(!_printPosLabel[kv[0]]) _printPosLabel[kv[0]] = kv[1].label; });
  });
  function printColRepeatWarn(byPosKey, name){
    var combined = {};
    Object.entries(byPosKey || {}).forEach(function(e){ combined[e[0]]=(combined[e[0]]||0)+e[1]; });
    if(typeof repeatHistCounts==='function' && name){
      var h=(repeatHistCounts(name)||{}).byPosKey||{};
      Object.entries(h).forEach(function(e){ combined[e[0]]=(combined[e[0]]||0)+e[1]; });
    }
    var keys = Object.keys(combined);
    if(!keys.length) return '';
    if(keys.length === 1){
      var only=keys[0];
      return combined[only]>=2 ? '<div style="font-size:6pt;color:#c0392b;font-weight:600">&#9888; ซ้ำ '+(_printPosLabel[only]||only)+'</div>' : '';
    }
    var cycles = Math.min.apply(null, keys.map(function(k){ return combined[k]; }));
    var topK=null, topRep=0;
    keys.forEach(function(k){ var r=combined[k]-cycles; if(r>topRep){topRep=r;topK=k;} });
    if(topRep>=2){
      // [ค] rotation-aware: เวียน ≥3 ตำแหน่งแล้ว และตัวที่ซ้ำไม่กระจุกเกิน 60% → ไม่เตือน (โครงสร้าง)
      var ROTATE_CONC=0.6;
      var tot=keys.reduce(function(a,k){return a+combined[k];},0);
      var concentrated=(combined[topK]/tot)>ROTATE_CONC;
      if(keys.length>=3 && !concentrated) return '';
      var lab=_printPosLabel[topK]||topK;
      return '<div style="font-size:6pt;color:#c0392b;font-weight:600">&#9888; ซ้ำ '+lab+'</div>';
    }
    return '';
  }

  var totalRow = {kl_day:0,sw_day:0,ae:0,night:0,ovnt:0,total:0,hrs:0,roleTot:{},deduct:0,grandTotal:0,bf:0};
