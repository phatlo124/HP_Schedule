function renderHistoryTab(){
  var wrap=document.getElementById('history-wrap');
  if(!wrap) return;
  var keys=Object.keys(S.scheduleHistory).sort().reverse();
  if(!keys.length){
    wrap.innerHTML='<div class="empty-state" style="min-height:180px"><div class="empty-icon">🗃</div><div class="empty-title">ยังไม่มีประวัติ</div><div class="empty-sub">Archive ตารางเวรจากแท็บ 06 เพื่อเริ่มสะสมข้อมูล</div></div>';
    return;
  }
  var SHIFTS=['DAY','HALF','EVE','NIGHT','OVNT'];
  var html='';
  keys.forEach(function(mk){
    var parts=mk.split('-').map(Number), y=parts[0], mo=parts[1];
    var label=THAI_MONTHS[mo]+' '+y;
    var data=S.scheduleHistory[mk];
    var persons=Object.keys(data).filter(function(k){return k!=='_meta';});
    var tRows=persons.map(function(name){
      var d=data[name]||{};
      var cells=SHIFTS.map(function(sh){return '<td>'+(d[sh]||'—')+'</td>';}).join('');
      return '<tr><td>'+name+'</td>'+cells+'</tr>';
    }).join('');
    html+='<div class="hist-month-card" id="hmc-'+mk+'">'
      +'<div class="hist-month-head" onclick="toggleHistCard(\''+mk+'\')">'
      +'<h4>📅 '+label+' <span style="font-weight:400;opacity:.6">('+persons.length+' คน)</span></h4>'
      +'<div style="display:flex;gap:8px;align-items:center">'
      +'<button class="btn btn-ghost btn-xs" onclick="deleteHistMonth(\''+mk+'\');event.stopPropagation()" style="color:var(--red)">🗑</button>'
      +'<span class="hist-toggle">▼</span>'
      +'</div></div>'
      +'<div class="hist-month-body"><div style="overflow-x:auto">'
      +'<table class="stats-table"><thead><tr>'
      +'<th>ชื่อ</th><th>เช้า</th><th>ครึ่ง</th><th>AE</th><th>บ่าย</th><th>ดึก</th>'
      +'</tr></thead><tbody>'+tRows+'</tbody></table>'
      +'</div></div></div>';
  });
  wrap.innerHTML=html;
}

function toggleHistCard(mk){
  var el=document.getElementById('hmc-'+mk);
  if(el) el.classList.toggle('expanded');
}
async function deleteHistMonth(mk){
  if(!await confirmModal('ลบประวัติเดือน '+mk+'?',{danger:true})) return;
  delete S.scheduleHistory[mk];
  autoSave(); renderHistoryTab(); updateNavBadges();
  showToast('ลบประวัติแล้ว','ok');
}
async function clearAllHistory(){
  if(!await confirmModal('ล้างประวัติทั้งหมด? การกระทำนี้ย้อนกลับไม่ได้',{danger:true})) return;
  S.scheduleHistory={};
  autoSave(); renderHistoryTab(); updateNavBadges();
  showToast('ล้างประวัติทั้งหมดแล้ว','ok');
}
