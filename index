function updatePharmField(id, path, val){
  const p = S.pharmacists.find(x => x.id === id);
  if (!p) return;
  const keys = path.split('.');
  let obj = p;
  for (let i = 0; i < keys.length - 1; i++) obj = obj[keys[i]];

  // Snapshot old value BEFORE overwrite (for comp changes)
  const oldComp = (path === 'comp') ? Object.assign({}, obj[keys[keys.length - 1]]) : null;

  obj[keys[keys.length - 1]] = val;

  // Log manual comp-hours edits
  if (path === 'comp') {
    const _diffs = getCompRoles().map(r=>`${r.name}:${(oldComp&&oldComp[r.id])??0}→${(val&&val[r.id])??0}`).join(' · ');
    appendActivityLog('MANUAL_HOURS', `[${p.name}] ${_diffs}`);
    renderFingerprintBadge();
  }

  autoSave(); renderStaffList();
}

/* ── Compensation field updater (no full re-render) ── */
function updateCompField(id, field, rawVal){
  const p = S.pharmacists.find(x=>x.id===id);
  if(!p) return;
  const val = Math.max(0, parseFloat(rawVal)||0);
  p.comp[field] = val;
  autoSave();
  // Update inline calc display without destroying the DOM
  const calcEl = document.getElementById('comp-calc-'+id);
  if(calcEl){
    const txt=_compCalcText(p);
    if(txt){ calcEl.style.display=''; calcEl.innerHTML=txt; }
    else   { calcEl.style.display='none'; }
  }
}
/* [COMP ROLE REGISTRY] dynamic comp-calc display string over all roles */
function _compCalcText(p){
  const parts=[]; let total=0;
  getCompRoles().forEach(r=>{
    const h=+(p.comp[r.id]||0);
    if(h>0){ parts.push(h+' ชม. ('+r.name+')'); total+=h; }
  });
  if(total<=0) return null;
  return parts.join(' + ')+' = '+(+total.toFixed(2))+' ชม. → ลดโควตาได้ <strong>'+compensationReduction(p)+' เวร</strong>';
}

