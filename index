function thaiMonthYear(m,y){ return `${THAI_MONTHS[m]} ${y}`; }

function getSlotMeta(slot) {
  const meta = { start: '08:00', end: '16:00', hours: 8.0, thai: 'เต็มวัน', short: 'เต็ม' };
  if (!slot) return meta;
  // [PART B] hours are data-driven via S.settings.shiftHours (per shift-type). The hardcoded
  // numbers below are FALLBACK defaults. When a month is generated, runScheduler snapshots the
  // effective hours into that month's history so historical months stay locked (forward-only).
  // _shiftHr(shiftType, fallback) → settings override if present & valid, else fallback.
  const _SH = (typeof S!=='undefined' && S.settings && S.settings.shiftHours) ? S.settings.shiftHours : null;
  const _shiftHr = (k, fb) => {
    const v = _SH ? _SH[k] : undefined;
    return (typeof v==='number' && v>0) ? v : fb;
  };

  if (slot.posKey === 'kl_day') {
    const idx = slot.slotIdx; // 0-indexed
    if (idx === 0 || idx === 2 || idx === 4) {
      meta.start = '08:00';
      meta.end = '16:00';
    } else if (idx === 1 || idx === 3) {
      meta.start = '08:30';
      meta.end = '16:30';
    }
    meta.hours = _shiftHr('DAY', 8.0);
    meta.thai = 'เวรเช้า';
    meta.short = 'เช้า';
  } else if (slot.posKey === 'sw_day') {
    const idx = slot.slotIdx; // 0-indexed
    if (idx === 0 || idx === 2) {
      meta.start = '08:00';
      meta.end = '16:00';
    } else if (idx === 1 || idx === 3) {
      meta.start = '08:30';
      meta.end = '16:30';
    }
    meta.hours = _shiftHr('DAY', 8.0);
    meta.thai = 'เวรเช้า';
    meta.short = 'เช้า';
  } else if (slot.posKey === 'kl_half' || slot.posKey === 'half') {
    meta.start = '09:00';
    meta.end = '12:30';
    meta.hours = _shiftHr('HALF', 3.5);
    meta.thai = 'ครึ่งวัน';
    meta.short = 'ครึ่ง';
  } else if (slot.posKey === 'kl_eve') {
    meta.start = '16:30';
    meta.end = '20:30';
    meta.hours = _shiftHr('EVE', 4.0);
    meta.thai = 'เวรเย็น AE';
    meta.short = 'AE';
  } else if (slot.posKey === 'sw_eve') {
    meta.start = '16:30';
    meta.end = '20:30';
    meta.hours = _shiftHr('EVE', 4.0);
    meta.thai = 'เวรเย็น AE';
    meta.short = 'AE';
  } else if (slot.posKey === 'sw_night') {
    meta.start = '16:30';
    meta.end = '23:30';
    meta.hours = _shiftHr('NIGHT', 7.0);
    meta.thai = 'เวรบ่าย';
    meta.short = 'บ่าย';
  } else if (slot.posKey === 'sw_ovnt') {
    meta.start = '23:30';
    meta.end = '08:30';
    meta.hours = _shiftHr('OVNT', 9.0);
    meta.thai = 'เวรดึก';
    meta.short = 'ดึก';
  } else {
    // fallback
    const sm = SHIFT_META[slot.shift] || {};
    meta.start = sm.start || '08:00';
    meta.end = sm.end || '16:30';
    meta.hours = _shiftHr(slot.shift, sm.hours || 8.5);
    meta.thai = sm.thai || '';
    meta.short = sm.short || '';
  }
  return meta;
}

function getEligibleShifts(p) {
  const all = Object.keys(SHIFT_META);
  if (p.flags.age50plus)   return all.filter(s=>s!=='OVNT');
  return all;
}
function compensationReduction(p) {
  // uses p.comp (persistent cumulative balance) directly · now role-registry driven
  return compReductionGeneric(p);
}
/* ── [COMP ROLE REGISTRY v3] accessors + generic reduction ──
   A role = { id, name, needsComp, hoursPerCredit }. Per pharmacist, p.comp is a map keyed
   by role id. Generic reduction = Σ floor(p.comp[id] / role.hoursPerCredit) over roles with
   needsComp=true. With the two seeded roles (warehouse=hoursPerCredit, tdm=4) this equals the
   legacy compensationReduction exactly. Read-only here; wired into the engine in CP-2. */
function getCompRoles(){ return Array.isArray(S.compRoles) ? S.compRoles : []; }
function compRoleById(id){ return getCompRoles().find(r=>r.id===id) || null; }
function compReductionGeneric(p){
  let red=0;
  getCompRoles().forEach(r=>{
    if(!r.needsComp) return;
    const rate=r.hoursPerCredit||0; if(rate<=0) return;
    red += Math.floor(((p.comp && p.comp[r.id])||0) / rate);
  });
  return red;
}
// Virtual hours pre-load for a given comp map (or pharmacist) = Σ credits × rate (needsComp only).
function compVirtualHours(compMap){
  let hrs=0;
  getCompRoles().forEach(r=>{
    if(!r.needsComp) return;
    const rate=r.hoursPerCredit||0; if(rate<=0) return;
    hrs += Math.floor(((compMap && compMap[r.id])||0) / rate) * rate;
  });
  return hrs;
}
// [v4 RAW-OT BALANCE] Engine pre-load = OT จริงทั้งหมด (ไม่ floor เป็น block ไม่ discount เศษ)
// ใช้แทน compVirtualHours เฉพาะที่ totalHours seed (HC-3 + scoring) ตามที่ user ยอมรับ trade-off:
// คน OT มาก → totalHours สูงตรงตัว → ถูกกันออกจากเวร schedule มากขึ้น → grandTotal (OT+sched) แน่นรอบ mean
// ไม่กระทบ compVirtualHours/compReductionGeneric เดิม (Waterfall Credit/leftover ledger/Feature M คนละกลไก)
function compVirtualHoursRaw(compMap){
  let hrs=0;
  getCompRoles().forEach(r=>{
    if(!r.needsComp) return;
    hrs += (compMap && compMap[r.id]) || 0;
  });
  return hrs;
}
