/* ── helpers ── */
// [DEPT REGISTRY v2] แผนกเป็น data-driven (S.departments) — schedulable=false กันออกจากเวร
//   deptOf() มี fallback อ่าน deptPriority เดิม (un-migrated / backward-compat)
function deptOf(p){
  const id = p.department || (p.deptPriority==='LAST' ? 'prod' : 'disp');
  return (S.departments||[]).find(d=>d.id===id) || null;
}
function isSchedulable(p){ const d=deptOf(p); return !p.flags.inactive && !!(d && d.schedulable); }
/* ── [NEWBIE] Seniority tagging — inverted logic ──────────────────────────
   Newbie = มี tag 'Newbie' ใน p.tags[] · Senior = ไม่มี tag (ว่าง/undefined = Senior)
   backward-compat: ข้อมูลเก่าไม่มี tags → นับเป็น Senior → เดือนเก่าไม่กระทบ        */
function isNewbie(p){ return !!p && Array.isArray(p.tags) && p.tags.includes('Newbie'); }
function isSenior(p){ return !isNewbie(p); }
/* ── [BUDDY v4_2_0] Buddy mutual-exclusion groups ─────────────────────────
   buddy = กลุ่มน้องใหม่ 2–3 คน "ห้ามขึ้นเวรวันเดียวกัน" (engine กระจายวันให้)
   - เป็น buddy ได้ต้องเป็น Newbie ก่อน (gate ที่ UI + defensive ที่นี่)
   - ถอด Newbie หรือถอดออกจากกลุ่ม = หมดผล exclusion ทันที (รันปกติ)
   - effect คิดเฉพาะเพื่อนร่วมกลุ่มที่ยัง isNewbie อยู่เท่านั้น                       */
function _buddyGroupsOf(pid){
  return (S.buddyPairs||[]).filter(g=>g && Array.isArray(g.members) && g.members.includes(pid));
}
function getBuddyMateIds(p){                 // id เพื่อนร่วมกลุ่ม (ไม่รวมตัวเอง · เฉพาะที่ยัง newbie)
  if(!p || !isNewbie(p)) return [];
  const out=new Set();
  _buddyGroupsOf(p.id).forEach(g=>g.members.forEach(mid=>{
    if(mid===p.id) return;
    const m=S.pharmacists.find(x=>x.id===mid);
    if(m && isNewbie(m)) out.add(mid);
  }));
  return [...out];
}
function buddyMateNamesOf(p){                 // ชื่อเพื่อนร่วมกลุ่ม (ใช้เทียบกับ assignedToday ในเอนจิน)
  return getBuddyMateIds(p).map(id=>{
    const m=S.pharmacists.find(x=>x.id===id); return m ? m.name : null;
  }).filter(Boolean);
}
/* ── [V4 RNG] mulberry32 — seeded PRNG ทดแทน Math.random ในเอนจินจัดเวร ──
   seed เดียวกัน → ตารางเดิมเป๊ะ (reproducible QA) · S.settings.rngSeed=0 = auto สุ่ม seed ใหม่ทุก run */
function _mulberry32(seed){
  let a = seed >>> 0;
  return function(){
    a |= 0; a = (a + 0x6D2B79F5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
function isEligibleForShift(p, shift) {
  if (!isSchedulable(p)) return false;                // inactive + แผนกไม่ขึ้นเวร (รวม prod/LAST เดิม)
  if (p.flags.age50plus && shift === 'OVNT') return false;
  return true;
}
