const BACKUP_STALE_MS = 30*24*60*60*1000;
function checkBackupStatus(){
  const el=document.getElementById('backup-warn'); if(!el) return;
  let msg='';
  if(!_driveReady){
    msg='⚠️ ยังไม่ได้เชื่อมต่อ Drive — ข้อมูลอยู่ในเบราว์เซอร์เท่านั้น เสี่ยงสูญหาย กดปุ่ม “เชื่อมต่อไฟล์” เพื่อโหลด/ซิงก์';
  } else {
    const ts=S.settings?._lastBackupTs||0;
    if(!ts || (Date.now()-ts)>BACKUP_STALE_MS){
      const days = ts ? Math.floor((Date.now()-ts)/86400000) : null;
      msg='⚠️ ยังไม่ได้ Sync ขึ้น Drive'+(days!=null?`มา ${days} วัน`:'')+' — กด 🔄 Sync';
    }
  }
  el.textContent=msg; el.style.display=msg?'block':'none';
}
function updateDbUI(conn,name='',syncing=false){
  document.getElementById('db-dot').className='db-dot'+(conn?(syncing?' syncing':' connected'):'');
  document.getElementById('db-label').innerHTML=conn?`<strong>${name}</strong> — <span style="color:var(--green)">เชื่อมต่อแล้ว</span>`:`<strong>Google Drive</strong> — ไม่ได้เชื่อมต่อ`;
  document.getElementById('sb-db-status').textContent=conn?`📁 Drive`:'🔌 ไม่ได้เชื่อมต่อ';
  document.getElementById('btn-sync').disabled=!conn;
  document.getElementById('btn-load-file').disabled=!conn;
  checkBackupStatus();
}

