function renderPostFairness() {
  const panel  = document.getElementById('panel-post-fairness');
  const body   = document.getElementById('post-fairness-body');
  const sigPill= document.getElementById('fairness-sigma-pill');
  if (!panel || !body) return;

  if (!S.schedule) {
    panel.style.display = 'none';
    return;
  }
  panel.style.display = '';

  const active = S.pharmacists.filter(isSchedulable);

  // [COMP ROLE REGISTRY] per-role hours + generic comp totals
  const shownRoles = getCompRoles().filter(r => active.some(p => (+(p.comp[r.id]||0))>0));

  // [OT-FIX] st.hours = totalHours = OT seed (compVirtualHoursRaw) + เวรจริง รวมในตัวแล้ว
  // ห้ามใช้ st.hours เป็น "เวรจริง" และห้ามบวก compHrs ซ้ำ (บั๊กเดิม: grandTotal = เวรจริง + 2×OT)
  // เวรจริงล้วน = Σ(จำนวนเวรแต่ละชนิด × ชม.) จาก stats — ground-truth เดียวกับแท็บสรุป
  const _SHRS = (S.settings && S.settings.shiftHours) || {DAY:8.0,HALF:3.5,EVE:4.0,NIGHT:7.0,OVNT:9.0};
  const _shHr = k => (typeof _SHRS[k]==='number' ? _SHRS[k] : (SHIFT_META[k]?.hours || 0));
  const _realShiftHrs = st => Object.keys(st).reduce((h,k)=> k==='hours' ? h : h + (st[k]||0)*_shHr(k), 0);
  const personData = active.map(p => {
    const st = S.schedule.stats?.[p.id] || {};
    const schedHrs = Math.round(_realShiftHrs(st)*10)/10;       // เวรจริงล้วน
    const roleHrs = {}; let compHrs = 0;
    getCompRoles().forEach(r => { const h=+(p.comp[r.id]||0); roleHrs[r.id]=h; compHrs+=h; });
    const grandTotal = Math.round((schedHrs + compHrs)*10)/10;  // เวรจริง + OT (นับครั้งเดียว)
    return { name: p.name, dept: deptName(p), schedHrs, compHrs, grandTotal, roleHrs, deduct: compReductionGeneric(p) };
  }).sort((a,b) => b.grandTotal - a.grandTotal);

  // [OT-FIX] headline σ + mean ใช้ "ภาระงานรวม" (grandTotal = เวรจริง+OT) = ตัวชี้วัดความเป็นธรรมจริง
  const grandHrs = personData.map(d => d.grandTotal);
  const sigma  = computeSigma(grandHrs);
  // σ no-OT = เช็คว่า algorithm กระจายเวรจริงยุติธรรมเฉพาะกลุ่มไม่มี OT (pill — คงเดิม ถูกต้องอยู่แล้ว)
  const noOTHrs = personData.filter(d=>!d.compHrs||d.compHrs===0).map(d=>d.schedHrs);
  const sigmaNoOT = noOTHrs.length>=2 ? computeSigma(noOTHrs) : sigma;
  const maxHrs = Math.max(...grandHrs, 1);
  const mean   = grandHrs.length ? grandHrs.reduce((a,b)=>a+b,0)/grandHrs.length : 0;

  if (sigPill) {
    // แสดง σ no-OT เป็นค่าหลัก (อ้างอิงได้) · tooltip บอกค่าทุกคน
    sigPill.textContent = `σ เวร = ${sigmaNoOT.toFixed(2)}`;
    sigPill.className = `badge badge-${sigmaNoOT<=3?'teal':sigmaNoOT<=6?'gold':'red'}`;
    sigPill.title = `σ เฉพาะคนไม่มี OT (อ้างอิงได้): ${sigmaNoOT.toFixed(2)} · σ ทุกคน: ${sigma.toFixed(2)}`;
  }

  const barRows = personData.map(d => {
    const pct = Math.round((d.grandTotal / maxHrs) * 100);
    const barColor = d.grandTotal > mean+3 ? 'var(--red)' : d.grandTotal < mean-3 ? 'var(--amber)' : 'var(--teal)';
    const roleCells = shownRoles.map(r=>{
      const h=d.roleHrs[r.id]||0;
      return `<td style="text-align:center;font-size:.68rem;font-family:'IBM Plex Mono',monospace;color:${h>0?'var(--teal)':'var(--text3)'}">${h>0?h.toFixed(1):'–'}</td>`;
    }).join('');
    const deductTag = d.deduct > 0
      ? `<span style="font-size:.62rem;color:var(--purple)">−${d.deduct} เวร</span>`
      : '';
    return `<tr style="font-size:.76rem">
      <td style="white-space:nowrap;font-weight:600;min-width:120px">${d.name}</td>
      <td style="min-width:200px;padding:3px 8px">
        <div style="display:flex;align-items:center;gap:6px">
          <div style="flex:1;background:var(--surface);border-radius:4px;height:12px;overflow:hidden">
            <div style="width:${pct}%;height:100%;background:${barColor};border-radius:4px;transition:width .3s"></div>
          </div>
          <span style="font-family:'IBM Plex Mono',monospace;font-size:.72rem;min-width:40px;text-align:right">${d.schedHrs.toFixed(1)}</span>
        </div>
      </td>
      ${roleCells}
      <td style="text-align:center">${deductTag}</td>
      <td style="text-align:center;font-family:'IBM Plex Mono',monospace;font-weight:700;color:var(--navy)">${d.grandTotal.toFixed(1)}</td>
    </tr>`;
  }).join('');

  const sigLabel = sigma<=3?'ยอดเยี่ยม ≤3':sigma<=6?'ดี ≤6':'ควรปรับปรุง';
  body.innerHTML = `
    <div style="display:flex;gap:12px;align-items:center;margin-bottom:12px;flex-wrap:wrap">
      <div>
        <div class="stat-label">Fairness σ (ภาระงานรวม)</div>
        <div class="sigma-badge sigma-${sigma<=3?'ok':sigma<=6?'warn':'bad'}">${sigma.toFixed(2)}</div>
        <div class="stat-sub">${sigLabel}</div>
      </div>
      <div style="flex:1;font-size:.75rem;color:var(--text3);line-height:1.8;min-width:160px">
        เฉลี่ย <strong>${mean.toFixed(1)} ชม.</strong> · 
        <span style="color:var(--red)">■</span> มากกว่าค่าเฉลี่ย >3 ชม. ·
        <span style="color:var(--amber)">■</span> น้อยกว่าค่าเฉลี่ย >3 ชม.<br>
        Bar/รวม = ภาระงานรวม (เวรจริง + OT) · เลขท้ายแถบ = ชม.เวรจริงล้วน · คอลัมน์งาน = ชม. OT แต่ละงาน (* = ไม่ชดเชย)
      </div>
    </div>
    <div style="overflow-x:auto">
      <table class="stats-table" style="width:100%">
        <thead><tr style="font-size:.65rem;text-transform:uppercase;letter-spacing:.05em">
          <th style="text-align:left;padding:5px 8px">ชื่อ</th>
          <th style="padding:5px 8px">ชม.เวรจริง</th>
          ${shownRoles.map(r=>`<th style="padding:5px 8px" title="ชดเชย /${r.hoursPerCredit}ชม.=1เวร${r.needsComp?'':' · ไม่ชดเชย'}">${r.name}${r.needsComp?'':' *'}</th>`).join('')}
          <th style="padding:5px 8px">ลดเวร</th>
          <th style="padding:5px 8px">รวม</th>
        </tr></thead>
        <tbody>${barRows}</tbody>
      </table>
    </div>`;
}

