function initActivityLog() {
  if (!localStorage.getItem(ACTLOG_KEY)) {
    localStorage.setItem(ACTLOG_KEY, JSON.stringify([]));
  }
}

/**
 * appendActivityLog(action, detail)
 * Appends a timestamped entry. Never erased by doClearCache().
 * @param {string} action  — event type constant (e.g. 'MANUAL_HOURS')
 * @param {string} detail  — human-readable description
 */
function appendActivityLog(action, detail) {
  let log = [];
  try { log = JSON.parse(localStorage.getItem(ACTLOG_KEY) || '[]'); } catch(e) {}
  log.push({
    ts:     new Date().toISOString(),
    action,
    detail,
    fp:     generateDataFingerprint()   // snapshot of data state at time of change
  });
  // FIFO prune — keep most recent ACTLOG_MAX entries
  if (log.length > ACTLOG_MAX) log = log.slice(log.length - ACTLOG_MAX);
  localStorage.setItem(ACTLOG_KEY, JSON.stringify(log));
}

/* ── [LONGEVITY] Forward/backward-compatible state migration ──
   Replaces the old hard "version !== APP_VER → reject" gate, which SILENTLY
   discarded all saved data on any version bump (a latent data-loss bug for
   long-term use). Returns a migrated copy safe for _applyState, or null if
   the blob is unusable. Structural migration (positions, FULL purge, defaults)
   continues to live in _applyState; this only adds version-keyed transforms
   and a settings deep-merge so newly-added setting keys gain their defaults. */
function migrateState(d){
  if(!d || typeof d!=='object') return null;
  const def = buildDefaultState();
  // Deep-merge settings: keep saved values, fill any new keys (e.g. cumulativeWeight)
  d.settings = Object.assign({}, def.settings, d.settings||{});
  // [BUDDY v4_2_0] additive optional field — backward-compat ทุกเวอร์ชัน (ไม่ bump APP_VER)
  if(!Array.isArray(d.buddyPairs)) d.buddyPairs = [];
  // [v1→v2 DEPT REGISTRY] seed S.departments + map deptPriority → department (id)
  if((d.version||0) < 2){
    if(!Array.isArray(d.departments) || !d.departments.length){
      d.departments = JSON.parse(JSON.stringify(def.departments));
    }
    (d.pharmacists||[]).forEach(p=>{
      if(!p.department){
        // LAST → ผลิต (prod) · FIRST รวมคลัง+จ่ายยา ระบบแยกเองไม่ได้ → default จ่ายยา
        // (ผู้ใช้แก้คนคลังรายคนครั้งเดียวภายหลัง) · เก็บ deptPriority ไว้ dormant ไม่ลบ
        p.department = (p.deptPriority==='LAST') ? 'prod' : 'disp';
      }
    });
  }
  // [v2→v3 COMP ROLE REGISTRY] seed S.compRoles from the legacy warehouse/tdm channels.
  // warehouse rate = the user's current hoursPerCredit (frozen) so output stays byte-identical;
  // tdm rate = EVE hours (4). Existing p.comp keys are already 'warehouse'/'tdm' = role ids → no remap.
  if((d.version||0) < 3){
    if(!Array.isArray(d.compRoles) || !d.compRoles.length){
      const _hpc = (d.settings && d.settings.hoursPerCredit) || 8;
      d.compRoles = [
        { id:'warehouse', name:'คลัง', needsComp:true, hoursPerCredit:_hpc },
        { id:'tdm',       name:'TDM',  needsComp:true, hoursPerCredit:4 },
      ];
    }
    (d.pharmacists||[]).forEach(p=>{ if(!p.comp || typeof p.comp!=='object') p.comp={warehouse:0,tdm:0}; });
  }
  // [v3→v4 REPEAT-WEIGHT DEFAULT] Activate column round-robin penalty by default.
  // The old default was repeatWeight:0 (feature dormant). Users who never opened
  // Settings carry that stale 0 in localStorage and would miss the new behavior,
  // since the settings deep-merge above keeps saved values. We bump ONLY the saved
  // value that still equals the OLD default (0) up to the new default (5); any
  // user who deliberately set a different value (including a non-zero one) is left
  // untouched. repeatWeight=5 is additive/soft — HC/coverage/Feature M still win,
  // so this cannot introduce HC violations or null slots.
  if((d.version||0) < 4){
    if(d.settings && d.settings.repeatWeight === 0){
      d.settings.repeatWeight = 5;
    }
  }
  // [v4→v5 BURDEN EQUITY] seed shift-burden balancing settings. The deep-merge above
  // already fills burdenWeight/burden from defaults when ABSENT, but we set them
  // explicitly here so an existing settings object (which the merge keeps) gains the
  // new keys. burdenWeight=8 + burden map are soft scoring terms — HC/coverage/Feature M
  // still win, so no HC violations or null slots. Users may tune or zero them in Settings.
  if((d.version||0) < 5){
    if(d.settings){
      if(d.settings.burdenWeight === undefined) d.settings.burdenWeight = 8;
      if(!d.settings.burden || typeof d.settings.burden !== 'object'){
        d.settings.burden = {HALF:-2, DAY:0, EVE:0, NIGHT:2, OVNT:3};
      }
    }
  }
  // [v5→v6 BURDEN WEIGHT TUNE] ลด default 8 → 4 (8 แรงเกินไป — spread เวรล้วนกว้างขึ้น).
  // อัปเฉพาะค่าที่ยังเท่า default เก่า (8) → 4 · คนที่ตั้งค่าอื่นเอง (รวม 0=ปิด) ไม่ถูกแตะ.
  if((d.version||0) < 6){
    if(d.settings && d.settings.burdenWeight === 8){
      d.settings.burdenWeight = 4;
    }
  }
  // [v6→v7 BURDEN WEIGHT SWEET SPOT] ปรับ default 4 → 6 (จาก multi-run: 6 ให้ corr เป็นลบ
  // = เกลี่ย burden จริง + spread no-OT ต่ำสุด 12.9h · 4 อ่อนเกินไป corr ยังบวก).
  // อัปเฉพาะค่าที่ยังเท่า default เก่า (4) → 6 · custom/0 ไม่ถูกแตะ.
  if((d.version||0) < 7){
    if(d.settings && d.settings.burdenWeight === 4){
      d.settings.burdenWeight = 6;
    }
  }
  // [v7→v8 SHIFT HOURS] seed editable per-shift hours. The deep-merge fills it from defaults
  // when absent; we also ensure the object exists with all 5 keys so the Settings UI can bind.
  // These are the CURRENT effective hours — changing them affects FUTURE months only (each
  // generated month snapshots its hours into history, so past months stay locked).
  if((d.version||0) < 8){
    if(d.settings){
      if(!d.settings.shiftHours || typeof d.settings.shiftHours !== 'object'){
        d.settings.shiftHours = {DAY:8.0, HALF:3.5, EVE:4.0, NIGHT:7.0, OVNT:9.0};
      } else {
        const _def={DAY:8.0, HALF:3.5, EVE:4.0, NIGHT:7.0, OVNT:9.0};
        Object.keys(_def).forEach(k=>{ if(typeof d.settings.shiftHours[k]!=='number') d.settings.shiftHours[k]=_def[k]; });
      }
    }
  }
  d.version = APP_VER;   // stamp to current after a successful migration
  return d;
}
function autoRestore() {
  const raw = localStorage.getItem(APP_KEY);
  if (!raw) return;
  try {
    const d = migrateState(JSON.parse(raw));
    if (!d) return;
    _applyState(d);
  } catch(e){ console.warn('Restore failed',e); }
}
function _applyState(d) {
  S = Object.assign(buildDefaultState(), d);
  if (!S.settings) S.settings = buildDefaultState().settings;
  if (!S.positions||!Object.keys(S.positions).length){
    S.positions=JSON.parse(JSON.stringify(DEFAULT_POSITIONS));
  } else {
    // Migrate: add any missing posKeys from DEFAULT_POSITIONS (e.g. newly added positions)
    Object.entries(DEFAULT_POSITIONS).forEach(([dayType,posMap])=>{
      if(!S.positions[dayType]) S.positions[dayType]=JSON.parse(JSON.stringify(posMap));
      else Object.entries(posMap).forEach(([pk,pv])=>{
        if(!S.positions[dayType][pk]) S.positions[dayType][pk]=JSON.parse(JSON.stringify(pv));
      });
    });
    // Purge decommissioned FULL slots from all day types; remove DAY/HALF only from weekday/preHoliday
    const _fullKeys = ['kl_full','sw_full'];
    ['holiday','weekday','preHoliday'].forEach(dt=>{
      if(S.positions[dt]) _fullKeys.forEach(k=>{ delete S.positions[dt][k]; });
    });
    // Remove DAY/HALF from weekday and preHoliday (EVE-only days)
    ['weekday','preHoliday'].forEach(dt=>{
      if(S.positions[dt]){ delete S.positions[dt].kl_day; delete S.positions[dt].sw_day; delete S.positions[dt].kl_half; }
    });
    // Invalidate cached schedule if it contains any decommissioned slots
    const _badPosKeys = ['kl_full','sw_full'];
    if(S.schedule){
      const _hasBadSlots = Object.values(S.schedule.days||{}).some(day=>
        (day.slots||[]).some(sl=>_badPosKeys.includes(sl.posKey)||sl.shift==='FULL')
      );
      if(_hasBadSlots){ S.schedule=null; }
    }
    // Purge FULL from scheduleHistory entries
    Object.values(S.scheduleHistory||{}).forEach(entry=>{
      Object.values(entry).forEach(d=>{ if(d&&typeof d==='object') delete d.FULL; });
    });
  }
  if(!S.monthData)    S.monthData={};
  renderAll();
}
