function doImportStaff(){
  try{
    const arr=JSON.parse(document.getElementById('import-json').value.trim());
    if(!Array.isArray(arr)){showToast('ต้องเป็น JSON array','err');return;}
    let added=0, skipped=0;
    arr.forEach(item=>{
      if(!item.name){skipped++;return;}
      if(S.pharmacists.some(p=>p.name===item.name)){skipped++;return;}
      S.pharmacists.push({
        id: item.id||uuid(), name:item.name,
        deptPriority: item.deptPriority||'FIRST',
        department: item.department || (item.deptPriority==='LAST'?'prod':'disp'),
        preferredUnit: item.preferredUnit||null,
        flags: Object.assign({age50plus:false,newEmployee:false,inactive:false}, item.flags||{}),
        comp: Object.assign({warehouse:0,tdm:0}, item.comp||{}),
        leaveDays: item.leaveDays||{},
        notes: item.notes||''
      });
      added++;
    });
    closeModal('modal-import');
    autoSave(); renderStaffList(); updateNavBadges();
    showToast(`Import ${added} คน${skipped?` (ข้าม ${skipped})`:''}สำเร็จ`,'ok');
  }catch(e){ showToast('Import ล้มเหลว: '+e.message,'err'); }
}

