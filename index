        const nm=slot.assignedTo.split(' ')[0];
        const lockIco=slot.locked?'🔒':'🔓';
        cell=`<div class="slot-pill ${scls}${slot.locked?' locked':''}" title="${slot.assignedTo} · ${slot.label}">
          <button class="lock-btn${slot.locked?' locked-on':''}" onclick="toggleLock(${d},'${slot.id}')">${lockIco}</button>
          <span class="sn">${nm}</span>
          <span class="sx" onclick="removeSlot(${d},'${slot.id}')">✕</span>
        </div>`;
      } else {
        cell=`<div class="slot-empty req" onclick="openOverrideModal(${d},'${slot.id}')">+ จัด</div>`;
      }
      // ── POLISH-A: KL/SW combined-column flex container ──
      const isKlSw = col.posKey === 'kl' || col.posKey === 'sw';
      const tdInner = isKlSw
        ? `<div style="display:flex;flex-direction:column;gap:4px;width:100%">${cell}</div>`
        : cell;
      row+=`<td style="min-width:80px;vertical-align:top">${tdInner}</td>`;
    });
    row+=`</tr>`;
    body+=row;
  }
  table.innerHTML=`<thead>${h1}${h2}</thead><tbody>${body}</tbody>`;
  renderRepeatWarnings();
}

