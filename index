    let row=`<tr><td class="day-cell ${dayCls}" style="position:sticky;left:0;z-index:5">${d}<br>${dowLbl}${dtTag}</td>`;
    cols.forEach(col=>{
      const slot=slotMap[col.id];
      if(!slot){ row+=`<td class="na-cell"></td>`; return; }
      const scls=_SHIFT_PILL_CLS[slot.shift]||'';
      let cell='';
