function getPrevMonthKey() {
  let m=S.calState.month-1, y=S.calState.year;
  if(m<=0){m=12;y--;}
  return monthKey(m,y);
}
function getRollingCount(pharmName, shiftType) {
  const window = S.settings.balanceWindow||3;
  const {month,year}=S.calState;
  let tot=0;
  for(let i=1;i<=window;i++){
    let m=month-i, y=year;
    if(m<=0){m+=12;y--;}
    const hist=S.scheduleHistory[monthKey(m,y)];
    if(hist&&hist[pharmName]) tot+=(hist[pharmName][shiftType]||0);
  }
  return tot;
}

/* ── [REPEAT WARNING] read-only count helpers (no engine mutation) ──
   Two granularities by design:
     • column = posKey + '#' + slotIdx  (within-month only; history has no slotIdx)
     • room   = unit (KL/SW)            (within-month + cross-month)
   Cross-month source = scheduleHistory[...]._byPosKey (posKey-level), rolling balanceWindow.
   These helpers are pure reads; they do NOT change any scheduling decision. */
function _posKeyUnit(posKey){
  if(!posKey) return null;
  if(posKey.indexOf('kl_')===0) return 'KL';
  if(posKey.indexOf('sw_')===0) return 'SW';
  return null;
}
// Cross-month history counts over rolling window. Returns {byPosKey:{}, byUnit:{}, byColSlot:{}}.
function repeatHistCounts(name, window){
  window = window || (S.settings.balanceWindow||3);
  const {month,year}=S.calState;
  const byPosKey={}, byUnit={}, byColSlot={};
  for(let i=1;i<=window;i++){
    let m=month-i, y=year; if(m<=0){m+=12;y--;}
    const row=S.scheduleHistory[monthKey(m,y)]?.[name];
    if(!row) continue;
    const bpk=row._byPosKey;
    if(bpk) Object.entries(bpk).forEach(([pk,c])=>{
      byPosKey[pk]=(byPosKey[pk]||0)+c;
      const u=_posKeyUnit(pk); if(u) byUnit[u]=(byUnit[u]||0)+c;
    });
    const bcs=row._byColSlot;   // [SLOTIDX X-MONTH] exact 'posKey#slotIdx' counts (เดือนเก่าไม่มี → ข้าม)
    if(bcs) Object.entries(bcs).forEach(([ck,c])=>{ byColSlot[ck]=(byColSlot[ck]||0)+c; });
  }
  return {byPosKey, byUnit, byColSlot};
}
// Distribution counts from a finished schedule. Returns {col:{name:{posKey#slotIdx:n}}, unit:{name:{unit:n}}}.
function repeatSchedCounts(sched){
  sched = sched || S.schedule;
  const col={}, unit={};
  if(!sched) return {col, unit};
  Object.values(sched.days||{}).forEach(day=>{
    (day.slots||[]).forEach(sl=>{
      if(!sl.assignedTo) return;
      const n=sl.assignedTo, ck=sl.posKey+'#'+sl.slotIdx, u=sl.unit||'?';
      (col[n] ||= {}); col[n][ck]=(col[n][ck]||0)+1;
      (unit[n] ||= {}); unit[n][u]=(unit[n][u]||0)+1;
    });
  });
  return {col, unit};
}

/* ── [REPEAT WARNING] per-person warnings: counts exceeding group avg + threshold ──
   Combines within-month (current schedule) + cross-month (history) per LOCKED design.
   column = posKey level (history has no slotIdx) · room = unit level. Display-only. */
function repeatWarnings(sched){
  sched = sched || S.schedule;
  const out={column:[], room:[]};
  if(!sched) return out;
  const thr=S.settings.repeatThreshold ?? 1;
  const active=S.pharmacists.filter(isSchedulable).map(p=>p.name);
  const nSched=active.length||1;
  const {col, unit}=repeatSchedCounts(sched);
  const hist={}; active.forEach(n=>{ hist[n]=repeatHistCounts(n); });
  const unitNames={KL:'ห้องยากลาง', SW:'ห้องยาฉุกเฉิน'};
  const {posKeyInfo}=(typeof _buildSchedCols==='function')?_buildSchedCols():{posKeyInfo:{}};
  // within-month posKey totals (sum over slotIdx) per person
  const colByPos={};
  active.forEach(n=>{ colByPos[n]={}; Object.entries(col[n]||{}).forEach(([ck,c])=>{ const pk=ck.split('#')[0]; colByPos[n][pk]=(colByPos[n][pk]||0)+c; }); });
  // ROOM (unit)
  ['KL','SW'].forEach(U=>{
    const counts=active.map(n=>((unit[n]||{})[U]||0)+((hist[n]&&hist[n].byUnit[U])||0));
    const avg=counts.reduce((a,b)=>a+b,0)/nSched;
    active.forEach((n,i)=>{ if(counts[i]>avg+thr) out.room.push({name:n,unit:U,label:unitNames[U]||U,count:counts[i],avg:+avg.toFixed(1)}); });
  });
  // COLUMN (posKey level)
  const allPks=new Set();
  active.forEach(n=>{ Object.keys(colByPos[n]).forEach(p=>allPks.add(p)); Object.keys((hist[n]&&hist[n].byPosKey)||{}).forEach(p=>allPks.add(p)); });
  allPks.forEach(pk=>{
    const counts=active.map(n=>(colByPos[n][pk]||0)+((hist[n]&&hist[n].byPosKey[pk])||0));
    const avg=counts.reduce((a,b)=>a+b,0)/nSched;
    active.forEach((n,i)=>{ if(counts[i]>avg+thr) out.column.push({name:n,posKey:pk,label:(posKeyInfo[pk]&&posKeyInfo[pk].label)||pk,count:counts[i],avg:+avg.toFixed(1)}); });
  });
  return out;
}

/* ── build skeleton ── */
function buildScheduleSkeleton() {
  const m=S.calState.month, y=S.calState.year, cY=y-543;
  const days=new Date(cY,m,0).getDate();
  const skel={month:m,year:y,days:{},stats:{},violations:[]};
  const prevSched=S.schedule;
  for(let d=1;d<=days;d++){
    const dayType=getEffectiveDayType(d);
    const posSlots=S.positions[dayType]||{};
    const slots=[];
    for(const [posKey,posVal] of Object.entries(posSlots)){
      for(let i=0;i<(posVal.count||0);i++){
        const id=`${posKey}_${i}`;
        const prev=prevSched?.days?.[d]?.slots?.find(s=>s.id===id);
        slots.push({
          id, posKey, slotIdx:i,
          label:posVal.label,
          shift:posVal.shift,
          unit:posVal.unit,
          assignedTo: prev?.locked ? prev.assignedTo : null,
          locked: prev?.locked||false
        });
      }
    }
    skel.days[d]={dayType,slots};
  }
  return skel;
}

/* ── quota calc ── */
function computeBaseQuota(sched) {
  const totSlots={}, eligible={};
  const active=S.pharmacists.filter(isSchedulable);
  Object.values(sched.days).forEach(day=>{
    day.slots.forEach(sl=>{ totSlots[sl.shift]=(totSlots[sl.shift]||0)+1; });
  });
  Object.keys(totSlots).forEach(sh=>{
    eligible[sh]=active.filter(p=>isEligibleForShift(p,sh)).length||1;
  });
  const bq={};
  Object.keys(totSlots).forEach(sh=>{ bq[sh]=totSlots[sh]/eligible[sh]; });
  return bq;
}

/* ── scoring ── */
function scoreCandidate(p, shift, shiftCounts, totalHours, baseQuota, avgShiftHrs, cumDeficit, nbBlocked) {
  const cnts=shiftCounts[p.id]||{};
  const s1=cnts[shift]||0;
  const s2=getRollingCount(p.name,shift);
  const reduction=compensationReduction(p);
  const netQ=Math.max(0,(baseQuota[shift]||0)-reduction);
  const s3=Math.max(0,s1-netQ);
  // s4: include virtual comp pre-load — so comp workers appear "busier" in both
  // spread constraint (HC-3) and fairness score, receiving fewer real shifts.
  const s4=totalHours[p.id]||0;
  // s5: [FEATURE M] cumulative fairness — projected cumulative POSITION this month
  // = entry hours-vs-average (−deficit) PLUS hours already taken this month (s4).
  // Behind people (deficit>0) start low and are picked first; as they accumulate
  // within-month hours the boost self-decays toward parity → converges cumulative spread.
  const _def=(cumDeficit && cumDeficit[p.id]) || 0;
  const s5=s4 - _def;
  const W1=10,W2=3,W3=20,W4=2;
  // [FEATURE N-6] HALF balances across months only via s2 (single slot-index → no rotation
  // leverage); give HALF a heavier rolling weight so repeats are pushed apart cross-month.
  const W2eff = (shift==='HALF') ? (S.settings.halfRollingWeight ?? W2) : W2;
  const W5=S.settings.cumulativeWeight ?? 6;   // configurable via settings — not hardcoded
  // s6: [PART A] Shift Burden Equity — directional cross-month burden balancing.
  // Each person carries a "burden load" = Σ(rollingCount[shift] × burden[shift]) over the
  // rolling window. burden map: heavy shifts positive (OVNT+3, NIGHT+2), light shift
  // negative (HALF−2), neutral 0 (DAY/EVE). The term flips direction by the CURRENT shift's
  // burden sign: for a heavy shift (burden>0) a high-load person scores WORSE (pushed away);
  // for a light shift (burden<0) a high-load person scores BETTER (gets it first). Neutral
  // shifts (burden===0) contribute nothing. burdenWeight=0 → exact parity (term vanishes).
  const W6 = S.settings.burdenWeight ?? 0;
  let s6 = 0;
  if(W6!==0){
    const bmap = S.settings.burden || {};
    const curB = bmap[shift] || 0;
    if(curB!==0){
      let load=0;
      Object.keys(bmap).forEach(sh=>{ load += getRollingCount(p.name,sh) * (bmap[sh]||0); });
      // sign(curB): heavy→+1 (penalize high load), light→−1 (reward high load)
      s6 = load * (curB>0 ? 1 : -1);
    }
  }
  // s7: [NEWBIE] ชดเชยชั่วโมงให้น้องใหม่ที่ถูก pairing guard กันออก — block มาก → คะแนนต่ำ
  // → ถูกเลือกก่อนใน seat อื่น (รวม slotIdx สูงที่ว่าง) → ชั่วโมงเดือนไม่ต่ำกว่า mean · 0=ปิด
  const W7 = S.settings.newbieBlockBoost ?? 4;
  const s7 = (nbBlocked && nbBlocked[p.id]) || 0;
  return W1*s1 + W2eff*s2 + W3*s3 + W4*s4 + W5*s5 + W6*s6 - W7*s7;
}

/* ── HC-1 check ── */
function didOvntYesterday(name, dayNum, ovntOnDay, prevOvnt) {
  if(dayNum>1) return (ovntOnDay[dayNum-1]||new Set()).has(name);
  if(dayNum===1) return prevOvnt===name;
  return false;
}

/* ── validate ── */
function validateSchedule(sched, prevLastOvnt) {
  const errs=[];
  const days=Object.keys(sched.days).map(Number).sort((a,b)=>a-b);
  const ovntOnDay={};
  days.forEach(d=>{
    const assigned=new Set();
    sched.days[d].slots.forEach(sl=>{
      if(!sl.assignedTo) return;
      if(assigned.has(sl.assignedTo))
        errs.push(`HC-2: ${sl.assignedTo} มี 2 เวรในวันที่ ${d}`);
      assigned.add(sl.assignedTo);
      if(sl.shift==='OVNT'){
        if(!ovntOnDay[d]) ovntOnDay[d]=new Set();
        ovntOnDay[d].add(sl.assignedTo);
      }
    });
  });
  // HC-1: OVNT สิ้นสุด 08:30 → ห้ามขึ้นเวรเช้า (DAY/HALF 08:00) หรือ AE (EVE 16:30) วันถัดไป
  days.forEach(d=>{
    sched.days[d].slots.forEach(sl=>{
      if(!sl.assignedTo||!['DAY','HALF','EVE'].includes(sl.shift)) return;
      if(didOvntYesterday(sl.assignedTo, d, ovntOnDay, prevLastOvnt)){
        const shiftLabel=sl.shift==='EVE'?'AE':'เช้า';
        errs.push(`HC-1: ${sl.assignedTo} เวรดึกวันที่ ${d-1} ต่อเวร${shiftLabel}วันที่ ${d} (gap < 12h)`);
      }
    });
  });
  // ── [BUDDY v4_2_0] soft notice: สมาชิกกลุ่ม buddy ขึ้นเวรวันเดียวกัน ──
  // exclusion เป็น soft (coverage ชนะ) → เกิดได้เฉพาะเคส coverage-forced · ไม่ใช่ HC
  // แต่ push เข้า list (prefix "BUDDY:") ให้หัวหน้าเห็นและจัดการเอง
  (S.buddyPairs||[]).forEach(g=>{
    if(!g || !Array.isArray(g.members) || g.members.length<2) return;
    const names=g.members.map(id=>{ const m=S.pharmacists.find(x=>x.id===id); return (m && isNewbie(m))?m.name:null; }).filter(Boolean);
    if(names.length<2) return;
    days.forEach(d=>{
      const on=names.filter(n=>sched.days[d].slots.some(sl=>sl.assignedTo===n));
      if(on.length>=2) errs.push(`BUDDY: ${on.join(' + ')} (กลุ่มผูก) ขึ้นเวรวันเดียวกันที่ ${d} — coverage forced`);
    });
  });
  // ── [MIN-1 SLOT] surface คน schedulable ที่ได้เวร <4 ชม. (hard rule เบิกเงิน — ปกติ post-pass เติมให้แล้ว) ──
  if(S.settings.minOneSlotGuarantee !== false){
    const _QUAL = (Array.isArray(S.settings.minSlotShifts) && S.settings.minSlotShifts.length) ? S.settings.minSlotShifts : ['DAY','NIGHT','OVNT'];
    S.pharmacists.filter(isSchedulable).forEach(p=>{
      let _big=false;
      days.forEach(d=>sched.days[d].slots.forEach(sl=>{ if(sl.assignedTo===p.name && _QUAL.includes(sl.shift)) _big=true; }));
      if(!_big) errs.push(`MIN1: ${p.name} ไม่มีเวรเต็มผลัด (${_QUAL.join('/')}) — ไม่นับ 2×EVE (swap ไม่สำเร็จเดือนนี้)`);
    });
  }
  return errs;
}

/* ══ MAIN SCHEDULER ══ */
function runScheduler() {
  const active=S.pharmacists.filter(isSchedulable);
  if(!active.length){ showToast('ยังไม่มีเภสัชกรที่ขึ้นเวรได้','warn'); return; }
  if(!S.calState.month){ showToast('กรุณาเลือกเดือนในแท็บ 03 ก่อน','warn'); return; }
  if(!Object.keys(S.calState.dayTypes||{}).length) initMonthDayTypes();

  const sched=buildScheduleSkeleton();
  // [V4 RNG] run-scoped seeded RNG — rngSeed>0 = reproducible · 0 = auto (บันทึก seed ที่ใช้ลง sched)
  const _rngSeed=((S.settings.rngSeed|0)>0) ? (S.settings.rngSeed|0)
                 : (((Date.now() ^ (Math.random()*0xFFFFFFFF)) >>> 0) || 1);
  const _rng=_mulberry32(_rngSeed);
  sched._rngSeed=_rngSeed;
  const bq=computeBaseQuota(sched);
  const shiftCounts={}, totalHours={};
  // HALF rotation: dedicated per-pharmacist HALF counter for strict cycle enforcement
  const halfCounts={};  // { [p.id]: number } — tracks HALF assignments this month
  // [FEATURE N-RR] NIGHT/OVNT/DAY round-robin counters — same pattern as halfCounts.
  // Ensures every eligible person gets 1 of each rotation shift before anyone gets 2.
  // Cross-month aware: seeded from rolling history so someone who took OVNT last
  // month is deprioritized this month (rotation = withinMonth + historySeed).
  const nightCounts={};  // within-month NIGHT assignments
  const ovntCounts={};   // within-month OVNT assignments
  const dayCounts={};    // within-month DAY assignments
  // History seed (rolling balanceWindow) — read once, constant during the run.
  const _rrHistNight={}, _rrHistOvnt={}, _rrHistDay={};
  // [EXPERIMENTAL — OT-Guarantee Exemption] คน OT raw >= threshold ถูก "ลดความสำคัญ" (ไม่ใช่ห้าม)
  // ใน N-RR rotation-min tier: ถ้ามีคนไม่ exempt อยู่ใน pool ก็จะถูกเลือกก่อนเสมอ
  // ถ้าทุกคน exempt (เหลือแต่คน OT) → fallback กลับมาเป็น tier ปกติ (coverage ชนะ)
  const _otGuaranteeExemptH = S.settings.otGuaranteeExemptHours ?? 8;
  const _otExempt=(p)=> compVirtualHoursRaw(p._effectiveComp||{}) >= _otGuaranteeExemptH;
  const _rrPenalty=(p)=> _otExempt(p) ? 999 : 0;
  // Effective rotation count = within-month + history seed (used by the gates).
  const _rrNight=(p)=>(nightCounts[p.id]||0)+(_rrHistNight[p.id]||0)+_rrPenalty(p);
  const _rrOvnt =(p)=>(ovntCounts[p.id] ||0)+(_rrHistOvnt[p.id] ||0)+_rrPenalty(p);
  const _rrDay  =(p)=>(dayCounts[p.id]  ||0)+(_rrHistDay[p.id]  ||0)+_rrPenalty(p);
  // [FEATURE N] slot-index rotation: { [name]: { [posKey]: Set<slotIdx> } } — soft, coverage wins
  const slotIndexUsed={};
  // ── [CYCLIC COVERAGE COUNTER] per-person seat-rotation tier (soft · coverage ชนะเสมอ) ──
  // 14-bucket posKey#slotIdx · "ถังต่ำสุด (normalize ด้วย floor รายคน) = เลือกก่อน" จนล้างหนี้
  // history seed = repeatHistCounts(.byColSlot) — อ่าน _byColSlot ที่ backfill จาก CSV จริง (window 12)
  // bucket-exclusion: age50+ → ตัดถัง sw_ovnt (eligibility จริงที่ engine บังคับ) · preferredUnit ยังไม่ตัด (ดู KB §14 IDEA-1)
  // reset −floor on-the-fly = เทียบเท่า "ลบทุกถัง −1 เมื่อครบ ≥1 วนรอบ" (ไม่ mutate state)
  // flag: S.settings.cyclicCounterOn (default true · false = parity กับพฤติกรรมเดิมเป๊ะ)
  const _cycOn   = S.settings.cyclicCounterOn !== false;
  const _cycSeats= new Set();   // จักรวาลที่นั่งเดือนนี้ posKey#slotIdx
  const _cycHist = {};          // name -> { ck:count } (ข้ามเดือน)
  const _cycLive = {};          // name -> { ck:count } (ในเดือน)
  if(_cycOn){
    Object.values(sched.days||{}).forEach(day=>(day.slots||[]).forEach(s=>{
      if(s.posKey) _cycSeats.add(s.posKey+'#'+s.slotIdx);
    }));
    active.forEach(p=>{ _cycHist[p.name]=(repeatHistCounts(p.name,12).byColSlot)||{}; });
  }
  const _cycRaw = (name,ck)=>(_cycHist[name]?.[ck]||0)+(_cycLive[name]?.[ck]||0);
  const _cycFloor = (p)=>{ let mn=Infinity;
    _cycSeats.forEach(ck=>{
      if(p.flags?.age50plus && ck.indexOf('sw_ovnt#')===0) return;  // ตัดถังที่ขึ้นไม่ได้
      const v=_cycRaw(p.name,ck); if(v<mn) mn=v;
    });
    return mn===Infinity?0:mn;
  };
  const _cycNorm = (p,ck)=>_cycRaw(p.name,ck)-_cycFloor(p);
  // ── [REPEAT WARNING] live distribution counters (soft, repeatWeight; 0 = off → parity) ──
  const _rw   = S.settings.repeatWeight || 0;
  const _rThr = S.settings.repeatThreshold ?? 1;
  const repCol={}, repUnit={};            // name -> { K#i / unit : count }  (this month, live)
  const repHistPos={}, repHistUnit={};    // name -> { posKey / unit : count } (cross-month seed)
  const repHistColSlot={};                // name -> { 'posKey#slotIdx' : count } (cross-month, slotIdx-precise)
  const _repColTot={}, _repUnitTot={};    // group totals (incl. history) for average
  const _repPosTot={}, _repColSlotTot={}; // group posKey / colSlot totals (history)
  let _nSched=0;
  if(_rw>0){
    active.forEach(p=>{
      _nSched++;
      const h=repeatHistCounts(p.name);
      repHistPos[p.name]=h.byPosKey; repHistUnit[p.name]=h.byUnit; repHistColSlot[p.name]=h.byColSlot;
      Object.entries(h.byPosKey).forEach(([pk,c])=>{ _repPosTot[pk]=(_repPosTot[pk]||0)+c; });
      Object.entries(h.byUnit).forEach(([u,c])=>{ _repUnitTot[u]=(_repUnitTot[u]||0)+c; });
      Object.entries(h.byColSlot).forEach(([ck,c])=>{ _repColSlotTot[ck]=(_repColSlotTot[ck]||0)+c; });
    });
  }
  // Soft repeat penalty for candidate p taking slot (posKey K, slotIdx i, unit U).
  // Average-relative: penalty only when person exceeds group avg + threshold. Returns 0 when _rw=0.
  function _repeatPenalty(p, slot){
    if(_rw<=0 || _nSched<=0) return 0;
    const K=slot.posKey, ck=K+'#'+slot.slotIdx, U=slot.unit||'?';
    // [SLOTIDX X-MONTH] cross-month term keyed by exact 'posKey#slotIdx' (ck) แทน posKey (K)
    // → หมุนเวียนตำแหน่งย่อยข้ามเดือน · เดือนเก่าไม่มี _byColSlot → นับ 0 (graceful)
    const myCol=((repCol[p.name]||{})[ck]||0) + ((repHistColSlot[p.name]||{})[ck]||0);
    const avgCol=((_repColTot[ck]||0)+(_repColSlotTot[ck]||0))/_nSched;
    const exCol=Math.max(0, myCol-(avgCol+_rThr));
    const myUnit=((repUnit[p.name]||{})[U]||0) + ((repHistUnit[p.name]||{})[U]||0);
    const avgUnit=(_repUnitTot[U]||0)/_nSched;
    const exUnit=Math.max(0, myUnit-(avgUnit+_rThr));
    return _rw*(exCol+exUnit);
  }
  // Pre-load virtual hours for comp reduction so HC-3 spread + scoring both treat
  // comp workers as having fewer remaining shifts. Use average shift hours as proxy.
  const avgShiftHrs=(()=>{
    const metas=Object.values(SHIFT_META).map(m=>m.hours||0).filter(h=>h>0);
    return metas.length ? metas.reduce((a,b)=>a+b,0)/metas.length : 8;
  })();
  // ── [ROLLOVER LEDGER] Step 5: Load previous month's leftover and inject as BF ──
  const prevMk=getPrevMonthKey();
  const prevHistEntry = S.scheduleHistory[prevMk] || {};
  const prevLeftoverByName = prevHistEntry._meta?.leftoverByName || {};

  // ── [FEATURE M] Cumulative Fairness deficit — RATE-BASED, leave-aware ──
  // วัดบน "อัตราชั่วโมง/เดือนที่ทำงานจริง" ไม่ใช่ยอดสะสมดิบ:
  //   deficit = (อัตราเฉลี่ยกลุ่ม × เดือน active ของคนนี้) − สะสมจริง
  //   >0 = ตามหลังตามอัตรา (score ต่ำ → ถูกหยิบก่อน) ; <0 = นำ
  // • คนลา/พัก: เดือนที่ grandTotal=0 ไม่ถูกนับใน denominator → อัตราไม่เพี้ยน → ไม่โดนไล่ catch-up
  // • คนทำงานครบทุกเดือนเท่ากัน: สูตรลดรูปเป็น (projectedAvgCum − cum) เดิม → พฤติกรรมไม่เปลี่ยน (parity)
  // • [GUARD A] เพิ่งกลับจากพัก (เดือนก่อนหน้าไม่มีชั่วโมง) → เริ่มที่ par (deficit 0) เลยในเดือนแรก
  // soft term เท่านั้น — HC/coverage/age50-OVNT ชนะเสมอ. Virtual Hours pre-load (s4) ไม่ถูกแตะ
  const _prevCum  = prevHistEntry._meta?._cumulativeHrs || {};
  const _cumFrom  = prevHistEntry._meta?._cumulativeFrom || null;
  // นับเดือน active ต่อคน = เดือนในกรอบสะสม (≤ เดือนก่อนหน้า, ≥ _cumulativeFrom) ที่ grandTotal > 0
  const _activeMonths = {};
  Object.keys(S.scheduleHistory || {}).forEach(mk => {
    if (_cumFrom && mk < _cumFrom) return;
    if (mk > prevMk) return;
    const month = S.scheduleHistory[mk] || {};
    Object.keys(month).forEach(name => {
      if (name === '_meta') return;
      const gt = month[name] && month[name].grandTotal;
      if (typeof gt === 'number' && gt > 0) _activeMonths[name] = (_activeMonths[name] || 0) + 1;
    });
  });
  // pooled group rate = Σ สะสม / Σ เดือน active (เฉพาะคนที่เคยทำงานในกรอบ)
  let _sumCum = 0, _sumMon = 0;
  active.forEach(p => {
    const c = _prevCum[p.name], m = _activeMonths[p.name] || 0;
    if (typeof c === 'number' && m > 0) { _sumCum += c; _sumMon += m; }
  });
  const _avgRate = _sumMon > 0 ? _sumCum / _sumMon : 0;
  // เก็บไว้เผื่อ report/อนาคต — ค่าเฉลี่ยสะสมแบบเดิม
  const _cumVals = active.map(p => _prevCum[p.name]).filter(v => typeof v === 'number');
  const projectedAvgCum = _cumVals.length ? _cumVals.reduce((a,b)=>a+b,0)/_cumVals.length : 0;
  const cumDeficit = {};
  S.pharmacists.forEach(p => {
    const prevRow = prevHistEntry[p.name];
    const prevWorked = prevRow && typeof prevRow.grandTotal === 'number' && prevRow.grandTotal > 0;
    if (!p.flags?.inactive && !prevWorked) { cumDeficit[p.id] = 0; return; }  // [A] กลับจากพัก/คนใหม่ → par
    const c = _prevCum[p.name], m = _activeMonths[p.name] || 0;
    if (typeof c !== 'number' || m === 0) { cumDeficit[p.id] = 0; return; }    // ไม่มีประวัติ → par
    cumDeficit[p.id] = +(((_avgRate * m) - c).toFixed(2));                     // [B] rate-based
  });

  S.pharmacists.forEach(p=>{
    shiftCounts[p.id]={};
    halfCounts[p.id]=0;
    nightCounts[p.id]=0;
    ovntCounts[p.id]=0;
    dayCounts[p.id]=0;
    // [FEATURE N-RR · PHASE 1] within-month rotation only. Cross-month history seed
    // is intentionally 0 here — strict round-robin operates within the current month.
    // (Cross-month balancing is deferred to Part A "Burden Equity" to avoid double-
    //  pulling against Feature M's cumulative-hours term.) Flip these to
    //  getRollingCount(p.name, SHIFT) in a future phase to enable cross-month rotation.
    _rrHistNight[p.id]=0;
    _rrHistOvnt[p.id] =0;
    _rrHistDay[p.id]  =0;
    // Rollover BF: remainder saved at last archive for this pharmacist (per role id + total)
    const bf = prevLeftoverByName[p.name] || { total: 0 };
    // Effective comp per role = newly typed hours (p.comp[id]) + automated BF from previous month.
    // We do NOT persist this merge — transient for this run only. Virtual hours = Σ credits×rate
    // over roles with needsComp (compVirtualHours), matching archive deduction rates exactly.
    const effComp={};
    getCompRoles().forEach(r=>{ effComp[r.id] = +(((p.comp[r.id]||0) + (bf[r.id]||0)).toFixed(2)); });
    totalHours[p.id] = compVirtualHoursRaw(effComp);
    // Cache effective comp for scoring/reporting (keep legacy warehouse/tdm keys available)
    p._effectiveComp = Object.assign({}, effComp, { bf });
  });

  // Cross-month carry-overs
  const prevLastOvnt=(prevHistEntry._meta?.lastOvnt)||null;
  // Who missed EVE last month → must get it first this month
  const prevMissedEve=new Set(prevHistEntry?._meta?.missedEve||[]);

  const days=Object.keys(sched.days).map(Number).sort((a,b)=>a-b);
  const ovntOnDay={};

  const _nbBlocked={};    // [NEWBIE] นับครั้งที่น้องใหม่ถูกกันออกจาก seat (ใช้ชดเชยชั่วโมง s7)

  for(const dayNum of days){
    const day=sched.days[dayNum];
    const assignedToday=new Set();

    // Count locked slots first
    day.slots.forEach(sl=>{
      if(sl.locked&&sl.assignedTo){
        const p=S.pharmacists.find(x=>x.name===sl.assignedTo);
        if(p){
          shiftCounts[p.id][sl.shift]=(shiftCounts[p.id][sl.shift]||0)+1;
          if(sl.shift==='HALF')  halfCounts[p.id]=(halfCounts[p.id]||0)+1;
          if(sl.shift==='NIGHT') nightCounts[p.id]=(nightCounts[p.id]||0)+1;
          if(sl.shift==='OVNT')  ovntCounts[p.id]=(ovntCounts[p.id]||0)+1;
          if(sl.shift==='DAY')   dayCounts[p.id]=(dayCounts[p.id]||0)+1;
          totalHours[p.id]+=getSlotMeta(sl).hours;
          assignedToday.add(sl.assignedTo);
          if(sl.shift==='OVNT'){ if(!ovntOnDay[dayNum])ovntOnDay[dayNum]=new Set(); ovntOnDay[dayNum].add(sl.assignedTo); }
        }
      }
    });

    // Sort slots by SHIFT_ORDER_ALG
    const unlockedSlots=day.slots.filter(sl=>!sl.locked).sort((a,b)=>
      SHIFT_ORDER_ALG.indexOf(a.shift)-SHIFT_ORDER_ALG.indexOf(b.shift));

    // ── [NEWBIE] Senior-anchor rotation ──────────────────────────────────
    // จองที่นั่ง senior 1 ที่ต่อกลุ่มหลายสล็อต โดย anchor "หมุนตามวัน" แล้วเติมก่อน
    // → senior การันตี + น้องใหม่วนได้ครบทุก slotIdx (รวมตำแหน่งสูงสุด) ข้ามวัน
    unlockedSlots.forEach(s=>{ delete s._needSenior; });          // กัน flag ค้างจาก run ก่อน
    {
      const isSr=n=>isSenior(S.pharmacists.find(x=>x.name===n));
      const groups={};
      unlockedSlots.forEach(s=>{ (groups[s.posKey] ||= []).push(s); });  // เฉพาะ seat ที่ยังเปิด
      const lockedSenior={};
      day.slots.forEach(s=>{ if(s.locked&&s.assignedTo&&isSr(s.assignedTo)) lockedSenior[s.posKey]=true; });
      Object.entries(groups).forEach(([pk,arr])=>{
        if(arr.length<=1 || lockedSenior[pk]) return;             // ห้องเดี่ยว/มี senior ล็อกแล้ว → ข้าม
        const anchor=arr[dayNum % arr.length];                    // anchor หมุนตามวัน
        anchor._needSenior=true;
      });
    }
    // ดัน anchor seat ขึ้นเติมก่อน (sort เสถียร → ลำดับ shift เดิมของ seat อื่นคงไว้)
    unlockedSlots.sort((a,b)=> (b._needSenior?1:0)-(a._needSenior?1:0));

    for(const slot of unlockedSlots){
      // Get valid candidates
      let candidates=active.filter(p=>{
        if(!isEligibleForShift(p,slot.shift)) return false;
        if(assignedToday.has(p.name)) return false; // HC-2
        if(['DAY','HALF','EVE'].includes(slot.shift)&&didOvntYesterday(p.name,dayNum,ovntOnDay,prevLastOvnt)) return false; // HC-1: OVNT ends 08:30 → ห้ามเวรเช้า/AE วันถัดไป
        return true;
      });

      if(!candidates.length){ slot.assignedTo=null; continue; }

      // ── [BUDDY v4_2_0] Mutual-exclusion (soft, coverage ALWAYS wins) ──
      // สมาชิกกลุ่ม buddy (น้องใหม่) ห้ามขึ้นเวรวันเดียวกัน → กันคนที่มีเพื่อนร่วมกลุ่ม
      // ขึ้นแล้ววันนี้ออกจาก pool ก่อน seniority/N-RR/HC-3 (exclusion มาก่อน rotation/spread).
      // ตัดเฉพาะ "น้องใหม่" เท่านั้น (mate เป็น newbie) → ไม่เคยตัด senior ออก = Newbie guard
      // ไม่ถูกแตะ. ถ้าตัดแล้วว่าง → คงรายชื่อเดิม (coverage ชนะ ไม่ null) เคส forced ถูก log
      // ใน validateSchedule. ไม่แตะ totalHours/rotation ใดๆ (ไม่เกี่ยวชั่วโมง).
      if(candidates.length>1){
        const _noBuddyClash=candidates.filter(p=>!buddyMateNamesOf(p).some(n=>assignedToday.has(n)));
        if(_noBuddyClash.length>0) candidates=_noBuddyClash;
      }

      // ── [NEWBIE] Seniority filter: anchor บังคับ senior · มี fallback กัน deadlock ──
      {
        const _g=(day.slots||[]).filter(s=>s.posKey===slot.posKey);
        const _names=_g.filter(s=>s.assignedTo).map(s=>s.assignedTo);
        const _hasSr=_names.some(n=>isSenior(S.pharmacists.find(x=>x.name===n)));
        const _open=_g.filter(s=>!s.assignedTo).length;
        // ต้องการ senior เมื่อ: เป็น anchor seat  หรือ  เป็น seat เปิดสุดท้ายที่ยังไม่มี senior (safety net)
        const needSenior = slot._needSenior || (_g.length>1 && !_hasSr && _open===1);
        if(needSenior){
          const sr=candidates.filter(isSenior);
          if(sr.length>0){
            candidates.filter(isNewbie).forEach(p=>{ _nbBlocked[p.id]=(_nbBlocked[p.id]||0)+1; }); // สัญญาณชดเชยชั่วโมง
            candidates=sr;
          }
          // ไม่มี senior ว่าง (ลา/HC-1) → ปล่อยตามเดิม coverage ชนะ · ไปแลกกันเองนอกตาราง ไม่ flag
        }
      }

      // ── [FEATURE N-RR] Rotation PRE-FILTER (runs BEFORE HC-3 so rotation wins spread) ──
      // For DAY/NIGHT/OVNT: every eligible person must get 1 (within this month) before
      // anyone gets 2. We narrow to the rotation-minimum tier on the RAW candidate pool
      // (post HC-1/HC-2 only), THEN let HC-3 act as a tie-break inside that tier. This
      // guarantees a rotation-0 person is never skipped just because their hours are high
      // — per governing spec, rotation coverage outranks the 4–8h spread target.
      // Coverage still always wins (candidates never emptied).
      const _rrFn = slot.shift==='OVNT' ? _rrOvnt
                  : slot.shift==='NIGHT'? _rrNight
                  : slot.shift==='DAY'  ? _rrDay : null;
      if(_rrFn && candidates.length>1){
        const minRR=Math.min(...candidates.map(_rrFn));
        const rrTier=candidates.filter(p=>_rrFn(p)===minRR);
        if(rrTier.length>0) candidates=rrTier;
      }

      // HC-3: Max hour spread constraint — totalHours already includes virtual comp pre-load,
      // so comp workers naturally appear "busier" and are filtered out of the spread window.
      // For rotation shifts this now operates WITHIN the rotation-min tier (tie-break only).
      const maxSpread=S.settings.maxHourSpread??2;
      if(maxSpread>0&&candidates.length>1){
        const minHrs=Math.min(...candidates.map(p=>totalHours[p.id]||0));
        const spreadFiltered=candidates.filter(p=>(totalHours[p.id]||0)<=minHrs+maxSpread);
        if(spreadFiltered.length>0) candidates=spreadFiltered;
      }

      // Score + sort (lower = better)
      // shuffleTies: pre-shuffle candidates with Fisher-Yates before scoring so ties
      // are broken randomly without the non-transitive sort hack. [V4] uses seeded _rng.
      if(S.settings.shuffleTies){
        for(let i=candidates.length-1;i>0;i--){
          const j=Math.floor(_rng()*(i+1));
          [candidates[i],candidates[j]]=[candidates[j],candidates[i]];
        }
      }
      const scored=candidates.map(p=>({p,score:scoreCandidate(p,slot.shift,shiftCounts,totalHours,bq,avgShiftHrs,cumDeficit,_nbBlocked)+_repeatPenalty(p,slot)}));
      scored.sort((a,b)=>a.score-b.score);
      const _scoreOf=new Map(scored.map(x=>[x.p,x.score]));   // [V4 FILTER-4] lookup for tie detection

      let ranked=scored.map(x=>x.p);
      // [DEPT POLICY REMOVED] deptPriority (จ่ายยา/คลัง vs ผลิต) เป็น "ป้ายแผนก" เท่านั้น
      // ไม่มีผลต่อการเลือกเวรอีกแล้ว — ตารางครอบเฉพาะ คลัง/จ่ายยา, ผลิตไม่ขึ้นเวร,
      // เก็บไว้เพื่อรองรับการโยกย้ายบุคลากรโดยไม่ต้องลบชื่อ
      // EVE carry-over priority: who missed EVE last month AND still has no EVE this month → front of queue
      if(slot.shift==='EVE' && prevMissedEve.size>0){
        const needEve=ranked.filter(p=>prevMissedEve.has(p.name)&&!(shiftCounts[p.id]?.EVE));
        const others =ranked.filter(p=>!prevMissedEve.has(p.name)||(shiftCounts[p.id]?.EVE));
        if(needEve.length) ranked=[...needEve,...others];
      }

      // ── HALF Fair Rotation: enforce strict cycle before allowing repeat ──
      // HC-3 may have already removed low-halfCount candidates; relax HC-3 for HALF
      // by also considering pre-HC3 candidates when minHalf tier is absent post-filter.
      if(slot.shift==='HALF' && ranked.length>1){
        const minHalf=Math.min(...ranked.map(p=>halfCounts[p.id]||0));
        const halfFiltered=ranked.filter(p=>(halfCounts[p.id]||0)===minHalf);
        if(halfFiltered.length>0){
          ranked=halfFiltered;
        } else {
          // All minHalf candidates were removed by HC-3 — re-admit from scored list
          const scoredByHalf=scored.map(x=>x.p).filter(p=>isEligibleForShift(p,'HALF'));
          const minHalfAll=Math.min(...scoredByHalf.map(p=>halfCounts[p.id]||0));
          const relaxed=scoredByHalf.filter(p=>(halfCounts[p.id]||0)===minHalfAll);
          if(relaxed.length>0) ranked=relaxed;
        }
      }

      // ── [FEATURE N-RR] Rotation re-affirm after scoring (DAY/NIGHT/OVNT) ──
      // Pre-filter already narrowed candidates to the rotation-min tier before HC-3,
      // but scoring/shuffle reorders within the tier. Re-affirm here using the SAME
      // effective count so the winner is always from the rotation-minimum.
      // Coverage still wins (never empties ranked).
      if(_rrFn && ranked.length>1){
        const minRR=Math.min(...ranked.map(_rrFn));
        const rrTier=ranked.filter(p=>_rrFn(p)===minRR);
        if(rrTier.length>0) ranked=rrTier;
      }

      // ── [FEATURE N] Slot-Index Rotation (soft, coverage ALWAYS wins) ──
      // Tier A = candidates who have NOT yet taken this (posKey, slotIdx) this month;
      // Tier B = those who have. Prefer A; if A is empty keep the full list so the slot
      // is NEVER nulled by rotation. Runs last → cannot undo HC/eligibility/EVE/priority.
      if(ranked.length>1){
        const fresh=ranked.filter(p=>!(slotIndexUsed[p.name]?.[slot.posKey]?.has(slot.slotIdx)));
        if(fresh.length>0) ranked=fresh;
      }

      // ── [CYCLIC COVERAGE] seat-rotation tier (เสริม · ก่อน V4 FILTER-4 tie-break เดิม) ──
      // ถัง posKey#slotIdx ของ slot นี้ (normalize floor รายคน) ต่ำสุด = เลือกก่อน
      // soft: narrow เฉพาะเมื่อมี min ชัด · ไม่เคยทำ ranked ว่าง (coverage ชนะ) · ปิดด้วย flag → parity
      if(_cycOn && ranked.length>1){
        const _cck=slot.posKey+'#'+slot.slotIdx;
        const _minC=Math.min(...ranked.map(p=>_cycNorm(p,_cck)));
        const _cTier=ranked.filter(p=>_cycNorm(p,_cck)===_minC);
        if(_cTier.length>0 && _cTier.length<ranked.length) ranked=_cTier;
      }

      // ── [V4 FILTER-4] Variety-Aware Tie-Break (Target-Driven preserved) ─────────
      // ทำงาน "เฉพาะตอนคะแนน (skew) เสมอจริง" หลังผ่านทุก tier — Filter 3 ยังตัดสินก่อนเสมอ
      // ในกลุ่มเสมอ: ใครเคยทำตำแหน่งนี้ (posKey#slotIdx · ในเดือน+ข้ามเดือน) น้อยสุดได้ก่อน
      // → กระจายประเภทงาน/ทำเลห้องยา ไม่ซ้ำซาก · เสมอซ้ำ → ลำดับ seeded-shuffle ตัดสิน (reproducible)
      if(ranked.length>1){
        const _s0=_scoreOf.get(ranked[0]);
        const _tied=ranked.filter(p=>Math.abs(_scoreOf.get(p)-_s0)<1e-9);
        if(_tied.length>1){
          const _vck=slot.posKey+'#'+slot.slotIdx;
          const _vAt=p=>((repCol[p.name]||{})[_vck]||0)+((repHistColSlot[p.name]||{})[_vck]||0);
          const _minV=Math.min(..._tied.map(_vAt));
          const _vTier=_tied.filter(p=>_vAt(p)===_minV);
          if(_vTier.length<ranked.length) ranked=[..._vTier, ...ranked.filter(p=>!_vTier.includes(p))];
        }
      }

      const chosen=ranked[0];
      slot.assignedTo=chosen.name;
      assignedToday.add(chosen.name);
      shiftCounts[chosen.id][slot.shift]=(shiftCounts[chosen.id][slot.shift]||0)+1;
      if(slot.shift==='HALF')  halfCounts[chosen.id]=(halfCounts[chosen.id]||0)+1;
      if(slot.shift==='NIGHT') nightCounts[chosen.id]=(nightCounts[chosen.id]||0)+1;
      if(slot.shift==='OVNT')  ovntCounts[chosen.id]=(ovntCounts[chosen.id]||0)+1;
      if(slot.shift==='DAY')   dayCounts[chosen.id]=(dayCounts[chosen.id]||0)+1;
      totalHours[chosen.id]+=getSlotMeta(slot).hours;
      if(slot.shift==='OVNT'){ if(!ovntOnDay[dayNum])ovntOnDay[dayNum]=new Set(); ovntOnDay[dayNum].add(chosen.name); }
      // [FEATURE N] record the (posKey, slotIdx) this winner now occupies
      (slotIndexUsed[chosen.name] ||= {});
      (slotIndexUsed[chosen.name][slot.posKey] ||= new Set()).add(slot.slotIdx);
      // [CYCLIC COVERAGE] increment within-month seat bucket ของผู้ถูกเลือก
      if(_cycOn){
        const _cyck=slot.posKey+'#'+slot.slotIdx;
        (_cycLive[chosen.name] ||= {}); _cycLive[chosen.name][_cyck]=(_cycLive[chosen.name][_cyck]||0)+1;
      }
      // [REPEAT WARNING] increment live distribution counters (only when feature on)
      if(_rw>0){
        const _ck=slot.posKey+'#'+slot.slotIdx, _U=slot.unit||'?';
        (repCol[chosen.name] ||= {}); repCol[chosen.name][_ck]=(repCol[chosen.name][_ck]||0)+1;
        (repUnit[chosen.name] ||= {}); repUnit[chosen.name][_U]=(repUnit[chosen.name][_U]||0)+1;
        _repColTot[_ck]=(_repColTot[_ck]||0)+1;
        _repUnitTot[_U]=(_repUnitTot[_U]||0)+1;
      }
    }
  }

  // ── EVE Guarantee Post-Pass ──
  // Anyone eligible for EVE who got 0 EVE shifts: try to swap one EVE slot
  // from the person with the most EVE shifts (>1), preserving HC constraints.
  const eveEligible=active.filter(p=>isEligibleForShift(p,'EVE') && !_otExempt(p));
  // [EXPERIMENTAL] คน OT-exempt ที่ EVE=0 จะไม่ถูกบังคับ swap — ถือเป็น "missed by design" เดือนนี้
  const missedEveThisMonth=new Set();
  eveEligible.forEach(noEveP=>{
    if((shiftCounts[noEveP.id]?.EVE||0)>0) return; // already has EVE
    missedEveThisMonth.add(noEveP.name);
    // Collect all EVE slots across all days (unlocked, assigned to someone with 2+ EVE)
    const swapCandidates=[];
    Object.entries(sched.days).forEach(([dStr,day])=>{
      const d=Number(dStr);
      day.slots.forEach(sl=>{
        if(sl.shift!=='EVE'||sl.locked||!sl.assignedTo) return;
        const donor=active.find(x=>x.name===sl.assignedTo);
        if(!donor||(shiftCounts[donor.id]?.EVE||0)<2) return;
        // HC-2: noEveP must not already be assigned this day
        const alreadyThisDay=sched.days[d].slots.some(s=>s.assignedTo===noEveP.name);
        if(alreadyThisDay) return;
        // HC-1: noEveP must not have done OVNT the night before (EVE starts 16:30)
        if(didOvntYesterday(noEveP.name,d,ovntOnDay,prevLastOvnt)) return;
        // [BUDDY v4_2_0] ห้าม swap ไปวันที่เพื่อนร่วมกลุ่ม buddy ของ noEveP ขึ้นเวรอยู่
        // (กัน EVE post-pass สร้าง buddy-clash) — EVE guarantee ยัง soft: ถ้าทุก slot ติด → stays missed
        if(buddyMateNamesOf(noEveP).some(bn=>sched.days[d].slots.some(s=>s.assignedTo===bn))) return;
        // ── [NEWBIE GUARD] ห้าม swap ทำให้กลุ่ม posKey วันนั้นเหลือ Newbie ล้วน ──
        // เกิดได้เมื่อ noEveP เป็น Newbie และ donor เป็น Senior คนเดียวที่เหลือในกลุ่ม (multi-slot)
        if(isNewbie(noEveP) && isSenior(donor)){
          const _g=day.slots.filter(s=>s.posKey===sl.posKey);
          if(_g.length>1){
            const _others=_g.filter(s=>s!==sl && s.assignedTo).map(s=>active.find(x=>x.name===s.assignedTo));
            if(!_others.some(p=>p&&isSenior(p))) return; // donor คือ senior คนเดียว → ห้าม swap ออก
          }
        }
        swapCandidates.push({slot:sl, donor, day:d});
      });
    });
    if(!swapCandidates.length) return; // truly impossible this month — stays in missed set
    missedEveThisMonth.delete(noEveP.name); // will be fulfilled
    // Pick randomly among valid swap candidates
    const pick=swapCandidates[Math.floor(_rng()*swapCandidates.length)];
    pick.slot.assignedTo=noEveP.name;
    const eveHrs=SHIFT_META.EVE?.hours||4;
    shiftCounts[noEveP.id].EVE=(shiftCounts[noEveP.id].EVE||0)+1;
    shiftCounts[pick.donor.id].EVE=Math.max(0,(shiftCounts[pick.donor.id].EVE||1)-1);
    totalHours[noEveP.id]+=eveHrs;
    // BUG FIX: clamp donor hours to 0 (virtual pre-load can make this negative otherwise)
    totalHours[pick.donor.id]=Math.max(0,totalHours[pick.donor.id]-eveHrs);
  });

  // ── [MIN-1 SLOT GUARANTEE] Hard floor: ทุกคน schedulable ต้องมีเวร ≥4 ชม. (≥1 slot จริง เพื่อเบิกเงิน) ──
  // runs LAST (หลัง EVE guarantee) — OVERRIDE OT-exemption: คน OT สูงที่ถูกกันจนได้ 0 เวร ก็ต้องได้ ≥1
  // ให้เวร ≥4h (EVE 4h ก่อน = กระทบชั่วโมงน้อยสุด · ไม่ใช้ HALF 3.5h) ผ่าน swap จาก donor ที่มี ≥2 slot
  // guard ครบ: HC-1/HC-2/buddy/newbie · coverage ไม่เสีย (donor เหลือ ≥1 เสมอ)
  // flag: S.settings.minOneSlotGuarantee (default true · false = ปิด กลับพฤติกรรมเดิม)
  const _min1On = S.settings.minOneSlotGuarantee !== false;
  const _missedMin1 = new Set();
  if(_min1On){
    // [SLOT-BASED v4_2_6] การันตี "1 เวรเต็มผลัด" ต่อคน = shift ∈ {DAY,NIGHT,OVNT} — ไม่นับ 2×EVE
    // เลือก target แบบสุ่มทุกผลัด (วนได้ทุกที่ หากไม่มีข้อห้าม)
    const _QUAL = (Array.isArray(S.settings.minSlotShifts) && S.settings.minSlotShifts.length) ? S.settings.minSlotShifts : ['DAY','NIGHT','OVNT'];
    const _isQual = sl => _QUAL.includes(sl.shift);
    const _slotsOf=(nm)=>{ const r=[]; Object.entries(sched.days).forEach(([dStr,day])=>day.slots.forEach(s=>{ if(s.assignedTo===nm) r.push({slot:s, day:Number(dStr)}); })); return r; };
    const _bigCntOf=(nm)=> _slotsOf(nm).filter(o=>_isQual(o.slot)).length;
    const _hasBig =(nm)=> _bigCntOf(nm) >= 1;
    const _hasOnDay=(nm,d)=> sched.days[d] && sched.days[d].slots.some(s=>s.assignedTo===nm);
    let _pass=0;
    while(_pass++ < 4){                                          // stabilize: swap อาจกระทบ donor → วนจนนิ่ง
      const _need = active.filter(p=>!_hasBig(p.name));
      if(!_need.length) break;
      let _changed=false;
      _need.forEach(zp=>{
        // 1) target = เวรเต็มผลัด (DAY/NIGHT/OVNT) ของ donor ที่มี qual ≥2 (ยกแล้วยังเหลือ ≥1) + guard ฝั่ง zp
        const targets=[];
        Object.entries(sched.days).forEach(([dStr,day])=>{
          const d=Number(dStr);
          day.slots.forEach(sl=>{
            if(sl.locked||!sl.assignedTo) return;
            if(sl.assignedTo===zp.name) return;
            if(!_isQual(sl)) return;                               // เอาเฉพาะเวรเต็มผลัด
            if(_bigCntOf(sl.assignedTo) < 2) return;               // donor ต้องเหลือ ≥1 (กัน whack-a-mole)
            if(!isEligibleForShift(zp, sl.shift)) return;
            if(_hasOnDay(zp.name, d)) return;                      // HC-2 (zp)
            if(sl.shift!=='OVNT' && didOvntYesterday(zp.name,d,ovntOnDay,prevLastOvnt)) return; // HC-1 (zp)
            if(buddyMateNamesOf(zp).some(bn=>day.slots.some(s=>s.assignedTo===bn))) return;     // buddy (zp)
            const donor=active.find(x=>x.name===sl.assignedTo);
            if(donor && isNewbie(zp) && isSenior(donor)){         // newbie guard (mirror EVE)
              const _g=day.slots.filter(s=>s.posKey===sl.posKey);
              if(_g.length>1){ const _o=_g.filter(s=>s!==sl&&s.assignedTo).map(s=>active.find(x=>x.name===s.assignedTo)); if(!_o.some(p=>p&&isSenior(p))) return; }
            }
            targets.push({slot:sl, donor, day:d});
          });
        });
        if(!targets.length) return;                               // เติมไม่ได้รอบนี้
        // สุ่มลำดับ target (Fisher-Yates ด้วย _rng) → วนได้ทุกผลัด ไม่ fix DAY ก่อน
        const _ord=targets.map((_,i)=>i);
        for(let i=_ord.length-1;i>0;i--){ const j=Math.floor(_rng()*(i+1)); [_ord[i],_ord[j]]=[_ord[j],_ord[i]]; }
        // 2) เลือก target แรก (สุ่ม) ที่ทำ mutual swap ได้: zp ยกเวรครึ่งผลัด (EVE/HALF) ให้ donor → คุมชั่วโมง
        const _zpSmall=_slotsOf(zp.name).filter(o=>!_isQual(o.slot));
        let pick=null, give=null;
        for(const idx of _ord){
          const t=targets[idx];
          const g=_zpSmall.find(o=>{
            if(o.day===t.day) return false;                       // คนละวัน
            if(!isEligibleForShift(t.donor, o.slot.shift)) return false;
            if(_hasOnDay(t.donor.name, o.day)) return false;      // HC-2 (donor)
            if(o.slot.shift!=='OVNT' && didOvntYesterday(t.donor.name,o.day,ovntOnDay,prevLastOvnt)) return false; // HC-1 (donor)
            if(buddyMateNamesOf(t.donor).some(bn=>sched.days[o.day].slots.some(s=>s.assignedTo===bn))) return false; // buddy (donor)
            return true;
          });
          if(g){ pick=t; give=g; break; }
        }
        if(!pick) pick=targets[_ord[0]];                          // ไม่มี mutual → pure transfer (donor qual≥2 อยู่แล้ว)
        // apply: zp รับ target
        const sh=pick.slot.shift, hrs=getSlotMeta(pick.slot).hours;
        pick.slot.assignedTo=zp.name;
        shiftCounts[zp.id][sh]=(shiftCounts[zp.id][sh]||0)+1;
        shiftCounts[pick.donor.id][sh]=Math.max(0,(shiftCounts[pick.donor.id][sh]||1)-1);
        totalHours[zp.id]+=hrs; totalHours[pick.donor.id]=Math.max(0,totalHours[pick.donor.id]-hrs);
        if(sh==='OVNT'){ if(!ovntOnDay[pick.day])ovntOnDay[pick.day]=new Set(); ovntOnDay[pick.day].delete(pick.donor.name); ovntOnDay[pick.day].add(zp.name); }
        // mutual: donor รับเวรครึ่งผลัดของ zp กลับ
        if(give){
          const gs=give.slot.shift, gh=getSlotMeta(give.slot).hours;
          give.slot.assignedTo=pick.donor.name;
          shiftCounts[pick.donor.id][gs]=(shiftCounts[pick.donor.id][gs]||0)+1;
          shiftCounts[zp.id][gs]=Math.max(0,(shiftCounts[zp.id][gs]||1)-1);
          totalHours[pick.donor.id]+=gh; totalHours[zp.id]=Math.max(0,totalHours[zp.id]-gh);
          if(gs==='OVNT'){ if(!ovntOnDay[give.day])ovntOnDay[give.day]=new Set(); ovntOnDay[give.day].delete(zp.name); ovntOnDay[give.day].add(pick.donor.name); }
        }
        _changed=true;
      });
      if(!_changed) break;
    }
    active.forEach(p=>{ if(!_hasBig(p.name)) _missedMin1.add(p.name); });
  }

  // Build stats (by id for internal use, by name for archive)
  const stats={};
  S.pharmacists.forEach(p=>{
    stats[p.id]={...shiftCounts[p.id],hours:Math.round((totalHours[p.id]||0)*10)/10};
  });
  sched.stats=stats;
  sched.generated=new Date().toISOString();
  sched.violations=validateSchedule(sched, prevLastOvnt);

  S.schedule=sched;
  autoSave(); renderGenerateTab(); updateNavBadges();
  const vLen=sched.violations.length;
  if(vLen) showToast(`สร้างตารางเสร็จ — พบ ${vLen} ข้อขัดแย้ง`,'warn');
  else showToast('สร้างตารางเวรสำเร็จ ✓','ok');
}

async function clearSchedule(){
  if(!await confirmModal('ล้างตารางเวรปัจจุบัน?',{danger:true})) return;
  S.schedule=null;
  autoSave(); renderGenerateTab(); updateNavBadges();
  showToast('ล้างตารางแล้ว','ok');
}

function archiveSchedule(){
  if(!S.schedule) return;
  const mk=monthKey(S.schedule.month,S.schedule.year);
  const byName={};
  S.pharmacists.forEach(p=>{
    const d=S.schedule.stats?.[p.id];
    if(d) byName[p.name]={...d};
  });
  // lastOvnt: find who did OVNT on the last day
  const lastDay=Math.max(...Object.keys(S.schedule.days).map(Number));
  const lastDaySlots=(S.schedule.days[lastDay]||{}).slots||[];
  const ovntSlot=lastDaySlots.find(s=>s.shift==='OVNT'&&s.assignedTo);
  // Collect who has 0 EVE this month among eligible (for carryover next month)
  const eveEligibleNames=new Set(
    S.pharmacists.filter(p=>isSchedulable(p)&&isEligibleForShift(p,'EVE')).map(p=>p.name)
  );
  const missedEveArchive=Object.entries(byName)
    .filter(([name,d])=>name!=='_meta'&&eveEligibleNames.has(name)&&!(d.EVE||0))
    .map(([name])=>name);
  // NOTE: _meta is stamped in Step 3 below (after leftoverMap is built) — not here.

  // [CUMULATIVE ENGINE] Pre-save comp values before Step 1 deducts them (needed for grandTotal)
  const _archOrigComp = {};
  S.pharmacists.forEach(p => {
    const oc={}; getCompRoles().forEach(r=>{ oc[r.id]=+(p.comp[r.id]||0); });
    _archOrigComp[p.name] = oc;   // per-role map (includes legacy warehouse/tdm role ids)
  });

  // ── [ROLLOVER LEDGER] Step 1: Auto-deduct comp hours consumed this month (per role rate) ──
  const leftoverMap = {};  // pharmName → { [roleId]: hoursLeft, ..., total }
  S.pharmacists.forEach(p=>{
    const left={}; let total=0;
    getCompRoles().forEach(r=>{
      const rate=r.hoursPerCredit||0;
      let h=+(p.comp[r.id]||0);
      if(rate>0){ const credits=Math.floor(h/rate); if(credits>0) h=Math.max(0,h-credits*rate); }
      h=+h.toFixed(2);
      p.comp[r.id]=h;
      left[r.id]=h; total+=h;
    });
    left.total=+total.toFixed(2);
    leftoverMap[p.name]=left;
    // ── [ROLLOVER LEDGER] Step 2: Embed leftover per-person into byName row ──
    if(byName[p.name]) byName[p.name].leftoverRemainingHours = left.total;
  });

  // ── [CUMULATIVE ENGINE] Compute slot hours + grandTotal per person ──
  const _archSlotHrs = {};
  const _archByPosKey = {};                                   // [FEATURE-2] name -> { posKey: count }
  const _archByColSlot = {};                                  // [SLOTIDX X-MONTH] name -> { 'posKey#slotIdx': count }
  S.pharmacists.forEach(p => { _archSlotHrs[p.name] = 0; _archByPosKey[p.name] = {}; _archByColSlot[p.name] = {}; });
  Object.values(S.schedule.days).forEach(day => {
    (day.slots||[]).forEach(sl => {
      if(sl.assignedTo && Object.prototype.hasOwnProperty.call(_archSlotHrs, sl.assignedTo)){
        _archSlotHrs[sl.assignedTo] = +(_archSlotHrs[sl.assignedTo] + getSlotMeta(sl).hours).toFixed(2);
        if(sl.posKey){ const _b = _archByPosKey[sl.assignedTo]; _b[sl.posKey] = (_b[sl.posKey]||0) + 1;
          const _ck = sl.posKey+'#'+sl.slotIdx, _c = _archByColSlot[sl.assignedTo]; _c[_ck] = (_c[_ck]||0) + 1; }
      }
    });
  });
  // Stamp grandTotal + original OT into each byName row
  // (archivedComp per-role used by copyPrevMonthOT; archivedWarehouse/Tdm kept for back-compat)
  Object.keys(byName).filter(k => k !== '_meta').forEach(name => {
    const oc = _archOrigComp[name] || {};
    const ocTotal = Object.values(oc).reduce((a,b)=>a+(+b||0),0);
    byName[name].grandTotal        = +( (_archSlotHrs[name]||0) + ocTotal ).toFixed(2);
    byName[name].archivedComp      = oc;                       // { roleId: hours } — generic
    byName[name].archivedWarehouse = oc.warehouse || 0;        // legacy back-compat
    byName[name].archivedTdm       = oc.tdm || 0;              // legacy back-compat
    byName[name]._byPosKey         = _archByPosKey[name] || {};   // [FEATURE-2] column saturation source
    byName[name]._byColSlot        = _archByColSlot[name] || {};  // [SLOTIDX X-MONTH] exact-slot rotation source
  });

  // ── [ROLLOVER LEDGER] Step 3 + Cumulative Engine: Stamp _meta for bulk lookup ──
  // Derive previous month key relative to the month being archived (mk)
  const [_cmY, _cmM] = mk.split('-').map(Number);
  let _cmPM = _cmM - 1, _cmPY = _cmY; if(_cmPM <= 0){ _cmPM = 12; _cmPY--; }
  const _prevMeta2   = S.scheduleHistory[monthKey(_cmPM, _cmPY)]?._meta || {};
  const _prevCum     = _prevMeta2._cumulativeHrs || {};
  // [REPAIR] carry forward EVERYONE's prior cumulative (รวมคนที่ พัก/ไม่ schedulable เดือนนี้)
  // กันยอดสะสมหลุดเมื่อตั้งคนเป็นพักชั่วคราวแล้วกลับมาใหม่ — เดิมวนเฉพาะ isSchedulable จึง drop key
  const _newCum      = Object.assign({}, _prevCum);
  Object.keys(byName).filter(k => k !== '_meta').forEach(name => {
    _newCum[name]    = +( (_prevCum[name]||0) + (byName[name].grandTotal||0) ).toFixed(2);
  });
  byName._meta={
    lastOvnt: ovntSlot?.assignedTo||null,
    missedEve: missedEveArchive,
    leftoverByName: leftoverMap,          // pharmName → { warehouse, tdm, total }
    _cumulativeHrs: _newCum,              // running total per person since _cumulativeFrom
    _cumulativeFrom: _prevMeta2._cumulativeFrom || mk   // first month of accumulation
  };

  S.scheduleHistory[mk]=byName;
  // Keep rolling 12 months — re-read keys AFTER insert
  let keys=Object.keys(S.scheduleHistory).sort();
  while(keys.length>12){ delete S.scheduleHistory[keys.shift()]; keys=Object.keys(S.scheduleHistory).sort(); }

  // ── [ROLLOVER LEDGER] Step 4: FLUSH comp inputs — reset to 0 after archive ──
  // The remainder was already saved into scheduleHistory above.
  // Clear p.comp so next month's inputs start blank (user types only NEW hours).
  S.pharmacists.forEach(p=>{
    getCompRoles().forEach(r=>{ p.comp[r.id]=0; });
  });

  autoSave(); updateNavBadges(); renderStaffList();
  _scheduleDbSync();        // [BACKUP] auto-sync this month to the connected file
  checkBackupStatus();
  showToast(`Archive ${THAI_MONTHS[S.schedule.month]} ${S.schedule.year} สำเร็จ — หักชม.ชดเชย + ยกเศษไปเดือนหน้าแล้ว`,'ok');
}

/* ── [LONGEVITY] Rebase cumulative fairness baseline ──
   Declares a FRESH fairness epoch: zeroes every person's running cumulative as of
   the latest archived month and moves _cumulativeFrom forward. This INTENTIONALLY
   forgives all past imbalance — from the next month Feature M sees every person at
   the same baseline (deficit 0), so it re-balances from equal footing. Use only at
   a deliberate boundary (fiscal year, major roster change). It does NOT touch any
   schedule already archived; only future months start from the reset baseline.
   Wire to a Settings button, e.g.:
     <button onclick="confirmModal('รีเซ็ตฐานความเป็นธรรมสะสม? ...',{danger:true}).then(ok=>{if(ok)rebaseCumulative()})">Rebase ฐานสะสม</button> */
function rebaseCumulative(){
  const keys=Object.keys(S.scheduleHistory||{}).sort();
  if(!keys.length){ showToast('ยังไม่มีประวัติให้ rebase','warn'); return; }
  const latest=keys[keys.length-1];
  const meta=S.scheduleHistory[latest]?._meta;
  if(!meta||!meta._cumulativeHrs){ showToast('ไม่พบ _cumulativeHrs','warn'); return; }
  const zeroed={}; Object.keys(meta._cumulativeHrs).forEach(n=>zeroed[n]=0);
  meta._cumulativeHrs=zeroed;
  meta._cumulativeFrom=latest;
  autoSave();
  if(typeof appendActivityLog==='function') appendActivityLog('REBASE_CUMULATIVE', `baseline reset @ ${latest}`);
  showToast('Rebase ฐานสะสมสำเร็จ — เริ่มรอบความเป็นธรรมใหม่','ok');
}

/* ── [REPAIR] Rebuild cumulative hours from stored monthly grandTotal ──
   คำนวณ _cumulativeHrs ของ _meta เดือนล่าสุดใหม่ โดยรวม grandTotal ที่เก็บไว้รายเดือน
   ของทุกคน (ไม่กรอง isSchedulable) ตั้งแต่ _cumulativeFrom เป็นต้นมา — แก้กรณียอดสะสม
   เป็น 0 เพราะคนนั้นถูกตั้งเป็น พัก/inactive ตอน archive (cumulative engine ข้ามไป
   และตัดสาย carry-forward). เป็นการซ่อม display เท่านั้น ไม่แตะเวรที่ archive แล้ว,
   HC engine หรือ Virtual Hours pre-loading. */
function rebuildCumulativeHrs(){
  const keys = Object.keys(S.scheduleHistory||{}).sort();
  if(!keys.length){ showToast('ยังไม่มีประวัติให้คำนวณ','warn'); return; }
  const latest = keys[keys.length-1];
  const meta   = S.scheduleHistory[latest] && S.scheduleHistory[latest]._meta;
  if(!meta){ showToast('ไม่พบ _meta เดือนล่าสุด','warn'); return; }
  const from   = meta._cumulativeFrom || keys[0];        // เคารพขอบเขต rebase (ถ้าเคยรีเซ็ต)
  const rebuilt = {};
  keys.filter(mk => mk >= from).forEach(mk => {          // monthKey zero-padded → เทียบ string ได้
    const month = S.scheduleHistory[mk] || {};
    Object.keys(month).forEach(name => {
      if(name === '_meta') return;
      const gt = month[name] && month[name].grandTotal;
      if(gt === undefined || gt === null) return;
      rebuilt[name] = +((rebuilt[name]||0) + gt).toFixed(2);
    });
  });
  meta._cumulativeHrs = rebuilt;
  autoSave();
  if(typeof appendActivityLog==='function') appendActivityLog('REBUILD_CUMULATIVE', `rebuilt @ ${latest} from ${from} (${Object.keys(rebuilt).length} คน)`);
  if(typeof renderHistoryMatrix==='function'){ try{ renderHistoryMatrix(); }catch(e){} }
  if(typeof renderStatsTab==='function'){ try{ renderStatsTab(); }catch(e){} }
  showToast('คำนวณชั่วโมงสะสมใหม่จากประวัติสำเร็จ','ok');
}

/* ══ SCHEDULE TABLE RENDER (SMC v5_6 style) ══ */
const _SHIFT_PILL_CLS = { EVE:'s-eve', NIGHT:'s-night', OVNT:'s-ovnt', DAY:'s-full', HALF:'s-full' };
const _SHIFT_HDR_CLS  = { EVE:'h-eve', NIGHT:'h-night', OVNT:'h-ovnt', DAY:'h-full', HALF:'h-full' };
const _DOW_SHORT = ['อา','จ','อ','พ','พฤ','ศ','ส'];

function _buildSchedCols(){
  if(!S.schedule) return {posKeyOrder:[],posKeyInfo:{},cols:[]};
  const m=S.schedule.month,y=S.schedule.year,cY=y-543;
  const totalDays=new Date(cY,m,0).getDate();
  const posKeyInfo={};
  for(let d=1;d<=totalDays;d++){
    const day=S.schedule.days[d];
    if(!day) continue;
    (day.slots||[]).forEach(sl=>{
      if(!posKeyInfo[sl.posKey]) posKeyInfo[sl.posKey]={label:sl.label,shift:sl.shift,unit:sl.unit,maxIdx:sl.slotIdx};
      else posKeyInfo[sl.posKey].maxIdx=Math.max(posKeyInfo[sl.posKey].maxIdx,sl.slotIdx);
    });
  }
  // Sort columns by explicit posKey order matching Google Sheet layout:
  // kl_day → kl_half → sw_day → kl_eve → sw_eve → sw_night → sw_ovnt
  const _POS_KEY_PRI={kl_day:0,kl_half:1,sw_day:2,kl_eve:3,sw_eve:4,sw_night:5,sw_ovnt:6};
  const UNIT_PRI={KL:0,SW:1};
  const posKeyOrder=Object.keys(posKeyInfo).sort((a,b)=>{
    const pa=_POS_KEY_PRI[a]??9, pb=_POS_KEY_PRI[b]??9;
    if(pa!==pb) return pa-pb;
    const ua=UNIT_PRI[posKeyInfo[a].unit]??9, ub=UNIT_PRI[posKeyInfo[b].unit]??9;
    return ua-ub;
  });
  const cols=[];
  posKeyOrder.forEach(pk=>{
    const info=posKeyInfo[pk];
    for(let i=0;i<=info.maxIdx;i++) cols.push({posKey:pk,slotIdx:i,id:`${pk}_${i}`,label:info.label,shift:info.shift,unit:info.unit});
  });
  return {posKeyOrder,posKeyInfo,cols};
}
