function removeSlot(dayNum,slotId){
  const slot=S.schedule?.days?.[dayNum]?.slots?.find(s=>s.id===slotId);
  if(!slot||!slot.assignedTo) return;
  const p=S.pharmacists.find(x=>x.name===slot.assignedTo);
  if(p&&S.schedule.stats?.[p.id]){
    const sc=S.schedule.stats[p.id];
    const kl_day = sc.kl || 0;
      const sw_day = sc.sw || 0;
    sc[slot.shift]=Math.max(0,(sc[slot.shift]||0)-1);
    sc.hours=Math.max(0,Math.round(((sc.hours||0)-getSlotMeta(slot).hours)*10)/10);
  }
  slot.assignedTo=null; slot.locked=false;
  autoSave(); renderScheduleTable(); renderStatsTab();
  showToast('ลบการจัดเวรแล้ว','ok');
}

/* ── [REBALANCE] on-demand re-optimize that PRESERVES locked slots ──
   Reuses runScheduler() unchanged: buildScheduleSkeleton keeps locked slots'
   assignedTo and clears only unlocked ones, so locks always survive. This wrapper
   only adds a guard + a preservation report; manual edits that are NOT locked WILL
   be reassigned (that is the point of rebalancing), so warn the supervisor first. */
async function rebalanceSchedule(){
  if(!S.schedule){ showToast('ยังไม่มีตาราง — กด ⚡ สร้างตาราง ก่อน','warn'); return; }
  let locked=0, unlocked=0;
  Object.values(S.schedule.days).forEach(d=>(d.slots||[]).forEach(s=>{
    if(s.locked && s.assignedTo) locked++; else unlocked++;
  }));
  const ok = await confirmModal(
    `จัดสมดุลตารางใหม่ด้วยการตั้งค่าปัจจุบัน:\n\n`+
    `• คงเวรที่ล็อก 🔒 ไว้ ${locked} ช่อง (ไม่เปลี่ยน)\n`+
    `• จัดช่องที่ไม่ได้ล็อก ${unlocked} ช่อง ใหม่ทั้งหมด\n\n`+
    `เวรที่แก้ด้วยมือแต่ยังไม่ได้ล็อกจะถูกจัดใหม่ — ดำเนินการต่อหรือไม่?`,
    { title:'⚖ จัดสมดุลใหม่' });
  if(!ok) return;
  runScheduler();   // proven path: preserves locks, applies repeatWeight + all fairness logic
  showToast(`จัดสมดุลใหม่แล้ว — คงเวรที่ล็อก ${locked} ช่อง`, 'ok');
}

