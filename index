function addCompRole(){
  const name=(document.getElementById('new-role-name').value||'').trim();
  const rate=Math.max(1, parseFloat(document.getElementById('new-role-rate').value)||8);
  const needsComp=document.getElementById('new-role-comp').checked;
  if(!name){ showToast('กรุณาใส่ชื่องาน','warn'); return; }
  if(!Array.isArray(S.compRoles)) S.compRoles=[];
  let base='role_'+(name.toLowerCase().replace(/[^a-z0-9ก-๙]+/gi,'_').replace(/^_+|_+$/g,'').slice(0,20));
  if(base==='role_') base='role_'+Date.now().toString(36);
  let id=base, n=1; while(S.compRoles.some(r=>r.id===id)){ id=base+'_'+(n++); }
  S.compRoles.push({id,name,needsComp,hoursPerCredit:rate});
  document.getElementById('new-role-name').value='';
  appendActivityLog('COMP_ROLE_ADD', `${name} · /${rate}ชม.=1เวร · ${needsComp?'ชดเชย':'ไม่ชดเชย'}`);
  autoSave(); renderCompRolesModal(); renderStaffList();
  showToast('เพิ่มงาน '+name+' ✓','ok');
}
function updateCompRole(id,field,val){
  const r=getCompRoles().find(x=>x.id===id); if(!r) return;
  if(field==='name'){ const v=(val||'').trim(); if(v) r.name=v; }
  else if(field==='hoursPerCredit'){ r.hoursPerCredit=Math.max(1,parseFloat(val)||r.hoursPerCredit); }
  else if(field==='needsComp'){ r.needsComp=!!val; }
  autoSave(); renderStaffList();
}
let _delRolePendingId=null;
async function deleteCompRole(id){
  const r=getCompRoles().find(x=>x.id===id); if(!r) return;
  const people=S.pharmacists.filter(p=>(+(p.comp&&p.comp[id]||0))>0);
  const pendingTotal=people.reduce((s,p)=>s+(+(p.comp[id]||0)),0);
  const others=getCompRoles().filter(x=>x.id!==id);
  // ไม่มีชั่วโมงค้าง → ลบได้เลย (ประวัติเดิมยังคงอยู่ ไม่ถูกลบ)
  if(pendingTotal<=0){
    const ok=await confirmModal(`ลบงาน "${r.name}"?\n\n(ประวัติเดิมของงานนี้จะยังคงอยู่ ไม่ถูกลบ)`,{danger:true,title:'🗑 ลบงาน OT'});
    if(!ok) return;
    S.compRoles=others;
    S.pharmacists.forEach(p=>{ if(p.comp && (id in p.comp)) delete p.comp[id]; });
    appendActivityLog('COMP_ROLE_DEL', r.name);
    autoSave(); renderCompRolesModal(); renderStaffList(); renderFingerprintBadge();
    showToast('ลบงาน '+r.name,'ok'); return;
  }
  // มีชั่วโมงค้าง → ถามว่าจะทดไปงานใด
  _delRolePendingId=id;
  const info=document.getElementById('del-role-info');
  if(info) info.innerHTML=`งาน <strong>${r.name}</strong> มีชั่วโมงค้างรวม <strong>${pendingTotal.toFixed(1)} ชม.</strong> (${people.length} คน)<br>เลือกงานที่จะ “ทด” ชั่วโมงเหล่านี้ไปแทน — ประวัติเดิมของงานนี้จะยังคงอยู่:`;
  const sel=document.getElementById('del-role-target');
  if(sel) sel.innerHTML=others.map(x=>`<option value="${x.id}">${x.name} (อัตรา ${x.hoursPerCredit} ชม./เวร)</option>`).join('')
    + `<option value="__discard__">— ทิ้งทั้งหมด (ไม่ทด, ล้างเป็น 0) —</option>`;
  openModal('modal-del-role');
}
function confirmRoleDelete(){
  const id=_delRolePendingId; if(!id){ closeModal('modal-del-role'); return; }
  const r=getCompRoles().find(x=>x.id===id);
  const sel=document.getElementById('del-role-target');
  const target=sel?sel.value:'__discard__';
  const toRole=(target && target!=='__discard__');
  let moved=0, ppl=0;
  S.pharmacists.forEach(p=>{
    if(!p.comp || !(id in p.comp)) return;
    const h=+(p.comp[id]||0);
    if(h>0 && toRole){ p.comp[target]=(+(p.comp[target]||0))+h; moved+=h; ppl++; }
    delete p.comp[id];                         // ลบเฉพาะชั่วโมงค้างปัจจุบัน — ไม่แตะ scheduleHistory
  });
  S.compRoles=getCompRoles().filter(x=>x.id!==id);
  const tName=toRole?(getCompRoles().find(x=>x.id===target)?.name||''):null;
  appendActivityLog('COMP_ROLE_DEL', `${r?r.name:id}${tName?` · ทด ${moved.toFixed(1)} ชม. (${ppl} คน) → ${tName}`:' · ล้างชั่วโมงค้าง'}`);
  _delRolePendingId=null;
  autoSave(); closeModal('modal-del-role'); renderCompRolesModal(); renderStaffList(); renderFingerprintBadge();
  showToast(tName?`ลบ ${r?r.name:''} · ทด ${moved.toFixed(1)} ชม. → ${tName}`:`ลบ ${r?r.name:''} · ล้างชั่วโมงค้าง`,'ok');
}

/* ── Copy OT from previous archived month into p.comp ── */
function copyPrevMonthOT(){
  const prevMk    = getPrevMonthKey();
  const prevEntry = S.scheduleHistory[prevMk];
  const [py, pm]  = prevMk.split('-').map(Number);
  const prevLabel = THAI_MONTHS_SHORT[pm] + ' ' + py;

  if(!prevEntry){
    showToast('ไม่พบข้อมูล Archive เดือน ' + prevLabel, 'warn');
    return;
  }
  let copied = 0;
  S.pharmacists.filter(p => !p.flags.inactive).forEach(p => {
    const d  = prevEntry[p.name];
    if(!d) return;
    // generic: restore every role from archivedComp; fall back to legacy warehouse/tdm fields
    const src = d.archivedComp || { warehouse:d.archivedWarehouse||0, tdm:d.archivedTdm||0 };
    let any=0;
    getCompRoles().forEach(r=>{ const h=+(src[r.id]||0); if(h>0){ p.comp[r.id]=h; any+=h; } });
    if(any>0) copied++;
  });

  appendActivityLog('COPY_OT',
    `คัดลอก OT จาก ${prevLabel} → ${copied} คน`);
  autoSave(); renderStaffList();

  if(copied > 0)
    showToast('คัดลอก OT จาก ' + prevLabel + ' — ' + copied + ' คน ✓', 'ok');
  else
    showToast('เดือน ' + prevLabel + ' ไม่มีข้อมูล OT (ใช้ Archive ใหม่ได้เลย)', 'warn');
}

