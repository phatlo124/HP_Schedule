    `<span class="badge badge-red" style="cursor:pointer" onclick="toggleHolidayMark(${d})" title="คลิกเพื่อลบ">${d} ${THAI_MONTHS_SHORT[m]}</span>`
  ).join('');

  const TYPE_LABELS={weekday:'ธรรมดา',preHoliday:'Extra',holiday:'หยุด'};
  const DOW=['จ','อ','พ','พฤ','ศ','ส','อา'];

  let cells='';
  DOW.forEach(d=>{ cells+=`<div class="cal-dow">${d}</div>`; });
  for(let i=0;i<firstDow;i++) cells+=`<div class="cal-day empty"></div>`;
