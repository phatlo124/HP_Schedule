<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<meta name="googlebot" content="noindex, nofollow">
<title>HP Pharmacist Scheduler </title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Thai:wght@300;400;600;700&family=IBM+Plex+Mono:wght@400;500&family=Noto+Sans+Thai:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════
   DESIGN TOKENS
═══════════════════════════════════════════════════════ */
:root {
  --navy:#0d1b2a; --navy2:#1b2f45; --navy3:#243c54;
  --gold:#c8a84b; --gold-light:#f0dfa0; --gold-pale:#fdf8ec;
  --teal:#2a7d6e; --teal-light:#e0f5f1;
  --red:#b5302a;  --red-light:#fff0ee;
  --amber:#b36a00; --amber-light:#fff8e6;
  --green:#2d7a3a; --green-light:#eaf4ec;
  --purple:#6b44a8; --purple-light:#f0ebff;
  --blue:#2456a4;  --blue-light:#eef3ff;
  --text:#1a1a1a; --text2:#3d3d3d; --text3:#6b6b6b;
  --border:#ddd8cc; --surface:#f7f6f2; --white:#fff;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:'Noto Sans Thai',sans-serif;background:var(--surface);color:var(--text);font-size:14px;line-height:1.6}
.layout{display:flex;height:100vh;overflow:hidden}

/* SIDEBAR */
.sidebar{width:224px;min-width:224px;background:var(--navy);display:flex;flex-direction:column;overflow-y:auto}
.sb-brand{padding:18px 16px 14px;border-bottom:1px solid rgba(255,255,255,.08)}
.sb-tag{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.18em;color:var(--gold);text-transform:uppercase;margin-bottom:4px}
.sb-title{font-family:'Noto Serif Thai',serif;font-size:1.05rem;font-weight:700;color:#fff;line-height:1.25}
.sb-title span{color:var(--gold)}
.sb-sub{font-size:0.65rem;color:rgba(255,255,255,.28);margin-top:3px}
.sb-section{padding:10px 16px 4px;font-family:'IBM Plex Mono',monospace;font-size:0.58rem;letter-spacing:.14em;color:rgba(255,255,255,.2);text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 16px;cursor:pointer;color:rgba(255,255,255,.48);font-size:0.8rem;font-weight:500;transition:all .14s;border-left:3px solid transparent;user-select:none}
.nav-item:hover{color:#fff;background:rgba(255,255,255,.04)}
.nav-item.active{color:var(--gold-light);background:rgba(200,168,75,.1);border-left-color:var(--gold)}
.nav-num{font-family:'IBM Plex Mono',monospace;font-size:0.63rem;color:var(--gold);opacity:.55;min-width:18px;flex-shrink:0}
.nav-badge{margin-left:auto;font-size:0.6rem;font-family:'IBM Plex Mono',monospace;padding:1px 6px;border-radius:8px;font-weight:700;flex-shrink:0}
.nav-badge.count{background:rgba(200,168,75,.2);color:var(--gold-light)}
.nav-badge.warn{background:var(--red);color:#fff}
.nav-badge.ok{background:var(--teal);color:#fff}
.sb-footer{margin-top:auto;padding:10px 16px;border-top:1px solid rgba(255,255,255,.07);font-family:'IBM Plex Mono',monospace;font-size:0.58rem;color:rgba(255,255,255,.18);line-height:1.8}

/* MAIN */
.main{flex:1;overflow-y:auto;display:flex;flex-direction:column;min-width:0}
.topbar{background:#fff;border-bottom:1px solid var(--border);padding:0 24px;height:50px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;position:sticky;top:0;z-index:50}
.topbar-title{font-family:'Noto Serif Thai',serif;font-size:.95rem;font-weight:700;color:var(--navy)}
.topbar-right{display:flex;align-items:center;gap:10px;font-size:0.72rem;color:var(--text3)}
.pill{background:var(--gold-pale);color:#7a5a00;border:1px solid var(--gold);padding:2px 9px;border-radius:20px;font-weight:600;font-size:0.66rem;font-family:'IBM Plex Mono',monospace;cursor:default}
.pill.teal{background:var(--teal-light);color:var(--teal);border-color:var(--teal)}
.pill.red{background:var(--red-light);color:var(--red);border-color:var(--red)}
.pill.amber{background:var(--amber-light);color:var(--amber);border-color:#e0a840}
.save-badge{font-family:'IBM Plex Mono',monospace;font-size:0.65rem;color:var(--text3);transition:color .3s}
.save-badge.pulse{color:var(--amber);font-weight:700}
.notify-btn{background:none;border:none;cursor:pointer;font-size:1.05rem;position:relative;padding:2px 4px;color:var(--text3)}
.notify-dot{position:absolute;top:-1px;right:-1px;width:8px;height:8px;background:var(--red);border-radius:50%;border:2px solid #fff;display:none}
.notify-dot.visible{display:block}
.content{padding:20px 24px;flex:1}
.tab-panel{display:none}.tab-panel.active{display:block}

/* COMPONENTS */
.page-hdr{margin-bottom:18px}
.page-hdr h2{font-family:'Noto Serif Thai',serif;font-size:1.22rem;font-weight:700;color:var(--navy);margin-bottom:3px}
.page-hdr p{font-size:0.78rem;color:var(--text3)}
.stats-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:16px}
.stat-card{background:#fff;border:1px solid var(--border);border-radius:9px;padding:13px 15px;border-top:3px solid var(--border)}
.stat-card.t-teal{border-top-color:var(--teal)}.stat-card.t-gold{border-top-color:var(--gold)}
.stat-card.t-navy{border-top-color:var(--navy)}.stat-card.t-red{border-top-color:var(--red)}
.stat-card.t-purple{border-top-color:var(--purple)}.stat-card.t-green{border-top-color:var(--green)}
.stat-label{font-size:0.64rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:5px}
.stat-big{font-family:'IBM Plex Mono',monospace;font-size:1.75rem;font-weight:500;color:var(--navy);line-height:1}
.stat-sub{font-size:0.68rem;color:var(--text3);margin-top:4px}
.panel{background:#fff;border:1px solid var(--border);border-radius:9px;overflow:hidden;margin-bottom:14px}
.panel-head{padding:9px 16px;background:var(--navy);display:flex;align-items:center;justify-content:space-between;gap:8px}
.panel-head h3{font-size:0.72rem;font-weight:700;color:var(--gold-light);letter-spacing:.05em;text-transform:uppercase}
.panel-body{padding:16px}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.callout{border-left:3px solid var(--gold);background:var(--gold-pale);border-radius:0 7px 7px 0;padding:11px 15px;font-size:0.78rem;color:#4a3a00;margin:10px 0}
.callout.info{border-left-color:var(--teal);background:var(--teal-light);color:#0d3d35}
.callout.danger{border-left-color:var(--red);background:var(--red-light);color:#5c0808}
.callout.amber{border-left-color:var(--amber);background:var(--amber-light);color:#5a3000}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 13px;border-radius:6px;border:none;font-family:inherit;font-size:0.78rem;font-weight:600;cursor:pointer;transition:all .15s;letter-spacing:.02em;white-space:nowrap}
.btn:disabled{opacity:.45;cursor:not-allowed}
.btn-primary{background:var(--navy);color:var(--gold-light)}.btn-primary:hover:not(:disabled){background:var(--navy2)}
.btn-teal{background:var(--teal);color:#fff}.btn-teal:hover:not(:disabled){background:#22685a}
.btn-gold{background:var(--gold);color:#1a1000}.btn-gold:hover:not(:disabled){background:#b89038}
.btn-red{background:var(--red);color:#fff}.btn-red:hover:not(:disabled){opacity:.85}
.btn-ghost{background:transparent;color:var(--text3);border:1px solid var(--border)}.btn-ghost:hover:not(:disabled){background:var(--surface);color:var(--text)}
.btn-purple{background:var(--purple);color:#fff}.btn-purple:hover:not(:disabled){opacity:.85}
.btn-amber{background:var(--amber);color:#fff}.btn-amber:hover:not(:disabled){opacity:.85}
.btn-sm{padding:4px 9px;font-size:0.7rem}.btn-xs{padding:2px 7px;font-size:0.63rem}
.btn-row{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

/* BADGES */
.badge{display:inline-block;padding:2px 7px;border-radius:10px;font-size:0.63rem;font-weight:700;font-family:'IBM Plex Mono',monospace}
.badge-teal{background:var(--teal-light);color:var(--teal)}.badge-gold{background:var(--gold-pale);color:#7a5a00}
.badge-red{background:var(--red-light);color:var(--red)}.badge-navy{background:#eef0f5;color:var(--navy)}
.badge-green{background:var(--green-light);color:var(--green)}.badge-amber{background:var(--amber-light);color:var(--amber)}
.badge-purple{background:var(--purple-light);color:var(--purple)}

/* INPUTS */
.inp{padding:7px 10px;border:1px solid var(--border);border-radius:6px;font-size:0.8rem;font-family:inherit;background:#fff;color:var(--text);width:100%}
.inp:focus{outline:none;border-color:var(--gold)}
.inp-group{display:flex;flex-direction:column;gap:4px}
.inp-group label{font-size:0.7rem;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.05em}
select.inp{cursor:pointer}

/* ═══════════════════════════════════════════════════════
   STAFF TAB — PHARMACIST CARDS
═══════════════════════════════════════════════════════ */
.staff-toolbar{display:flex;gap:8px;align-items:center;margin-bottom:12px;flex-wrap:wrap}
.staff-search{flex:1;min-width:180px;padding:7px 11px;border:1px solid var(--border);border-radius:6px;font-size:0.8rem;font-family:inherit;background:#fff;color:var(--text)}
.staff-search:focus{outline:none;border-color:var(--gold)}
.filter-chips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;align-items:center}
.chip{padding:4px 11px;border-radius:20px;font-size:0.7rem;font-weight:600;cursor:pointer;border:1px solid var(--border);background:#fff;color:var(--text3);transition:all .12s;user-select:none}
.chip:hover{border-color:var(--gold);color:var(--navy)}
.chip.active{background:var(--navy);color:var(--gold-light);border-color:var(--navy)}
.staff-stats-bar{font-size:0.73rem;color:var(--text3);margin-bottom:12px;font-family:'IBM Plex Mono',monospace}
.staff-stats-bar span{color:var(--text2);font-weight:600}

/* Pharmacist grid */
.pharm-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
@media(max-width:900px){.pharm-grid{grid-template-columns:1fr}}

/* Pharmacist card */
.pharm-card{background:#fff;border:1px solid var(--border);border-radius:9px;overflow:hidden;transition:border-color .12s,box-shadow .12s}
.pharm-card:hover{border-color:#c8c0b0}
.pharm-card.inactive{background:#fafaf8;opacity:.7}
.pharm-card.inactive .pharm-name{text-decoration:line-through;color:var(--text3)}
.pharm-card.expanded{border-color:var(--gold);box-shadow:0 2px 12px rgba(200,168,75,.15)}

/* Card header */
.pharm-header{display:flex;align-items:center;gap:8px;padding:9px 12px;cursor:pointer;user-select:none}
.pharm-header:hover .pharm-name{color:var(--navy)}
.pharm-num{font-family:'IBM Plex Mono',monospace;font-size:0.62rem;color:var(--text3);min-width:22px;flex-shrink:0}
.pharm-name{font-size:0.82rem;font-weight:600;color:var(--text);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pharm-badges{display:flex;gap:4px;flex-shrink:0;align-items:center}
.dept-badge{font-size:0.58rem;padding:1px 6px;border-radius:8px;font-weight:700;font-family:'IBM Plex Mono',monospace;border:1px solid}
.dept-badge.first{background:var(--teal-light);color:var(--teal);border-color:var(--teal)}
.dept-badge.last{background:var(--amber-light);color:var(--amber);border-color:#e0a840}
.unit-badge{font-size:0.55rem;padding:1px 5px;border-radius:6px;font-weight:700;background:#eef0f5;color:var(--navy)}
.expand-arrow{font-size:.7rem;color:var(--text3);transition:transform .2s;flex-shrink:0}
.pharm-card.expanded .expand-arrow{transform:rotate(180deg)}

/* Flag row */
.pharm-flag-row{display:flex;align-items:center;gap:4px;padding:0 12px 8px;flex-wrap:wrap}
.flag-btn{background:none;border:1px solid var(--border);border-radius:6px;cursor:pointer;padding:2px 7px;font-size:0.65rem;font-weight:600;color:var(--text3);transition:all .12s;display:inline-flex;align-items:center;gap:3px}
.flag-btn:hover{border-color:var(--gold);color:var(--navy)}
.flag-btn.active-inactive{background:var(--red-light);border-color:var(--red);color:var(--red)}
.flag-btn.active-age50{background:#fff3cd;border-color:#e0a840;color:var(--amber)}
.flag-btn.active-credit{background:var(--purple-light);border-color:var(--purple);color:var(--purple)}
.flag-btn.active-newbie{background:#e8f5ec;border-color:#3a9d63;color:#2f7d4f}
.del-btn{margin-left:auto;background:none;border:none;cursor:pointer;font-size:0.72rem;color:transparent;padding:2px 5px;transition:color .12s;flex-shrink:0}
.pharm-flag-row:hover .del-btn{color:var(--text3)}
.del-btn:hover{color:var(--red)!important}

/* Expanded detail section */
.pharm-detail{border-top:1px solid var(--border);padding:14px 14px;display:none;background:#fdfcf8}
.pharm-card.expanded .pharm-detail{display:block}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.detail-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px}
.det-label{font-size:0.65rem;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px}
.det-val{font-size:0.8rem;color:var(--text)}
.comp-calc{background:var(--purple-light);border:1px solid #c0a8e8;border-radius:6px;padding:8px 10px;font-size:0.72rem;color:var(--purple);font-family:'IBM Plex Mono',monospace;margin-top:6px}

/* Eligible shifts strip */
.shift-strip{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px}
.shift-tag{font-size:0.62rem;padding:2px 7px;border-radius:8px;font-weight:700;border:1px solid;font-family:'IBM Plex Mono',monospace}
.shift-tag.ok{background:var(--green-light);color:var(--green);border-color:#b0d8b5}
.shift-tag.blocked{background:var(--red-light);color:var(--red);border-color:#e8a09b;text-decoration:line-through;opacity:.6}

/* Empty state */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:280px;gap:10px;opacity:.55}
.empty-icon{font-size:2.5rem}
.empty-title{font-family:'Noto Serif Thai',serif;font-size:1rem;font-weight:700;color:var(--navy)}
.empty-sub{font-size:0.78rem;color:var(--text3);text-align:center}

/* Placeholder tabs */
.placeholder-panel{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:340px;gap:10px;opacity:.55}
.placeholder-icon{font-size:2.5rem}
.placeholder-title{font-family:'Noto Serif Thai',serif;font-size:1rem;font-weight:700;color:var(--navy)}
.placeholder-sub{font-size:0.78rem;color:var(--text3)}

/* Dashboard extras */
.workflow{display:flex;gap:0;overflow:hidden;border-radius:8px;border:1px solid var(--border);margin-top:4px}
.wf-step{flex:1;padding:12px 10px;text-align:center;cursor:pointer;transition:background .12s;border-right:1px solid var(--border)}
.wf-step:last-child{border-right:none}
.wf-step:hover{background:var(--surface)}
.wf-step.done{background:var(--green-light)}
.wf-step.active-step{background:var(--gold-pale)}
.wf-num{font-family:'IBM Plex Mono',monospace;font-size:1rem;font-weight:700;color:var(--navy);margin-bottom:3px}
.wf-step.done .wf-num{color:var(--green)}
.wf-step.active-step .wf-num{color:var(--amber)}
.wf-label{font-size:0.68rem;color:var(--text3);line-height:1.3}
.wf-step.done .wf-label{color:var(--green)}
.db-status-bar{display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--surface);border-radius:7px;border:1px solid var(--border);margin-bottom:12px;flex-wrap:wrap}
.db-dot{width:9px;height:9px;border-radius:50%;background:#ccc;flex-shrink:0;transition:background .3s}
.db-dot.connected{background:var(--green)}
.db-dot.syncing{background:var(--amber);animation:blink .7s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.db-label{font-size:0.75rem;color:var(--text3);flex:1;font-family:'IBM Plex Mono',monospace}
.db-label strong{color:var(--text);font-weight:600}
.shift-day{background:#eaf4ec;color:var(--green);border:1px solid #b0d8b5}
.shift-half{background:#f0f7e6;color:#4a7a00;border:1px solid #c8e0a0}
.shift-eve{background:var(--blue-light);color:var(--blue);border:1px solid #b0c8f0}
.shift-night{background:var(--amber-light);color:var(--amber);border:1px solid #f0c070}
.shift-ovnt{background:var(--purple-light);color:var(--purple);border:1px solid #c0a8e8}
.data-table{width:100%;border-collapse:collapse;font-size:0.78rem}
.data-table th{background:var(--navy2);color:var(--gold-light);padding:7px 12px;text-align:left;font-size:0.66rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em}
.data-table td{padding:7px 12px;border-bottom:1px solid #f0ede5;color:var(--text2)}
.data-table tr:last-child td{border-bottom:none}
.data-table tr:hover td{background:#fafaf7}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
.overlay.open{display:flex}
.modal{background:#fff;border-radius:12px;padding:24px;width:100%;max-width:440px;box-shadow:0 20px 60px rgba(0,0,0,.3)}
.modal h3{font-family:'Noto Serif Thai',serif;font-size:1.1rem;font-weight:700;color:var(--navy);margin-bottom:12px}
.modal p{font-size:0.82rem;color:var(--text2);margin-bottom:16px;line-height:1.7}
.modal .btn-row{justify-content:flex-end;margin-top:18px}
.modal-lg{max-width:580px}
.toast-container{position:fixed;bottom:20px;right:20px;z-index:999;display:flex;flex-direction:column;gap:8px;pointer-events:none}
.toast{background:var(--navy);color:#fff;padding:10px 16px;border-radius:8px;font-size:0.78rem;border-left:4px solid var(--gold);min-width:200px;max-width:320px;opacity:0;transform:translateY(12px);transition:all .25s;pointer-events:auto}
.toast.show{opacity:1;transform:translateY(0)}
.toast.toast-ok{border-left-color:var(--teal)}.toast.toast-warn{border-left-color:var(--amber)}.toast.toast-err{border-left-color:var(--red)}

/* ═══════════════════════════════════════════════════════
   CALENDAR TAB
═══════════════════════════════════════════════════════ */
.cal-nav{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.cal-month-display{font-family:'Noto Serif Thai',serif;font-size:1.2rem;font-weight:700;color:var(--navy);flex:1;text-align:center}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.cal-dow{text-align:center;font-size:.63rem;font-weight:700;color:var(--text3);padding:4px 0;font-family:'IBM Plex Mono',monospace}
.cal-day{border:1px solid var(--border);border-radius:7px;padding:6px 4px 5px;cursor:pointer;transition:all .12s;min-height:58px;display:flex;flex-direction:column;align-items:center;gap:2px;position:relative;user-select:none}
.cal-day.empty{border-color:transparent!important;cursor:default;background:none!important}
.cal-day .day-num{font-family:'IBM Plex Mono',monospace;font-size:.88rem;font-weight:700}
.cal-day .day-lbl{font-size:.57rem;font-weight:700;padding:1px 5px;border-radius:8px;margin-top:auto}
.cal-day.type-weekday{background:#fff}.cal-day.type-weekday:hover{border-color:var(--teal)}
.cal-day.type-weekday .day-num{color:var(--text)}
.cal-day.type-weekday .day-lbl{background:var(--teal-light);color:var(--teal)}
.cal-day.type-preHoliday{background:var(--amber-light);border-color:#e0c870}.cal-day.type-preHoliday:hover{border-color:var(--amber)}
.cal-day.type-preHoliday .day-num{color:var(--amber)}
.cal-day.type-preHoliday .day-lbl{background:rgba(179,106,0,.12);color:var(--amber)}
.cal-day.type-holiday{background:var(--red-light);border-color:#e8a09b}.cal-day.type-holiday:hover{border-color:var(--red)}
.cal-day.type-holiday .day-num{color:var(--red)}
.cal-day.type-holiday .day-lbl{background:rgba(181,48,42,.1);color:var(--red)}
.hol-star{position:absolute;top:2px;right:4px;background:none;border:none;cursor:pointer;font-size:.72rem;line-height:1;padding:0}
.hol-star:hover{opacity:.6}
.cal-legend{display:flex;gap:14px;flex-wrap:wrap;font-size:.72rem;margin-top:10px}
/* ═══════════════════════════════════════════════════════
   POSITIONS TAB
═══════════════════════════════════════════════════════ */
.pos-panels{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
@media(max-width:1100px){.pos-panels{grid-template-columns:1fr 1fr}}
@media(max-width:700px){.pos-panels{grid-template-columns:1fr}}
.pos-panel{background:#fff;border:1px solid var(--border);border-radius:9px;overflow:hidden}
.pos-phead{padding:10px 14px;display:flex;align-items:center;justify-content:space-between}
.pos-phead h3{font-size:.78rem;font-weight:700;color:#fff}
.pos-slot{display:flex;align-items:center;gap:8px;padding:9px 14px;border-top:1px solid #f0ede5}
.pos-slot-label{flex:1}
.pos-slot-name{font-size:.8rem;color:var(--text2);font-weight:500}
.pos-slot-meta{display:flex;gap:4px;align-items:center;margin-top:3px}
.pos-cnt{display:flex;align-items:center;gap:6px}
.pos-btn{width:28px;height:28px;border:1px solid var(--border);border-radius:6px;background:#fff;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:background .1s;line-height:1}
.pos-btn:hover{background:var(--surface)}
.pos-val{font-family:'IBM Plex Mono',monospace;font-size:1rem;font-weight:700;color:var(--navy);min-width:28px;text-align:center}


/* ═══════════════════════════════════════════════════════
   SCHEDULE TABLE (Tab 06) — SMC v5_6 style
═══════════════════════════════════════════════════════ */
.schedule-scroll{overflow-x:auto;border-radius:7px;border:1px solid var(--border)}
table.sched{border-collapse:collapse;font-size:0.7rem;min-width:100%}
table.sched th{background:var(--navy);color:rgba(255,255,255,.65);padding:6px 5px;text-align:center;font-weight:500;font-size:0.65rem;white-space:nowrap;letter-spacing:.03em;position:sticky;top:0;z-index:10;border-right:1px solid rgba(255,255,255,.1)}
table.sched th.grp-head{font-family:'Noto Serif Thai',serif;font-size:0.72rem;color:var(--gold-light);background:var(--navy2)}
table.sched th.grp-head.h-eve{background:#1a3a6b}
table.sched th.grp-head.h-night{background:#4a3000}
table.sched th.grp-head.h-ovnt{background:#3a1a5a}
table.sched th.grp-head.h-full{background:#1a4a2a}
table.sched th.shift-head{font-size:0.6rem;opacity:.8;font-family:'IBM Plex Mono',monospace}
table.sched td{padding:3px 4px;border:1px solid #e9e4db;vertical-align:top}
table.sched td.day-cell{background:var(--navy2);color:rgba(255,255,255,.75);font-family:'IBM Plex Mono',monospace;font-size:0.68rem;text-align:center;padding:5px 4px;white-space:nowrap;min-width:44px;position:sticky;left:0;z-index:5}
table.sched td.day-cell.sat{background:#6b3a00;color:#ffe8c0}
table.sched td.day-cell.sun{background:#4a1a1a;color:#ffcccc}
table.sched td.day-cell.holiday{background:#7a0d0d;color:#ffaaaa}
table.sched td.day-cell.preHoliday{background:#5a3a00;color:#ffd080}
table.sched tr:hover td:not(.day-cell){background:#fffdf5}
table.sched td.na-cell{background:#f5f5f2;opacity:.25;min-width:20px}
.slot-pill{display:flex;align-items:center;gap:2px;background:var(--teal-light);border:1px solid #b0ddd7;border-radius:3px;padding:2px 4px;cursor:default;margin-bottom:2px}
.slot-pill.locked{border-style:dashed;background:#e8f8f5}
.slot-pill.override{border-color:var(--amber)!important;background:var(--amber-light)!important}
.slot-pill.s-eve{background:var(--blue-light);border-color:#b0c8f0}
.slot-pill.s-night{background:var(--amber-light);border-color:#f0c070}
.slot-pill.s-ovnt{background:var(--purple-light);border-color:#c0a8e8}
.slot-pill.s-full{background:var(--green-light);border-color:#b0d8b5}
.slot-pill .sn{font-size:0.65rem;color:var(--text);font-weight:600;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:75px}
.slot-pill.s-eve .sn{color:var(--blue)}.slot-pill.s-night .sn{color:var(--amber)}.slot-pill.s-ovnt .sn{color:var(--purple)}.slot-pill.s-full .sn{color:var(--green)}
.lock-btn{background:none;border:none;cursor:pointer;font-size:0.68rem;line-height:1;padding:0 1px;opacity:.32;transition:opacity .1s;flex-shrink:0}
.lock-btn:hover{opacity:1}.lock-btn.locked-on{opacity:1}
.slot-pill .sx{color:var(--text3);opacity:.28;cursor:pointer;font-size:0.65rem;flex-shrink:0}.slot-pill .sx:hover{opacity:1;color:var(--red)}
.slot-empty{border:1px dashed #ccc;border-radius:3px;padding:3px 6px;font-size:0.62rem;color:#bbb;text-align:center;cursor:pointer;transition:all .1s;margin-bottom:2px;white-space:nowrap}.slot-empty:hover{border-color:var(--gold);color:var(--amber);background:var(--gold-pale)}
.slot-empty.req{border-color:var(--red);color:var(--red);background:var(--red-light)}
@media print{
  .sidebar,.topbar,.btn-row,button:not(.lock-btn){display:none!important}
  table.sched{font-size:6.5pt}
  table.sched th,table.sched td.day-cell{-webkit-print-color-adjust:exact;print-color-adjust:exact}
}


/* ═══════════════════════════════════════════════════════
   STATS TAB (07) + HISTORY TAB (08)
═══════════════════════════════════════════════════════ */
.stats-table{width:100%;border-collapse:collapse;font-size:.76rem}
.stats-table th{background:var(--navy2);color:var(--gold-light);padding:7px 10px;text-align:center;font-size:.63rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap;position:sticky;top:0}
.stats-table th:first-child{text-align:left}
.stats-table td{padding:6px 10px;border-bottom:1px solid #f0ede5;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:.73rem}
.stats-table td:first-child{text-align:left;font-family:'Noto Sans Thai',sans-serif;font-weight:600;font-size:.78rem}
.stats-table tr:hover td{background:#fafaf7}
.stats-table .over{color:var(--red);font-weight:700}
.stats-table .zero{color:var(--text3);opacity:.4}
.stats-table .total-row td{background:var(--navy2)!important;color:var(--gold-light);font-weight:700;border-bottom:none}
.sigma-badge{font-family:'IBM Plex Mono',monospace;font-size:2rem;font-weight:500;line-height:1}
.sigma-ok{color:var(--green)}.sigma-warn{color:var(--amber)}.sigma-bad{color:var(--red)}
.hist-month-card{background:#fff;border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:10px}
.hist-month-head{padding:8px 14px;background:var(--navy);display:flex;align-items:center;justify-content:space-between;cursor:pointer;user-select:none}
.hist-month-head h4{color:var(--gold-light);font-size:.78rem;font-weight:700}
.hist-month-body{padding:12px 14px;display:none}
.hist-month-card.expanded .hist-month-body{display:block}
.hist-month-card.expanded .hist-toggle{transform:rotate(180deg)}
.hist-toggle{color:var(--gold);font-size:.7rem;transition:transform .2s}

/* ═══════════════════════════════════════════════════════
   COMMAND CENTER — Hero + Executive KPIs  (v2.5 redesign)
═══════════════════════════════════════════════════════ */
.cc-hero{position:relative;overflow:hidden;border-radius:13px;margin-bottom:16px;padding:24px 28px;
  background:linear-gradient(118deg,var(--navy) 0%,var(--navy2) 58%,#16344f 100%);border:1px solid #14304a}
.cc-hero::after{content:"";position:absolute;right:-70px;top:-70px;width:260px;height:260px;border-radius:50%;
  background:radial-gradient(circle,rgba(200,168,75,.18),transparent 68%);pointer-events:none}
.cc-hero::before{content:"⚕";position:absolute;right:30px;bottom:-34px;font-size:160px;line-height:1;
  color:rgba(255,255,255,.045);font-family:'Noto Serif Thai',serif;pointer-events:none}
.cc-hero-tag{font-family:'IBM Plex Mono',monospace;font-size:.6rem;letter-spacing:.24em;text-transform:uppercase;
  color:var(--gold);display:inline-flex;align-items:center;gap:8px;margin-bottom:10px;position:relative}
.cc-hero-tag::before{content:"";width:20px;height:1px;background:var(--gold)}
.cc-hero h1{font-family:'Noto Serif Thai',serif;font-size:1.5rem;font-weight:700;color:#fff;line-height:1.25;
  margin-bottom:9px;position:relative}
.cc-hero h1 span{color:var(--gold-light)}
.cc-hero-copy{font-size:.83rem;line-height:1.65;color:rgba(255,255,255,.74);max-width:76ch;position:relative}
.cc-hero-en{font-size:.68rem;line-height:1.5;color:rgba(255,255,255,.42);max-width:80ch;font-style:italic;
  margin-top:4px;position:relative}
.cc-hero-pills{display:flex;gap:9px;flex-wrap:wrap;margin-top:16px;position:relative}
.cc-vp{display:inline-flex;align-items:center;gap:7px;padding:6px 13px;border-radius:8px;font-size:.7rem;
  font-weight:600;color:var(--gold-light);background:rgba(255,255,255,.06);border:1px solid rgba(200,168,75,.34)}
.cc-vp .i{font-size:.85rem}

.cc-kpis{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:14px}
.cc-kpi{position:relative;background:#fff;border:1px solid var(--border);border-radius:12px;
  padding:17px 20px 16px;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 1px 2px rgba(13,27,42,.04)}
.cc-kpi::before{content:"";position:absolute;left:0;top:0;bottom:0;width:4px}
.cc-kpi.k-teal::before{background:var(--teal)} .cc-kpi.k-purple::before{background:var(--purple)}
.cc-kpi.k-gold::before{background:var(--gold)}
.cc-kpi-top{display:flex;align-items:center;gap:11px;margin-bottom:13px}
.cc-kpi-ico{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;
  font-size:1.05rem;flex-shrink:0}
.cc-kpi.k-teal .cc-kpi-ico{background:var(--teal-light);color:var(--teal)}
.cc-kpi.k-purple .cc-kpi-ico{background:var(--purple-light);color:var(--purple)}
.cc-kpi.k-gold .cc-kpi-ico{background:var(--gold-pale);color:#9a7400}
.cc-kpi-label{font-size:.66rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text2);line-height:1.3}
.cc-kpi-en{font-size:.57rem;font-family:'IBM Plex Mono',monospace;color:#a8a499;letter-spacing:.05em;text-transform:uppercase;margin-top:1px}
.cc-kpi-val{font-family:'IBM Plex Mono',monospace;font-size:2.5rem;font-weight:500;color:var(--navy);line-height:1;
  display:flex;align-items:baseline;gap:6px}
.cc-kpi-unit{font-size:.82rem;color:var(--text3);font-weight:500}
.cc-kpi-sub{font-size:.7rem;color:var(--text3);margin-top:8px;line-height:1.4}

.cc-mini{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px}
.cc-mini .stat-card{padding:12px 15px;border-radius:10px}
.cc-mini .stat-big{font-size:1.5rem}
@media(max-width:860px){.cc-kpis,.cc-mini{grid-template-columns:1fr}}

/* ── Schedule matrix — modern monitoring refinements (table.sched) ── */
.schedule-scroll{border-radius:10px;box-shadow:0 1px 3px rgba(13,27,42,.05)}
table.sched{font-size:0.72rem}
table.sched th{padding:7px 6px;box-shadow:inset 0 -2px 0 rgba(200,168,75,.55)}
table.sched td{padding:4px 5px;border:1px solid #eceae3}
table.sched tbody tr:nth-child(even) td:not(.day-cell):not(.na-cell){background:#fbfaf7}
table.sched tr:hover td:not(.day-cell){background:var(--gold-pale)}
table.sched td.day-cell{min-width:48px;box-shadow:2px 0 5px rgba(13,27,42,.13)}
.slot-pill{border-radius:5px;padding:2px 5px;transition:transform .08s,box-shadow .08s}
.slot-pill:hover{transform:translateY(-1px);box-shadow:0 2px 5px rgba(13,27,42,.1)}
.slot-empty{border-radius:5px}

/* ── Optional: same polish for the hours-summary matrix (.stats-table) ── */
.stats-table tbody tr:nth-child(even) td{background:#fbfaf7}
.stats-table tr:hover td{background:var(--gold-pale)}

</style>
</head>
