function ceYear(){ return S.calState.year - 543; }
function daysInCurrMonth(){ return new Date(ceYear(), S.calState.month, 0).getDate(); }

function initMonthDayTypes(){
  const days = daysInCurrMonth();
  const m=S.calState.month, cY=ceYear();
  const h = new Set(S.calState.holidays||[]);
  const types = {};
  for(let d=1;d<=days;d++){
    const dow=new Date(cY,m-1,d).getDay();
    types[d]=(h.has(d)||dow===0||dow===6)?'holiday':'weekday';
  }
  // preHoliday: weekday whose next day is holiday
  for(let d=1;d<=days;d++){
    if(types[d]==='weekday' && d+1<=days && types[d+1]==='holiday') types[d]='preHoliday';
  }
  S.calState.dayTypes=types;
}

/* ── per-month persistence helpers ── */
function _calKey(m,y){ return `${y}-${String(m).padStart(2,'0')}`; }

function _saveCalMonth(){
  if(!S.monthData) S.monthData={};
  const key=_calKey(S.calState.month, S.calState.year);
  S.monthData[key]={
    dayTypes: JSON.parse(JSON.stringify(S.calState.dayTypes||{})),
    holidays: [...(S.calState.holidays||[])]
  };
}

function _loadCalMonth(m,y){
  if(!S.monthData) S.monthData={};
  const key=_calKey(m,y);
  if(S.monthData[key]){
    S.calState.dayTypes=JSON.parse(JSON.stringify(S.monthData[key].dayTypes||{}));
    S.calState.holidays=[...(S.monthData[key].holidays||[])];
  } else {
    S.calState.dayTypes={}; S.calState.holidays=[];
    // S.calState.month/year already updated by caller
    initMonthDayTypes();
  }
}

function getEffectiveDayType(day){
  const dt=S.calState.dayTypes;
  if(dt && dt[day]!==undefined) return dt[day];
  const m=S.calState.month, cY=ceYear();
  const dow=new Date(cY,m-1,day).getDay();
  const h=new Set(S.calState.holidays||[]);
  if(h.has(day)||dow===0||dow===6) return 'holiday';
  const days=daysInCurrMonth();
  if(day+1<=days){
    const nDow=new Date(cY,m-1,day+1).getDay();
    if(h.has(day+1)||nDow===0||nDow===6) return 'preHoliday';
  }
  return 'weekday';
}

function cycleDayType(day){
  if(!S.calState.dayTypes) S.calState.dayTypes={};
  const cur=getEffectiveDayType(day);
  const nxt={weekday:'preHoliday',preHoliday:'holiday',holiday:'weekday'}[cur]||'weekday';
  S.calState.dayTypes[day]=nxt;
  autoSave(); renderCalendarTab();
}

function toggleHolidayMark(day){
  if(!S.calState.holidays) S.calState.holidays=[];
  const idx=S.calState.holidays.indexOf(day);
  if(!S.calState.dayTypes) S.calState.dayTypes={};
  if(idx>=0){
    S.calState.holidays.splice(idx,1);
    delete S.calState.dayTypes[day];
  } else {
    S.calState.holidays.push(day); S.calState.holidays.sort((a,b)=>a-b);
    S.calState.dayTypes[day]='holiday';
    // mark previous day preHoliday if weekday
    if(day>1){
      const pd=day-1, pdDow=new Date(ceYear(),S.calState.month-1,pd).getDay();
      if(pdDow!==0&&pdDow!==6&&!S.calState.holidays.includes(pd))
        S.calState.dayTypes[pd]='preHoliday';
    }
  }
  autoSave(); renderCalendarTab(); renderDashboard();
}

