/**
 * generateDataFingerprint()
 * Produces a deterministic 7-char base-36 hash from the
 * canonical form of S.pharmacists (id, name, flags, comp, dept).
 * Changes whenever any profile field or comp hour is edited.
 */
function generateDataFingerprint() {
  const canon = S.pharmacists
    .map(p => [
      p.id,
      p.name,
      p.deptPriority || '',
      p.department || '',
      p.flags.age50plus  ? 1 : 0,
      p.flags.inactive   ? 1 : 0,
      getCompRoles().map(r=>r.id+':'+(p.comp[r.id]||0)).join(',')
    ])
    .sort((a, b) => a[0].localeCompare(b[0]));

  const str = JSON.stringify(canon) + '|n=' + S.pharmacists.length;

  // djb2 hash → unsigned 32-bit → base-36 uppercase (7 chars)
  let h = 5381;
  for (let i = 0; i < str.length; i++) {
    h = Math.imul(h, 33) ^ str.charCodeAt(i);
  }
  return (h >>> 0).toString(36).toUpperCase().padStart(7, '0').slice(-7);
}

function renderFingerprintBadge() {
  const el = document.getElementById('fp-badge');
  if (!el) return;
  const fp = generateDataFingerprint();
  el.textContent = 'FP:' + fp;
}

